# Next.js 프론트 환경변수 — apps/web/.env.local 에 복사 후 채워 사용.

# NestJS API base URL
NEXT_PUBLIC_API_URL=http://localhost:4000

# Dev auth — apiClient 가 모든 요청에 x-dev-user-id 헤더로 전송.
# DevAuthMiddleware(ADR-0006) 가 이 id 로 users 테이블 조회 → req.authUser 채움.
# 🚨 프로덕션 빌드에 포함되면 안 됨. prisma/backfill-dev-admin-user.sql 로 생성한
#    dev user 의 UUID 와 일치시킬 것.
NEXT_PUBLIC_DEV_USER_ID=00000000-0000-0000-0000-00000000d001
