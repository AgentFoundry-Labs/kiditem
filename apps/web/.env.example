# Next.js 프론트 환경변수 — apps/web/.env.local 에 복사 후 채워 사용.

# NestJS API base URL
NEXT_PUBLIC_API_URL=http://localhost:4000

# Supabase Auth — `supabase.auth.signInWithPassword` 가 토큰 쿠키를 자동 관리.
# Supabase Dashboard → Settings → API → Project URL / anon public.
# 첫 셋업 절차: docs/runbooks/auth-supabase.md 참고.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
