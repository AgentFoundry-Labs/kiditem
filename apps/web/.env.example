# Next.js 프론트 환경변수 — apps/web/.env.local 에 복사 후 채워 사용.

# NestJS API base URL
NEXT_PUBLIC_API_URL=http://localhost:4000

# Supabase Auth — `supabase.auth.signInWithPassword` 가 토큰 쿠키를 자동 관리.
# Supabase Dashboard → Settings → API Keys → Project URL / publishable key (`sb_publishable_...`).
# 첫 셋업 절차: docs/runbooks/auth-supabase.md 참고.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional — enable TanStack Query Devtools in local development.
# Off by default so stale Next dev chunks cannot block the app shell.
NEXT_PUBLIC_ENABLE_QUERY_DEVTOOLS=false
