NODE_ENV=development
PORT=4000
CORS_ORIGINS=http://localhost:3000
API_SELF_URL=http://localhost:4000

# Prisma/NestJS main connection.
DATABASE_URL=postgresql://kiditem:kiditem@localhost:5433/kiditem

# Supabase Auth — `Authorization: Bearer <token>` 또는 Supabase SSR auth-token 쿠키를 검증.
# Supabase Dashboard → Settings → API Keys.
SUPABASE_URL=
# scripts/sync-supabase-user.ts 전용. 절대 프론트/git 노출 금지.
SUPABASE_SECRET_KEY=

# Channel credentials encryption key — 32 bytes as base64, hex, or raw UTF-8.
# Generate locally with: openssl rand -base64 32
CHANNEL_CREDENTIALS_ENCRYPTION_KEY=

# S3-compatible storage. Local dev defaults to MinIO when these are empty, but
# setting them here makes local behavior match staging/prod more closely.
S3_REGION=us-east-1
S3_BUCKET=kiditem
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_URL=http://localhost:9000/kiditem
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# Server-side Gemini AI. Required for local AI feature testing.
GEMINI_API_KEY=
# Standalone/synchronous text paths: text transform, detail prefill, and
# no-product detail preview. Product-bound Agent OS jobs use `AGENT_*_MODEL`.
AI_TEXT_MODEL=gemini-2.5-flash
# Gemini media/vision paths: thumbnail editor image generation, detail-page
# generated images, and image analysis. This is not the Agent OS run model.
AI_IMAGE_MODEL=gemini-3.1-flash-image-preview
AI_IMAGE_ANALYSIS_MODEL=gemini-3.1-flash-lite-preview
AI_IMAGE_ANALYSIS_VERIFY_MODEL=gemini-3.1-flash-lite-preview

# Agent OS runtime. The background worker is disabled locally by default, but
# product-bound detail page / thumbnail generation may still execute immediately
# through Agent OS, so model env must be explicit.
AGENT_RUNTIME_WORKER_ENABLED=0
AGENT_RUNTIME_WORKER_INTERVAL_MS=2000
AGENT_RUNTIME_ALLOW_NOOP=0
AGENT_DEFAULT_MODEL=gemini-2.5-flash
AGENT_MANAGER_MODEL=
AGENT_RULES_EVALUATION_MODEL=
AGENT_RULES_SUGGEST_MODEL=
AGENT_AD_STRATEGY_MODEL=
AGENT_SOURCING_MODEL=
AGENT_THUMBNAIL_ANALYST_MODEL=gemini-3.1-pro-preview
AGENT_IMAGE_EDIT_MODEL=gemini-3.1-flash-image-preview
AGENT_THUMBNAIL_AUTO_EDIT_MODEL=gemini-3.1-flash-image-preview
AGENT_DETAIL_PAGE_GENERATE_MODEL=gemini-2.5-flash
AGENT_THUMBNAIL_GENERATE_MODEL=gemini-3.1-flash-image-preview
AGENT_CHAT_MODEL=
# Optional seed scope for Agent OS seed entrypoints. Empty means every active
# organization in the target database.
AGENT_SEED_ORG_IDS=

# Claude CLI chat/agent auth. Optional if the local `claude` CLI is already
# authenticated another way.
ANTHROPIC_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=

# Puppeteer render path. Docker/staging may set this to /usr/bin/chromium.
PUPPETEER_EXECUTABLE_PATH=

# Playwriter Wing image sync (optional local overrides)
PLAYWRITER_BIN=
PLAYWRITER_BROWSER_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
PLAYWRITER_BROWSER_PROFILE_DIR=
PLAYWRITER_DIRECT_PORT=9222
