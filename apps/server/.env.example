# Prisma/NestJS main connection.
DATABASE_URL=postgresql://kiditem:kiditem@localhost:5433/kiditem

# Supabase Auth — `Authorization: Bearer <token>` 또는 Supabase SSR auth-token 쿠키를 검증.
# Supabase Dashboard → Settings → API Keys.
SUPABASE_URL=
# scripts/sync-supabase-user.ts 전용. 절대 프론트/git 노출 금지.
SUPABASE_SECRET_KEY=

# Channel credentials encryption key — 32 bytes as base64, hex, or raw UTF-8.
# Generate locally with: openssl rand -base64 32
CHANNEL_CREDENTIALS_ENCRYPTION_KEY=

# Server-side Gemini AI. Required for local AI feature testing.
GEMINI_API_KEY=
AI_TEXT_MODEL=gemini-2.5-flash
AI_IMAGE_MODEL=gemini-3.1-flash-image-preview
AI_IMAGE_ANALYSIS_MODEL=gemini-3.1-flash-lite-preview
AI_IMAGE_ANALYSIS_VERIFY_MODEL=gemini-3.1-flash-lite-preview

# Playwriter Wing image sync (optional local overrides)
# PLAYWRITER_BIN=/absolute/path/to/playwriter
# PLAYWRITER_BROWSER_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# PLAYWRITER_BROWSER_PROFILE_DIR=/Users/me/.kiditem/wing-cdp-profile
# PLAYWRITER_DIRECT_PORT=9222
