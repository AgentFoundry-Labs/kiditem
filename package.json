{
  "name": "kiditem",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "npm run dev --workspace=apps/web",
    "clean:web-cache": "node -e \"require('fs').rmSync('apps/web/.next/dev/cache',{recursive:true,force:true})\"",
    "dev:server": "npm run start:dev --workspace=apps/server",
    "dev:agents": "cd agents && .venv/bin/uvicorn src.server:app --host 0.0.0.0 --port 8001 --reload",
    "dev:all": "concurrently -n web,server,agents -c blue,green,yellow \"npm run dev\" \"npm run dev:server\" \"npm run dev:agents\"",
    "build": "npm run build --workspace=apps/web && npm run build --workspace=apps/server",
    "hooks:install": "git config core.hooksPath .githooks",
    "check:agents-hygiene": "node scripts/check-agents-hygiene.mjs",
    "check:pr-reconstruction": "node scripts/check-pr-reconstruction-contract.mjs",
    "check:pr-release-contract": "node scripts/check-pr-release-contract.mjs",
    "check:scripts-inventory": "node scripts/check-script-inventory.mjs",
    "check:schema-artifact-sync": "node scripts/check-schema-artifact-sync.mjs",
    "check:directory-architecture": "node scripts/check-directory-architecture.mjs",
    "check:web-db-boundary": "./scripts/check-frontend-db-boundary.sh",
    "check:idor": "./scripts/check-queryraw-tenancy.sh",
    "check:tenant-scope": "./scripts/check-tenant-scope.sh",
    "check:raw-snapshot-read-models": "bash scripts/check-raw-snapshot-read-models.sh",
    "check:shared-interface-names": "node scripts/check-shared-interface-names.mjs",
    "check:shared-root-imports": "bash scripts/check-shared-root-imports.sh",
    "check:conventions": "npm run check:agents-hygiene && npm run check:scripts-inventory && npm run check:schema-artifact-sync && npm run check:directory-architecture && npm run check:web-db-boundary && npm run check:idor && npm run check:tenant-scope && npm run check:raw-snapshot-read-models && npm run check:shared-interface-names && npm run check:shared-root-imports",
    "knip:report": "knip --no-exit-code --no-progress --reporter compact",
    "test:scripts": "vitest run --config scripts/vitest.config.ts && node --test scripts/__tests__/*.test.mjs",
    "db:erd": "node scripts/generate-prisma-erd.mjs",
    "graphify:schema": "npm run db:erd && uv run --with graphifyy --python 3.11 python scripts/generate-schema-graphify.py",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "import:product-baseline": "tsx scripts/import-product-baseline.ts",
    "data:dev:status": "tsx scripts/dev-data.ts status",
    "data:dev:setup": "tsx scripts/dev-data.ts setup",
    "data:dev:pull": "tsx scripts/dev-data.ts pull",
    "data:dev:sync": "tsx scripts/dev-data.ts sync",
    "data:dev:export": "tsx scripts/dev-data.ts export",
    "data:dev:sanitize": "tsx scripts/dev-data.ts sanitize",
    "data:dev:replay": "tsx scripts/dev-data.ts replay",
    "data:dev:pack": "tsx scripts/dev-data.ts pack",
    "data:dev:publish": "tsx scripts/dev-data.ts publish",
    "data:migrate": "tsx scripts/run-data-migrations.ts",
    "staging:db": "tsx scripts/staging-db-baseline.ts",
    "seed:agent-os": "tsx scripts/seed-agent-os.ts",
    "db:test:up": "docker compose -f docker-compose.test.yml up -d --wait",
    "db:test:down": "docker compose -f docker-compose.test.yml down -v",
    "db:test:prepare": "bash prisma/test-db-setup.sh",
    "test:integration": "DATABASE_URL=postgresql://kiditem_test:kiditem_test@localhost:5434/kiditem_test npm run test:integration --workspace=apps/server"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1029.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@supabase/supabase-js": "^2.103.2",
    "concurrently": "^9.2.1",
    "dotenv": "^16.6.1",
    "knip": "^6.7.0",
    "playwriter": "^0.1.0",
    "prisma": "^7.5.0",
    "tsx": "^4.21.0",
    "vitest": "^4.1.2",
    "xlsx": "npm:@e965/xlsx@^0.20.3"
  },
  "overrides": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@google/genai": {
      "protobufjs": "7.5.6"
    },
    "@google/genai@1.52.0": {
      "protobufjs": "7.5.6"
    },
    "@hono/node-server": "1.19.14",
    "@langchain/core": {
      "langsmith": "0.6.3"
    },
    "@langchain/core@1.1.45": {
      "langsmith": "0.6.3"
    },
    "@langchain/langgraph-sdk": {
      "uuid": "13.0.2"
    },
    "@langchain/langgraph-sdk@1.8.8": {
      "uuid": "13.0.2"
    },
    "basic-ftp": "6.0.1",
    "express": "^5.2.0",
    "express-rate-limit": "8.5.1",
    "fast-xml-parser": "5.7.3",
    "hono": "4.12.18",
    "ip-address": "10.2.0",
    "langchain": {
      "langsmith": "0.6.3"
    },
    "langsmith": "0.6.3",
    "postcss": "8.5.14",
    "protobufjs": "7.5.6",
    "uuid": "11.1.1"
  },
  "dependencies": {
    "@ag-ui/client": "^0.0.53"
  }
}
