# KidItem environment variables (root level).
# Consumed by apps/server, apps/web, and agents/.
# For per-app env files see apps/server/.env.example and agents/.env.example.

# DATABASE_URL — Prisma/NestJS main connection (owner: kiditem, full table privileges)
DATABASE_URL=postgresql://user:password@localhost:5432/kiditem

# AGENT_DATABASE_URL — Python agents / Claude CLI chatbot (readonly, RLS session var 'app.organization_id')
# Format: postgresql://chatbot_readonly:chatbot_readonly@localhost:5433/kiditem?options=-c%20app.organization_id%3D{company_uuid}
CHATBOT_DATABASE_URL=

# Coupang Wing API — vendor credentials (SKU push, ads, sales)
COUPANG_ACCESS_KEY=
COUPANG_SECRET_KEY=
COUPANG_VENDOR_ID=

# AI runtime mode — proxy (VectorEngine) or direct
AI_MODE=cloud
# AI_BASE_URL — used when AI_MODE=proxy (e.g. https://api.vectorengine.ai/v1)
AI_BASE_URL=
# OPENAI_API_KEY — OpenAI SDK (sk-...)
OPENAI_API_KEY=
# GEMINI_API_KEY — Google Gemini (AI...). Also used by NestJS workflow analysis.
GEMINI_API_KEY=
# VECTORENGINE_API_KEY — proxy mode only (sk-...)
VECTORENGINE_API_KEY=
# FAL_KEY — fal.ai (image edit models)
FAL_KEY=

# AI Models — per-task model selection (no silent fallback — see ADR-0005)
# AI_TEXT_MODEL — copy/workflow text generation (e.g. gemini-2.5-flash)
AI_TEXT_MODEL=
# AI_IMAGE_ANALYSIS_MODEL — product image analysis (e.g. gemini-3.1-flash-lite-preview)
AI_IMAGE_ANALYSIS_MODEL=
# AI_IMAGE_ANALYSIS_VERIFY_MODEL — thumbnail compliance verification second-pass model
AI_IMAGE_ANALYSIS_VERIFY_MODEL=
# AI_IMAGE_MODEL — hero/banner image generation (e.g. gemini-3.1-flash-image-preview)
# Do not use gemini-2.5-flash-image-preview; that preview model is no longer available on generateContent.
AI_IMAGE_MODEL=
# AI_IMAGE_EDIT_MODEL — image editing (e.g. fal-ai/flux-2-pro/edit)
AI_IMAGE_EDIT_MODEL=
# AI_IMAGE_DETAIL_MODEL — detail image editing (e.g. fal-ai/flux-pro/kontext/max)
AI_IMAGE_DETAIL_MODEL=
# AI_IMAGE_EDIT_SIZE_MODEL — size chart editing (e.g. gemini-3.1-flash-image-preview)
AI_IMAGE_EDIT_SIZE_MODEL=

# Langfuse Cloud — LLM tracing (optional)
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Runner — Python agent poll interval (seconds)
POLL_INTERVAL_SECONDS=10

# Supabase Auth — JWKS 검증 + admin sync 스크립트.
# 프로젝트 생성: https://supabase.com/dashboard → Settings → API Keys.
# 첫 셋업: docs/runbooks/auth-supabase.md 참고.
SUPABASE_URL=
# Secret key (`sb_secret_...`). scripts/sync-supabase-user.ts 전용 — 절대 프론트/git 노출 금지.
SUPABASE_SECRET_KEY=

# Shared dev data — Google Drive Desktop local sync path and target org scope.
# Fresh local DBs may use 00000000-0000-4000-8000-000000000001 after
# docs/runbooks/import-drive-reference-data.md creates KidItem Dev.
KIDITEM_DEV_DATA_DRIVE_DIR=
KIDITEM_DEV_ORGANIZATION_ID=
