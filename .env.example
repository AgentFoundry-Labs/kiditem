# KidItem environment variables (root level).
# Consumed by root-level tooling: Prisma CLI, dev bootstrap, and dev data sync.
# App runtimes use app-local files:
# - apps/server/.env.example
# - apps/web/.env.example
# - agents/.env.example

# DATABASE_URL — Prisma CLI and root scripts main connection.
DATABASE_URL=postgresql://user:password@localhost:5432/kiditem

# Supabase Auth — JWKS 검증 + admin sync 스크립트.
# 프로젝트 생성: https://supabase.com/dashboard → Settings → API Keys.
# 첫 셋업: docs/runbooks/auth-supabase.md 참고.
# Stripe 모델: 이 프로젝트는 dev 전용. staging/prod 는 각자 별도 Supabase 프로젝트에서
# 자체 SUPABASE_URL/keys 를 가져야 한다. dev 키를 prod 환경에 올리지 않는다.
SUPABASE_URL=
# Secret key (`sb_secret_...`). 백엔드 JWT 검증 + scripts/sync-supabase-user.ts +
# bin/dev-bootstrap.sh 전용. 프론트/git 노출 금지. 환경별 분리 필수.
SUPABASE_SECRET_KEY=

# Dev preview auth — bin/dev-bootstrap.sh 가 어떤 사용자 이메일로 magic-link 를
# 발급할지. dev Supabase 프로젝트의 auth.users 에 이미 존재해야 한다. 미설정 시
# kiditem@naver.com (팀 공용 dev seed) 사용. docs/runbooks/dev-preview-with-auth.md.
DEV_USER_EMAIL=
# Preview/web origin for magic-link callback. Use the exact origin the isolated
# browser will run the web app on; host/port mismatch means cookies land on the
# wrong origin and the session looks missing.
DEV_WEB_ORIGIN=http://localhost:3000

# Shared dev data — Google Drive Desktop local sync path and target org scope.
# Fresh local DBs may use 00000000-0000-4000-8000-000000000001 after
# docs/runbooks/import-drive-reference-data.md creates KidItem Dev.
KIDITEM_DEV_DATA_DRIVE_DIR=
KIDITEM_DEV_ORGANIZATION_ID=
