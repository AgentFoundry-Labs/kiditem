generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Companies ────────────────────────────────────────────────────────────────

model Company {
  id             String   @id @default(uuid()) @db.Uuid
  name           String
  slug           String   @unique
  businessNumber String?  @map("business_number")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Core
  users          User[]
  products       Product[]
  inventory      Inventory[]
  orders         Order[]
  purchaseOrders PurchaseOrder[]
  ads            Ad[]
  profitLoss     ProfitLoss[]
  thumbnails     Thumbnail[]
  reviews        Review[]
  alerts         Alert[]

  // Sourcing & Content
  contentGenerations ContentGeneration[]

  // Workflow & Agent
  workflowTemplates WorkflowTemplate[]
  activityEvents    ActivityEvent[]
  agentDefinitions  AgentDefinition[]

  // Coupang
  coupangOrders  CoupangOrder[]
  coupangReturns CoupangReturn[]

  // Supplier & Procurement
  suppliers        Supplier[]
  supplierPayments SupplierPayment[]

  // Warehouse & Inventory Ops
  warehouses           Warehouse[]
  stockTransfers       StockTransfer[]
  stockTransactions    StockTransaction[]
  stockAudits          StockAudit[]

  // Logistics
  shipments    Shipment[]
  unshippedItems UnshippedItem[]
  pickingLists   PickingList[]
  returnTransfers ReturnTransfer[]

  // Product Extensions
  bundleProducts      BundleProduct[]
  processingCosts     ProcessingCost[]

  // Finance
  settlements    Settlement[]
  manualLedgers  ManualLedger[]

  // Operations & Config
  csRecords          CSRecord[]
  categoryMappings   CategoryMapping[]
  commonCodes        CommonCode[]
  optionMasters      OptionMaster[]

  // Analytics
  salesPlans             SalesPlan[]
  auditLogs              AuditLog[]

  // Ontology
  businessRules   BusinessRule[]
  systemSettings  SystemSetting[]

  // Agent Platform
  agentRuntimeStates    AgentRuntimeState[]
  heartbeatRuns         HeartbeatRun[]
  agentWakeupRequests   AgentWakeupRequest[]
  agentWorkflows        AgentWorkflow[]
  agentPermissionDenials AgentPermissionDenial[]
  agentActionSnapshots   AgentActionSnapshot[]

  // Ad Snapshots
  adCampaignSnapshots  AdCampaignSnapshot[]
  adProductSnapshots   AdProductSnapshot[]
  scrapeTargets        ScrapeTarget[]
  adSnapshots          AdSnapshot[]
  itemWinners          ItemWinner[]

  // Ad Execution
  adActions            AdAction[]
  executionWorkers     ExecutionWorker[]

  @@map("companies")
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id          String    @id @default(uuid()) @db.Uuid
  companyId   String    @map("company_id") @db.Uuid
  email       String    @unique
  name        String
  password    String?
  role        String    @default("member")
  team        String?
  avatarUrl   String?   @map("avatar_url")
  isActive    Boolean   @default(true) @map("is_active")
  lastLoginAt DateTime? @map("last_login_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("users")
}

// ─── Products ─────────────────────────────────────────────────────────────────

model Product {
  id          String   @id @default(uuid()) @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  name        String
  description String   @default("")
  sku         String?
  barcode     String?
  status      String   @default("draft")
  category    String?
  brand       String?
  tags        Json     @default("[]")
  thumbnailUrl String? @map("thumbnail_url")

  // Sourcing (kiditem)
  sourceUrl      String?  @map("source_url")
  sourcePlatform String?  @map("source_platform")
  costCny        Decimal? @map("cost_cny") @db.Decimal(12, 2)
  marginRate     Decimal? @map("margin_rate") @db.Decimal(5, 4)
  rawData        Json?    @map("raw_data")
  processedData  Json?    @map("processed_data")
  draftContent   Json?    @map("draft_content")
  pipelineStep   String?  @map("pipeline_step")
  detailPageUrl  String?  @map("detail_page_url")

  // Pricing
  costPrice      Int?     @map("cost_price")
  sellPrice      Int?     @map("sell_price")
  commissionRate Decimal? @map("commission_rate") @db.Decimal(5, 4)
  shippingCost   Int?     @map("shipping_cost")
  otherCost      Int?     @default(0) @map("other_cost")
  abcGrade       String?  @map("abc_grade")
  adTier         String?  @map("ad_tier")
  adBudgetLimit  Int?     @map("ad_budget_limit")

  // Coupang
  coupangProductId String? @map("coupang_product_id")

  // Delivery
  deliveryChargeType String? @map("delivery_charge_type")
  freeShipOverAmount Int?    @map("free_ship_over_amount")
  returnCharge       Int?    @map("return_charge")
  deliveryInfo       Json?   @map("delivery_info")
  images             Json?   @default("[]")
  imageUrl           String? @map("image_url")
  thumbnailStrategy  String  @default("standard") @map("thumbnail_strategy")

  // Health (Ontology Rules Engine)
  healthScore     Int?      @map("health_score")
  healthUpdatedAt DateTime? @map("health_updated_at") @db.Timestamptz

  // Soft delete
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  memo      String?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Core relations
  company    Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  inventory  Inventory?
  orders     Order[]
  ads        Ad[]
  profitLoss ProfitLoss[]
  thumbnails Thumbnail[]
  reviews    Review[]
  alerts     Alert[]
  purchaseOrderItems PurchaseOrderItem[]
  contentGenerations ContentGeneration[]
  productItems       ProductItem[]

  // Supplier & Procurement
  supplierProducts SupplierProduct[]

  // Warehouse & Inventory Ops
  stockTransfers    StockTransfer[]
  stockTransactions StockTransaction[]
  returnTransfers   ReturnTransfer[]

  // Logistics
  shipments      Shipment[]
  unshippedItems UnshippedItem[]

  // Product Extensions
  bundleItems      BundleItem[]
  productMemos     ProductMemo[]
  processingCosts  ProcessingCost[]

  // Analytics
  gradeHistory   GradeHistory[]
  trafficStats   TrafficStats[]
  adSnapshots    AdSnapshot[]
  itemWinners    ItemWinner[]
  adActions      AdAction[]

  @@unique([companyId, sku])
  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, isDeleted])
  @@index([status])
  @@index([abcGrade])
  @@index([pipelineStep])
  @@index([category])
  @@index([brand])
  @@index([isDeleted])
  @@map("products")
}

// ─── Inventory ────────────────────────────────────────────────────────────────

model Inventory {
  id        String @id @default(uuid()) @db.Uuid
  companyId String @map("company_id") @db.Uuid
  productId String @unique @map("product_id") @db.Uuid

  currentStock    Int   @default(0) @map("current_stock")
  reservedStock   Int   @default(0) @map("reserved_stock")
  safetyStock     Int   @default(0) @map("safety_stock")
  reorderPoint    Int   @default(0) @map("reorder_point")
  reorderQuantity Int   @default(0) @map("reorder_quantity")
  leadTimeDays    Int?  @map("lead_time_days")
  dailySalesAvg   Decimal @default(0) @map("daily_sales_avg") @db.Decimal(8, 2)

  lastRestockedAt DateTime? @map("last_restocked_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([productId])
  @@map("inventory")
}

// ─── Orders ───────────────────────────────────────────────────────────────────

model Order {
  id        String  @id @default(uuid()) @db.Uuid
  companyId String  @map("company_id") @db.Uuid
  productId String? @map("product_id") @db.Uuid

  orderNumber     String  @map("order_number")
  platform        String
  coupangOrderId  String? @map("coupang_order_id")
  customerName    String  @default("") @map("customer_name")
  productName     String  @map("product_name")
  quantity        Int     @default(1)
  unitPrice       Int     @map("unit_price")
  totalPrice      Int     @map("total_price")
  status          String  @default("pending")
  trackingNumber  String? @map("tracking_number")
  shippingCompany String? @map("shipping_company")

  // Receiver info (from dashboard)
  receiverName  String? @map("receiver_name")
  receiverPhone String? @map("receiver_phone")
  receiverAddr  String? @map("receiver_addr")
  memo          String?

  orderedAt   DateTime  @default(now()) @map("ordered_at") @db.Timestamptz
  shippedAt   DateTime? @map("shipped_at") @db.Timestamptz
  deliveredAt DateTime? @map("delivered_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product  Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  shipments Shipment[]

  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, orderedAt])
  @@index([productId])
  @@index([status])
  @@index([platform])
  @@index([orderedAt])
  @@map("orders")
}

// ─── Coupang Orders ──────────────────────────────────────────────────

model CoupangOrder {
  id            String   @id @default(uuid()) @db.Uuid
  companyId     String   @map("company_id") @db.Uuid
  shipmentBoxId String   @unique @map("shipment_box_id") @db.VarChar(30)
  orderId       String   @map("order_id") @db.VarChar(30)
  orderer       Json?
  receiver      Json?
  status        String   @default("ACCEPT")
  deliveryCompanyName String?  @map("delivery_company_name")
  invoiceNumber String?  @map("invoice_number")
  parcelPrintMessage  String?  @map("parcel_print_message")
  shippingPrice Int      @default(0) @map("shipping_price")
  totalPrice    Int      @default(0) @map("total_price")
  orderedAt     DateTime @map("ordered_at") @db.Timestamptz
  paidAt        DateTime? @map("paid_at") @db.Timestamptz
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  company       Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  orderItems    CoupangOrderItem[]

  @@index([companyId])
  @@index([status])
  @@index([orderedAt])
  @@map("coupang_orders")
}

model CoupangOrderItem {
  id            String   @id @default(uuid()) @db.Uuid
  orderId       String   @map("order_id") @db.Uuid

  vendorItemId      String  @map("vendor_item_id") @db.VarChar(30)
  vendorItemName    String  @default("") @map("vendor_item_name")
  sellerProductId   String? @map("seller_product_id") @db.VarChar(30)
  sellerProductName String  @default("") @map("seller_product_name")

  shippingCount           Int @default(1) @map("shipping_count")
  salesPrice              Int @default(0) @map("sales_price")
  orderPrice              Int @default(0) @map("order_price")
  instantCouponDiscount   Int @default(0) @map("instant_coupon_discount")

  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz

  order         CoupangOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([sellerProductId])
  @@map("coupang_order_items")
}

// ─── Coupang Returns ─────────────────────────────────────────────────

model CoupangReturn {
  id            String   @id @default(uuid()) @db.Uuid
  companyId     String   @map("company_id") @db.Uuid
  receiptId     String   @unique @map("receipt_id") @db.VarChar(30)
  orderId       String   @map("order_id") @db.VarChar(30)
  requesterName String   @default("") @map("requester_name")
  receiptStatus String   @default("UC") @map("receipt_status")
  receiptType   String   @default("RETURN") @map("receipt_type")
  faultByType   String   @default("CUSTOMER") @map("fault_by_type")
  cancelReason  String   @default("") @map("cancel_reason")
  cancelReasonCategory1 String? @map("cancel_reason_category1")
  cancelReasonCategory2 String? @map("cancel_reason_category2")
  reasonCode    String?  @map("reason_code")
  reasonCodeText String? @map("reason_code_text")
  returnDeliveryId String? @map("return_delivery_id") @db.VarChar(30)
  enclosePrice  Int?     @map("enclose_price")
  requestedAt   DateTime @map("requested_at") @db.Timestamptz
  completedAt   DateTime? @map("completed_at") @db.Timestamptz
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  returnItems   CoupangReturnItem[]

  @@index([companyId])
  @@index([receiptStatus])
  @@index([faultByType])
  @@index([requestedAt])
  @@map("coupang_returns")
}

model CoupangReturnItem {
  id            String   @id @default(uuid()) @db.Uuid
  returnId      String   @map("return_id") @db.Uuid

  vendorItemId    String? @map("vendor_item_id") @db.VarChar(30)
  vendorItemName  String  @default("") @map("vendor_item_name")
  sellerProductId String? @map("seller_product_id") @db.VarChar(30)
  sellerProductName String @default("") @map("seller_product_name")
  purchaseCount   Int     @default(1) @map("purchase_count")
  cancelCount     Int     @default(1) @map("cancel_count")

  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz

  return        CoupangReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)

  @@index([returnId])
  @@map("coupang_return_items")
}

// ─── Product Items ───────────────────────────────────────────────────

model ProductItem {
  id            String   @id @default(uuid()) @db.Uuid
  productId     String   @map("product_id") @db.Uuid
  vendorItemId  String?  @map("vendor_item_id") @db.VarChar(30)
  itemName      String   @default("") @map("item_name")
  originalPrice Int      @default(0) @map("original_price")
  salePrice     Int      @default(0) @map("sale_price")
  supplyPrice   Int      @default(0) @map("supply_price")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_items")
}

// ─── Purchase Orders ──────────────────────────────────────────────────────────

model PurchaseOrder {
  id        String @id @default(uuid()) @db.Uuid
  companyId String @map("company_id") @db.Uuid

  supplierName    String  @map("supplier_name")
  supplierContact String? @map("supplier_contact")
  supplierId      String? @map("supplier_id") @db.Uuid
  totalAmountCny  Decimal @map("total_amount_cny") @db.Decimal(12, 2)
  status          String  @default("draft")

  orderDate            DateTime  @default(now()) @map("order_date") @db.Date
  expectedDeliveryDate DateTime? @map("expected_delivery_date") @db.Date
  trackingNumber       String?   @map("tracking_number")

  // Inspection (from dashboard)
  receivedAt  DateTime? @map("received_at") @db.Timestamptz
  receivedQty Int?      @map("received_qty")
  defectQty   Int?      @map("defect_qty")
  defectType  String?   @map("defect_type")
  defectAction String?  @map("defect_action")
  defectNote  String?   @map("defect_note")
  inspectedAt DateTime? @map("inspected_at") @db.Timestamptz
  inspectedBy String?   @map("inspected_by")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  company  Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplier Supplier?           @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  items    PurchaseOrderItem[]
  supplierPayments SupplierPayment[]

  @@index([companyId])
  @@index([status])
  @@index([supplierId])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id        String @id @default(uuid()) @db.Uuid
  orderId   String @map("order_id") @db.Uuid
  productId String? @map("product_id") @db.Uuid

  productName  String  @map("product_name")
  quantity     Int
  unitPriceCny Decimal @map("unit_price_cny") @db.Decimal(12, 2)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  order   PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@map("purchase_order_items")
}

// ─── Ads ──────────────────────────────────────────────────────────────────────

model Ad {
  id        String @id @default(uuid()) @db.Uuid
  companyId String @map("company_id") @db.Uuid
  productId String @map("product_id") @db.Uuid

  platform     String  @default("coupang")
  campaignName String? @map("campaign_name")
  dailyBudget  Int?    @map("daily_budget")
  spend        Int     @default(0)
  impressions  Int     @default(0)
  clicks       Int     @default(0)
  conversions  Int     @default(0)
  revenue      Int     @default(0)
  roas         Decimal? @db.Decimal(10, 2)

  // Detailed attribution (from dashboard)
  billingType   String? @map("billing_type")
  saleType      String? @map("sale_type")
  adType        String? @map("ad_type")
  campaignId    String? @map("campaign_id")
  adGroup       String? @map("ad_group")
  adProductName String? @map("ad_product_name")
  adOptionId    String? @map("ad_option_id")
  convProductName String? @map("conv_product_name")
  convOptionId  String? @map("conv_option_id")
  placement     String?
  keyword       String?
  note          String?

  // 1-day attribution
  directOrders1d    Int @default(0) @map("direct_orders_1d")
  indirectOrders1d  Int @default(0) @map("indirect_orders_1d")
  directQty1d       Int @default(0) @map("direct_qty_1d")
  indirectQty1d     Int @default(0) @map("indirect_qty_1d")
  directRevenue1d   Int @default(0) @map("direct_revenue_1d")
  indirectRevenue1d Int @default(0) @map("indirect_revenue_1d")
  totalRoas1d       Decimal? @default(0) @map("total_roas_1d") @db.Decimal(10, 2)
  directRoas1d      Decimal? @default(0) @map("direct_roas_1d") @db.Decimal(10, 2)

  // 14-day attribution
  totalOrders14d     Int @default(0) @map("total_orders_14d")
  directOrders14d    Int @default(0) @map("direct_orders_14d")
  indirectOrders14d  Int @default(0) @map("indirect_orders_14d")
  totalQty14d        Int @default(0) @map("total_qty_14d")
  directQty14d       Int @default(0) @map("direct_qty_14d")
  indirectQty14d     Int @default(0) @map("indirect_qty_14d")
  totalRevenue14d    Int @default(0) @map("total_revenue_14d")
  directRevenue14d   Int @default(0) @map("direct_revenue_14d")
  indirectRevenue14d Int @default(0) @map("indirect_revenue_14d")
  totalRoas14d       Decimal? @default(0) @map("total_roas_14d") @db.Decimal(10, 2)
  directRoas14d      Decimal? @default(0) @map("direct_roas_14d") @db.Decimal(10, 2)

  campaignStartDate DateTime? @map("campaign_start_date") @db.Date
  campaignEndDate   DateTime? @map("campaign_end_date") @db.Date

  date      DateTime @default(now()) @db.Date
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([companyId])
  @@index([productId])
  @@index([date])
  @@index([productId, date])
  @@map("ads")
}

// ─── Profit & Loss ────────────────────────────────────────────────────────────

model ProfitLoss {
  id        String @id @default(uuid()) @db.Uuid
  companyId String @map("company_id") @db.Uuid
  productId String @map("product_id") @db.Uuid

  year  Int
  month Int

  revenue      Int @default(0)
  cogs         Int @default(0)
  commission   Int @default(0)
  shippingCost Int @default(0) @map("shipping_cost")
  adCost       Int @default(0) @map("ad_cost")
  otherCost    Int @default(0) @map("other_cost")
  netProfit    Int @default(0) @map("net_profit")
  profitRate   Decimal? @default(0) @map("profit_rate") @db.Decimal(5, 4)
  orderCount   Int @default(0) @map("order_count")
  returnCount  Int @default(0) @map("return_count")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([companyId, productId, year, month])
  @@index([companyId])
  @@index([productId])
  @@index([year, month])
  @@map("profit_loss")
}

// ─── Thumbnails ───────────────────────────────────────────────────────────────

model Thumbnail {
  id        String @id @default(uuid()) @db.Uuid
  companyId String @map("company_id") @db.Uuid
  productId String @map("product_id") @db.Uuid

  imageUrl      String  @map("image_url")
  strategy      String  @default("standard")
  status        String  @default("active")
  ctr           Decimal? @db.Decimal(5, 4)
  prevClickRate Decimal? @default(0) @map("prev_click_rate") @db.Decimal(5, 4)
  impressions   Int     @default(0)
  clicks        Int     @default(0)

  measuredAt DateTime? @map("measured_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([productId])
  @@map("thumbnails")
}

// ─── Reviews ──────────────────────────────────────────────────────────────────

model Review {
  id        String @id @default(uuid()) @db.Uuid
  companyId String @map("company_id") @db.Uuid
  productId String @map("product_id") @db.Uuid

  platform     String   @default("coupang")
  rating       Int
  content      String?
  reviewerName String?  @map("reviewer_name")

  reviewedAt DateTime @default(now()) @map("reviewed_at") @db.Timestamptz
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([companyId])
  @@index([productId])
  @@map("reviews")
}

// ─── Activity Events ──────────────────────────────────────────────────────────

model ActivityEvent {
  id         String   @id @default(uuid()) @db.Uuid
  companyId  String   @map("company_id") @db.Uuid
  objectType String   @map("object_type")
  objectId   String   @map("object_id") @db.Uuid
  eventType  String   @map("event_type")
  source     String   @default("manual")
  title      String
  data       Json?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([objectType, objectId])
  @@index([eventType])
  @@index([createdAt])
  @@map("activity_events")
}

// ─── Alerts ───────────────────────────────────────────────────────────────────

model Alert {
  id        String @id @default(uuid()) @db.Uuid
  companyId String @map("company_id") @db.Uuid
  productId String? @map("product_id") @db.Uuid

  type     String
  severity String  @default("warning")
  title    String
  message  String?
  isRead   Boolean @default(false) @map("is_read")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  company Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([companyId, isRead, createdAt])
  @@index([isRead])
  @@index([type])
  @@index([createdAt])
  @@map("alerts")
}

// ─── Agent Tasks ──────────────────────────────────────────────────────────────

model AgentTask {
  id        String  @id @default(uuid()) @db.Uuid
  companyId String? @map("company_id") @db.Uuid
  agentType String  @map("agent_type")
  status    String  @default("pending")
  priority  Int     @default(0)

  workflowRunId  String? @map("workflow_run_id") @db.Uuid
  workflowNodeId String? @map("workflow_node_id")
  sourceDataId   String? @map("source_data_id")

  input  Json?
  output Json?
  error  String?

  scheduledAt DateTime? @map("scheduled_at") @db.Timestamptz
  startedAt   DateTime? @map("started_at") @db.Timestamptz
  completedAt DateTime? @map("completed_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  logs AgentLog[]

  @@index([companyId])
  @@index([status])
  @@index([agentType])
  @@index([workflowRunId])
  @@index([createdAt])
  @@map("agent_tasks")
}

model AgentLog {
  id     String @id @default(uuid()) @db.Uuid
  taskId String @map("task_id") @db.Uuid
  level  String @default("info")
  message String
  data   Json?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  task AgentTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("agent_logs")
}

// ─── Agent Definitions (Paperclip 패턴) ──────────────────────────────────────

model AgentDefinition {
  id          String  @id @default(uuid()) @db.Uuid
  companyId   String? @map("company_id") @db.Uuid
  name        String
  type        String  @unique
  description String?

  // Adapter (런타임 추상화)
  adapterType   String @default("claude_local") @map("adapter_type")
  adapterConfig Json   @default("{}") @map("adapter_config")

  // Heartbeat (실행 모델)
  runtimeConfig Json @default("{}") @map("runtime_config")

  // Hierarchy (조직 구조)
  role      String  @default("specialist")
  title     String?
  icon      String?
  reportsTo String? @map("reports_to") @db.Uuid
  status    String  @default("idle")

  // Pause/Resume
  pauseReason String?   @map("pause_reason")
  pausedAt    DateTime? @map("paused_at") @db.Timestamptz

  // Permissions & Skills
  permissions  Json     @default("{}") @db.JsonB
  skills       String[] @default([])
  deniedSkills String[] @default([]) @map("denied_skills")

  // Business Safety
  actionCap  Json @default("{}") @map("action_cap") @db.JsonB
  trustLevel Int  @default(0) @map("trust_level")

  // Prompt & Tools (기존)
  promptTemplate String @map("prompt_template") @db.Text
  allowedTools   String @default("Bash(psql:*) Bash(curl:*) Read") @map("allowed_tools")
  permissionMode String @default("bypassPermissions") @map("permission_mode")

  // Budget (기존)
  monthlyTokenBudget Int       @default(0) @map("monthly_token_budget")
  tokensUsed         Int       @default(0) @map("tokens_used")
  budgetResetAt      DateTime? @map("budget_reset_at") @db.Timestamptz

  // Schedule & Timeout (기존)
  schedule         String?
  timeoutSeconds   Int     @default(300) @map("timeout_seconds")
  requiresApproval Boolean @default(true) @map("requires_approval")
  isActive         Boolean @default(true) @map("is_active")

  // Runtime tracking
  lastHeartbeatAt DateTime? @map("last_heartbeat_at") @db.Timestamptz
  metadata        Json?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  marketplaceId String? @map("marketplace_id") @db.Uuid

  // Relations
  company        Company?          @relation(fields: [companyId], references: [id])
  marketplace    AgentMarketplace? @relation(fields: [marketplaceId], references: [id])
  parent         AgentDefinition?  @relation("AgentHierarchy", fields: [reportsTo], references: [id])
  children       AgentDefinition[] @relation("AgentHierarchy")
  runtimeState   AgentRuntimeState?
  heartbeatRuns  HeartbeatRun[]
  wakeupRequests AgentWakeupRequest[]
  workflows      AgentWorkflow[]
  permissionDenials AgentPermissionDenial[]
  actionSnapshots   AgentActionSnapshot[]

  @@index([companyId])
  @@index([type])
  @@index([isActive])
  @@index([companyId, status])
  @@index([companyId, reportsTo])
  @@index([marketplaceId])
  @@map("agent_definitions")
}

// ─── Agent Runtime State ─────────────────────────────────────────────────────

model AgentRuntimeState {
  agentId           String @id @map("agent_id") @db.Uuid
  companyId         String @map("company_id") @db.Uuid
  adapterType       String @map("adapter_type")
  sessionId         String? @map("session_id")
  stateJson         Json   @default("{}") @map("state_json") @db.JsonB
  lastRunId         String? @map("last_run_id") @db.Uuid
  lastRunStatus     String? @map("last_run_status")
  totalInputTokens  Int    @default(0) @map("total_input_tokens")
  totalOutputTokens Int    @default(0) @map("total_output_tokens")
  totalCostCents    Int    @default(0) @map("total_cost_cents")
  lastError         String? @map("last_error")

  // 에러 복구 캐스케이드: 연속 실패 추적 → 3회 시 auto-pause
  consecutiveFailCount Int       @default(0) @map("consecutive_fail_count")
  lastFailedAt         DateTime? @map("last_failed_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  agent   AgentDefinition @relation(fields: [agentId], references: [id], onDelete: Cascade)
  company Company         @relation(fields: [companyId], references: [id])

  @@index([companyId, agentId])
  @@map("agent_runtime_state")
}

// ─── Heartbeat Runs ──────────────────────────────────────────────────────────

model HeartbeatRun {
  id               String  @id @default(uuid()) @db.Uuid
  companyId        String  @map("company_id") @db.Uuid
  agentId          String  @map("agent_id") @db.Uuid
  invocationSource String  @default("on_demand") @map("invocation_source")
  triggerDetail    String? @map("trigger_detail")
  status           String  @default("queued")
  startedAt        DateTime? @map("started_at") @db.Timestamptz
  finishedAt       DateTime? @map("finished_at") @db.Timestamptz
  error            String?
  exitCode         Int?    @map("exit_code")
  signal           String?
  usageJson        Json?   @map("usage_json") @db.JsonB
  resultJson       Json?   @map("result_json") @db.JsonB
  sessionIdBefore  String? @map("session_id_before")
  sessionIdAfter   String? @map("session_id_after")
  stdoutExcerpt    String? @map("stdout_excerpt") @db.Text
  stderrExcerpt    String? @map("stderr_excerpt") @db.Text
  errorCode        String? @map("error_code")
  processPid       Int?    @map("process_pid")
  wakeupRequestId  String? @map("wakeup_request_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  agent         AgentDefinition     @relation(fields: [agentId], references: [id])
  company       Company             @relation(fields: [companyId], references: [id])
  wakeupRequest AgentWakeupRequest? @relation(fields: [wakeupRequestId], references: [id])

  @@index([companyId, agentId, startedAt])
  @@index([status])
  @@map("heartbeat_runs")
}

// ─── Feature Gates (Claude Code 피처 게이트 패턴) ────────────────────────────

model FeatureGate {
  id               String   @id @default(uuid()) @db.Uuid
  name             String   @unique
  description      String?
  enabled          Boolean  @default(false)
  allowedCompanies String[] @map("allowed_companies")
  metadata         Json?    @db.JsonB

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("feature_gates")
}

// ─── Agent Workflows (Async Generator 패턴) ─────────────────────────────────

model AgentWorkflow {
  id          String   @id @default(uuid()) @db.Uuid
  agentId     String   @map("agent_id") @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  type        String
  status      String   @default("running")
  currentStep Int      @default(0) @map("current_step")
  state       Json     @default("{}") @db.JsonB
  steps       Json     @default("[]") @db.JsonB
  input       Json?    @db.JsonB
  output      Json?    @db.JsonB
  error       String?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  agent   AgentDefinition @relation(fields: [agentId], references: [id])
  company Company         @relation(fields: [companyId], references: [id])

  @@index([companyId, status])
  @@index([agentId])
  @@map("agent_workflows")
}

// ─── Agent Wakeup Requests ───────────────────────────────────────────────────

model AgentWakeupRequest {
  id              String  @id @default(uuid()) @db.Uuid
  companyId       String  @map("company_id") @db.Uuid
  agentId         String  @map("agent_id") @db.Uuid
  source          String
  triggerDetail   String? @map("trigger_detail")
  reason          String?
  payload         Json?   @db.JsonB
  status          String  @default("queued")
  coalescedCount  Int     @default(0) @map("coalesced_count")
  requestedByType String? @map("requested_by_type")
  requestedById   String? @map("requested_by_id")
  runId           String? @map("run_id") @db.Uuid
  requestedAt     DateTime @default(now()) @map("requested_at") @db.Timestamptz
  claimedAt       DateTime? @map("claimed_at") @db.Timestamptz
  finishedAt      DateTime? @map("finished_at") @db.Timestamptz
  error           String?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  agent         AgentDefinition @relation(fields: [agentId], references: [id])
  company       Company         @relation(fields: [companyId], references: [id])
  heartbeatRuns HeartbeatRun[]

  @@index([companyId, agentId, status])
  @@index([agentId, requestedAt])
  @@map("agent_wakeup_requests")
}

// ─── Agent Permission Denials ─────────────────────────────────────────────────

model AgentPermissionDenial {
  id        String   @id @default(uuid()) @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  agentId   String   @map("agent_id") @db.Uuid
  runId     String?  @map("run_id") @db.Uuid
  category  String                                    // dangerous_tool | budget_exceeded | feature_gate | skill_denied
  detail    String
  action    String   @default("blocked")              // blocked | warned
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  agent   AgentDefinition @relation(fields: [agentId], references: [id])
  company Company         @relation(fields: [companyId], references: [id])

  @@index([companyId, agentId, createdAt])
  @@map("agent_permission_denials")
}

// ─── Agent Action Snapshots (Business Safety) ────────────────────────────────

model AgentActionSnapshot {
  id          String    @id @default(uuid()) @db.Uuid
  companyId   String    @map("company_id") @db.Uuid
  runId       String    @map("run_id") @db.Uuid
  agentId     String    @map("agent_id") @db.Uuid
  tableName   String    @map("table_name")
  recordId    String    @map("record_id")
  fieldName   String    @map("field_name")
  valueBefore Json      @map("value_before")
  valueAfter  Json      @map("value_after")
  restoredAt  DateTime? @map("restored_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  agent   AgentDefinition @relation(fields: [agentId], references: [id])
  company Company         @relation(fields: [companyId], references: [id])

  @@index([runId])
  @@index([agentId, createdAt])
  @@map("agent_action_snapshots")
}

// ─── Content ──────────────────────────────────────────────────────────────────

model ContentGeneration {
  id                   String   @id @default(uuid()) @db.Uuid
  companyId            String   @map("company_id") @db.Uuid
  productId            String   @map("product_id") @db.Uuid
  originalImages       Json?    @map("original_images")
  processedImages      Json?    @map("processed_images")
  generatedTitle       String?  @map("generated_title")
  generatedDescription String?  @map("generated_description")
  generatedCopy        String?  @map("generated_copy")
  detailPageHtml       String?  @map("detail_page_html")
  status               String   @default("PENDING")
  retryCount           Int      @default(0) @map("retry_count")
  errorMessage         String?  @map("error_message")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([productId])
  @@index([status])
  @@map("content_generations")
}

// ─── Workflow Engine ──────────────────────────────────────────────────────────

model WorkflowTemplate {
  id          String   @id @default(uuid()) @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  name        String
  description String   @default("")
  module      String   @default("order")
  isActive    Boolean  @default(false) @map("is_active")
  triggerType String   @default("manual") @map("trigger_type")
  schedule    String?
  nodesJson   Json     @map("nodes_json")
  edgesJson   Json     @map("edges_json")
  version     Int      @default(1)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  marketplaceId String? @map("marketplace_id") @db.Uuid

  company     Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  marketplace WorkflowMarketplace?  @relation(fields: [marketplaceId], references: [id])
  runs        WorkflowRun[]

  @@index([companyId])
  @@index([isActive])
  @@index([module])
  @@index([marketplaceId])
  @@map("workflow_templates")
}

model WorkflowRun {
  id          String    @id @default(uuid()) @db.Uuid
  companyId   String?   @map("company_id") @db.Uuid
  templateId  String    @map("template_id") @db.Uuid
  status      String    @default("pending")
  triggeredBy String    @default("manual") @map("triggered_by")
  contextData Json?     @map("context_data")
  error       String?
  startedAt   DateTime? @map("started_at") @db.Timestamptz
  completedAt DateTime? @map("completed_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  template WorkflowTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  steps    WorkflowStepRun[]

  @@index([companyId])
  @@index([templateId])
  @@index([status])
  @@index([createdAt])
  @@map("workflow_runs")
}

model WorkflowStepRun {
  id          String    @id @default(uuid()) @db.Uuid
  runId       String    @map("run_id") @db.Uuid
  nodeId      String    @map("node_id")
  nodeType    String    @map("node_type")
  nodeLabel   String    @default("") @map("node_label")
  status      String    @default("pending")
  inputData   Json?     @map("input_data")
  outputData  Json?     @map("output_data")
  error       String?
  startedAt   DateTime? @map("started_at") @db.Timestamptz
  completedAt DateTime? @map("completed_at") @db.Timestamptz

  run WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([nodeId])
  @@map("workflow_step_runs")
}

// ═══════════════════════════════════════════════════════════════════════════════
// Dashboard 이식 — 신규 모델
// ═══════════════════════════════════════════════════════════════════════════════

// ─── Supplier & Procurement ───────────────────────────────────────────────────

model Supplier {
  id           String   @id @default(uuid()) @db.Uuid
  companyId    String   @map("company_id") @db.Uuid
  name         String
  contactName  String?  @map("contact_name")
  phone        String?
  email        String?
  address      String?
  leadTimeDays Int      @default(7) @map("lead_time_days")
  paymentTerms String?  @map("payment_terms")
  notes        String?
  status       String   @default("active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplierProducts SupplierProduct[]
  purchaseOrders   PurchaseOrder[]
  payments         SupplierPayment[]

  @@index([companyId])
  @@index([status])
  @@map("suppliers")
}

model SupplierProduct {
  id          String   @id @default(uuid()) @db.Uuid
  supplierId  String   @map("supplier_id") @db.Uuid
  productId   String   @map("product_id") @db.Uuid
  supplyPrice Int      @default(0) @map("supply_price")
  minOrderQty Int      @default(1) @map("min_order_qty")
  isMain      Boolean  @default(false) @map("is_main")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([supplierId, productId])
  @@index([productId])
  @@map("supplier_products")
}

model SupplierPayment {
  id              String    @id @default(uuid()) @db.Uuid
  companyId       String    @map("company_id") @db.Uuid
  supplierId      String    @map("supplier_id") @db.Uuid
  supplierName    String?   @map("supplier_name")
  amount          Int       @default(0)
  paidAmount      Int       @default(0) @map("paid_amount")
  status          String    @default("unpaid")
  dueDate         DateTime? @map("due_date") @db.Date
  paidDate        DateTime? @map("paid_date") @db.Date
  purchaseOrderId String?   @map("purchase_order_id") @db.Uuid
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplier      Supplier       @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([companyId, status])
  @@index([supplierId])
  @@index([status])
  @@map("supplier_payments")
}

// ─── Warehouse & Inventory Ops ────────────────────────────────────────────────

model Warehouse {
  id        String   @id @default(uuid()) @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  name      String
  code      String?
  address   String?
  manager   String?
  phone     String?
  isDefault Boolean  @default(false) @map("is_default")
  status    String   @default("active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Warehouse references from other models
  stockTransfersFrom     StockTransfer[]      @relation("TransferFromWarehouse")
  stockTransfersTo       StockTransfer[]      @relation("TransferToWarehouse")
  stockTransactions      StockTransaction[]
  shipments              Shipment[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("warehouses")
}

model StockTransfer {
  id              String    @id @default(uuid()) @db.Uuid
  companyId       String    @map("company_id") @db.Uuid
  productId       String    @map("product_id") @db.Uuid
  productName     String?   @map("product_name")
  fromWarehouseId String    @map("from_warehouse_id") @db.Uuid
  toWarehouseId   String    @map("to_warehouse_id") @db.Uuid
  quantity        Int
  status          String    @default("pending")
  requestedBy     String?   @map("requested_by")
  completedAt     DateTime? @map("completed_at") @db.Timestamptz
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz

  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  fromWarehouse Warehouse @relation("TransferFromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse @relation("TransferToWarehouse", fields: [toWarehouseId], references: [id])

  @@index([companyId])
  @@index([productId])
  @@index([status])
  @@map("stock_transfers")
}

model StockTransaction {
  id          String   @id @default(uuid()) @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  productId   String   @map("product_id") @db.Uuid
  productName String?  @map("product_name")
  type        String
  quantity    Int
  unitCost    Int      @default(0) @map("unit_cost")
  totalCost   Int      @default(0) @map("total_cost")
  relatedId   String?  @map("related_id")
  relatedType String?  @map("related_type")
  warehouseId String?  @map("warehouse_id") @db.Uuid
  note        String?
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product   Product    @relation(fields: [productId], references: [id], onDelete: Restrict)
  warehouse Warehouse? @relation(fields: [warehouseId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([companyId, createdAt])
  @@index([productId])
  @@index([type])
  @@index([createdAt])
  @@map("stock_transactions")
}

model StockAudit {
  id            String    @id @default(uuid()) @db.Uuid
  companyId     String    @map("company_id") @db.Uuid
  auditNumber   String    @map("audit_number")
  status        String    @default("in_progress")
  totalProducts Int       @default(0) @map("total_products")
  matchedCount  Int       @default(0) @map("matched_count")
  diffCount     Int       @default(0) @map("diff_count")
  auditedBy     String?   @map("audited_by")
  completedAt   DateTime? @map("completed_at") @db.Timestamptz
  notes         String?
  items         Json?
