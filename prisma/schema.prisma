generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Companies ────────────────────────────────────────────────────────────────

model Company {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  users          User[]
  products       Product[]
  inventory      Inventory[]
  orders         Order[]
  purchaseOrders PurchaseOrder[]
  ads            Ad[]
  profitLoss     ProfitLoss[]
  thumbnails     Thumbnail[]
  reviews        Review[]
  alerts         Alert[]
  douyinLiveRooms     DouyinLiveRoom[]
  contentGenerations  ContentGeneration[]
  coupangListings     CoupangListing[]
  workflowTemplates   WorkflowTemplate[]
  credentials         Credential[]
  activityEvents      ActivityEvent[]

  @@map("companies")
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid()) @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  email     String   @unique
  name      String
  role      String   @default("member")
  team      String?
  avatarUrl String?  @map("avatar_url")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("users")
}

// ─── Products ─────────────────────────────────────────────────────────────────

model Product {
  id          String   @id @default(uuid()) @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  name        String
  description String   @default("")
  status      String   @default("draft")
  category    String?
  tags        Json     @default("[]")
  thumbnailUrl String? @map("thumbnail_url")

  sourceUrl      String?  @map("source_url")
  sourcePlatform String?  @map("source_platform")
  costCny        Decimal? @map("cost_cny") @db.Decimal(12, 2)
  marginRate     Decimal? @map("margin_rate") @db.Decimal(5, 4)
  rawData        Json?    @map("raw_data")
  processedData  Json?    @map("processed_data")
  detailPageUrl  String?  @map("detail_page_url")

  sellPrice      Int?     @map("sell_price")
  commissionRate Decimal? @map("commission_rate") @db.Decimal(5, 4)
  shippingCost   Int?     @map("shipping_cost")
  abcGrade       String?  @map("abc_grade")
  adTier         String?  @map("ad_tier")

  coupangProductId String? @map("coupang_product_id")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  company    Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  inventory  Inventory?
  orders     Order[]
  ads        Ad[]
  profitLoss ProfitLoss[]
  thumbnails Thumbnail[]
  reviews    Review[]
  alerts     Alert[]
  purchaseOrderItems PurchaseOrderItem[]
  douyinLiveProducts DouyinLiveProduct[]
  contentGenerations ContentGeneration[]
  coupangListings    CoupangListing[]

  @@index([companyId])
  @@index([status])
  @@index([abcGrade])
  @@map("products")
}

// ─── Inventory ────────────────────────────────────────────────────────────────

model Inventory {
  id        String @id @default(uuid()) @db.Uuid
  companyId String @map("company_id") @db.Uuid
  productId String @unique @map("product_id") @db.Uuid

  currentStock    Int   @default(0) @map("current_stock")
  reservedStock   Int   @default(0) @map("reserved_stock")
  safetyStock     Int   @default(0) @map("safety_stock")
  reorderPoint    Int   @default(0) @map("reorder_point")
  reorderQuantity Int   @default(0) @map("reorder_quantity")
  leadTimeDays    Int?  @map("lead_time_days")
  dailySalesAvg   Float @default(0) @map("daily_sales_avg")

  lastRestockedAt DateTime? @map("last_restocked_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([productId])
  @@map("inventory")
}

// ─── Orders ───────────────────────────────────────────────────────────────────

model Order {
  id        String @id @default(uuid()) @db.Uuid
  companyId String @map("company_id") @db.Uuid
  productId String? @map("product_id") @db.Uuid

  orderNumber    String  @map("order_number")
  platform       String
  coupangOrderId String? @map("coupang_order_id")
  customerName   String  @default("") @map("customer_name")
  productName    String  @map("product_name")
  quantity       Int     @default(1)
  unitPrice      Int     @map("unit_price")
  totalPrice     Int     @map("total_price")
  status         String  @default("pending")
  trackingNumber String? @map("tracking_number")
  shippingCompany String? @map("shipping_company")

  orderedAt   DateTime  @default(now()) @map("ordered_at") @db.Timestamptz
  shippedAt   DateTime? @map("shipped_at") @db.Timestamptz
  deliveredAt DateTime? @map("delivered_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  company Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([productId])
  @@index([status])
  @@index([platform])
  @@index([orderedAt])
  @@map("orders")
}

// ─── Purchase Orders ──────────────────────────────────────────────────────────

model PurchaseOrder {
  id        String @id @default(uuid()) @db.Uuid
  companyId String @map("company_id") @db.Uuid

  supplierName    String  @map("supplier_name")
  supplierContact String? @map("supplier_contact")
  totalAmountCny  Decimal @map("total_amount_cny") @db.Decimal(12, 2)
  status          String  @default("draft")

  orderDate            DateTime  @default(now()) @map("order_date") @db.Date
  expectedDeliveryDate DateTime? @map("expected_delivery_date") @db.Date
  trackingNumber       String?   @map("tracking_number")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  company Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  items   PurchaseOrderItem[]

  @@index([companyId])
  @@index([status])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id        String @id @default(uuid()) @db.Uuid
  orderId   String @map("order_id") @db.Uuid
  productId String? @map("product_id") @db.Uuid

  productName  String  @map("product_name")
  quantity     Int
  unitPriceCny Decimal @map("unit_price_cny") @db.Decimal(12, 2)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  order   PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@map("purchase_order_items")
}

// ─── Ads ──────────────────────────────────────────────────────────────────────

model Ad {
  id        String @id @default(uuid()) @db.Uuid
  companyId String @map("company_id") @db.Uuid
  productId String @map("product_id") @db.Uuid

  platform     String  @default("coupang")
  campaignName String? @map("campaign_name")
  dailyBudget  Int?    @map("daily_budget")
  spend        Int     @default(0)
  impressions  Int     @default(0)
  clicks       Int     @default(0)
  conversions  Int     @default(0)
  roas         Decimal? @db.Decimal(10, 2)

  date      DateTime @default(now()) @db.Date
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([productId])
  @@index([date])
  @@map("ads")
}

// ─── Profit & Loss ────────────────────────────────────────────────────────────

model ProfitLoss {
  id        String @id @default(uuid()) @db.Uuid
  companyId String @map("company_id") @db.Uuid
  productId String @map("product_id") @db.Uuid

  year  Int
  month Int

  revenue      Int @default(0)
  cogs         Int @default(0)
  commission   Int @default(0)
  shippingCost Int @default(0) @map("shipping_cost")
  adCost       Int @default(0) @map("ad_cost")
  otherCost    Int @default(0) @map("other_cost")
  netProfit    Int @default(0) @map("net_profit")
  orderCount   Int @default(0) @map("order_count")
  returnCount  Int @default(0) @map("return_count")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([productId])
  @@index([year, month])
  @@map("profit_loss")
}

// ─── Thumbnails ───────────────────────────────────────────────────────────────

model Thumbnail {
  id        String @id @default(uuid()) @db.Uuid
  companyId String @map("company_id") @db.Uuid
  productId String @map("product_id") @db.Uuid

  imageUrl    String  @map("image_url")
  strategy    String  @default("standard")
  status      String  @default("active")
  ctr         Decimal? @db.Decimal(5, 4)
  impressions Int     @default(0)
  clicks      Int     @default(0)

  measuredAt DateTime? @map("measured_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([productId])
  @@map("thumbnails")
}

// ─── Reviews ──────────────────────────────────────────────────────────────────

model Review {
  id        String @id @default(uuid()) @db.Uuid
  companyId String @map("company_id") @db.Uuid
  productId String @map("product_id") @db.Uuid

  platform     String   @default("coupang")
  rating       Int
  content      String?
  reviewerName String?  @map("reviewer_name")

  reviewedAt DateTime @default(now()) @map("reviewed_at") @db.Timestamptz
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([productId])
  @@map("reviews")
}

// ─── Activity Events ──────────────────────────────────────────────────────────

model ActivityEvent {
  id         String   @id @default(uuid()) @db.Uuid
  companyId  String   @map("company_id") @db.Uuid
  objectType String   @map("object_type")
  objectId   String   @map("object_id") @db.Uuid
  eventType  String   @map("event_type")
  source     String   @default("manual")
  title      String
  data       Json?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([objectType, objectId])
  @@index([eventType])
  @@index([createdAt])
  @@map("activity_events")
}

// ─── Alerts ───────────────────────────────────────────────────────────────────

model Alert {
  id        String @id @default(uuid()) @db.Uuid
  companyId String @map("company_id") @db.Uuid
  productId String? @map("product_id") @db.Uuid

  type     String
  severity String  @default("warning")
  title    String
  message  String?
  isRead   Boolean @default(false) @map("is_read")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  company Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([isRead])
  @@index([type])
  @@index([createdAt])
  @@map("alerts")
}

// ─── Agent Tasks (Phase 2) ────────────────────────────────────────────────────

model AgentTask {
  id        String  @id @default(uuid()) @db.Uuid
  agentType String  @map("agent_type")
  status    String  @default("pending")
  priority  Int     @default(0)

  workflowRunId  String? @map("workflow_run_id") @db.Uuid
  workflowNodeId String? @map("workflow_node_id")
  sourceDataId   String? @map("source_data_id")

  input  Json?
  output Json?
  error  String?

  scheduledAt DateTime? @map("scheduled_at") @db.Timestamptz
  startedAt   DateTime? @map("started_at") @db.Timestamptz
  completedAt DateTime? @map("completed_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  logs AgentLog[]

  @@index([status])
  @@index([agentType])
  @@index([workflowRunId])
  @@index([createdAt])
  @@map("agent_tasks")
}

model AgentLog {
  id     String @id @default(uuid()) @db.Uuid
  taskId String @map("task_id") @db.Uuid
  level  String @default("info")
  message String
  data   Json?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  task AgentTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("agent_logs")
}

// ─── Phase 2: Sourcing ────────────────────────────────────────────────────────

model DouyinLiveRoom {
  id            String   @id @default(uuid()) @db.Uuid
  companyId     String   @map("company_id") @db.Uuid
  roomId        String   @unique @map("room_id")
  webRoomId     String   @map("web_room_id")
  streamerName  String   @default("") @map("streamer_name")
  liveUrl       String   @default("") @map("live_url")
  status        String   @default("PAUSED")
  viewerCount   Int      @default(0) @map("viewer_count")
  productCount  Int      @default(0) @map("product_count")
  lastConnectedAt DateTime? @map("last_connected_at") @db.Timestamptz
  errorMessage  String?  @map("error_message")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  company  Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  products DouyinLiveProduct[]

  @@index([companyId])
  @@map("douyin_live_rooms")
}

model DouyinLiveProduct {
  id             String   @id @default(uuid()) @db.Uuid
  liveRoomId     String   @map("live_room_id") @db.Uuid
  productId      String?  @map("product_id") @db.Uuid
  promotionId    BigInt   @map("promotion_id")
  productName    String   @default("") @map("product_name")
  price          Decimal  @default(0) @db.Decimal(12, 2)
  imageUrl       String   @default("") @map("image_url")
  productUrl     String   @default("") @map("product_url")
  indexInList    Int      @default(0) @map("index_in_list")
  extraData      Json?    @map("extra_data")
  detectedAt     DateTime @default(now()) @map("detected_at") @db.Timestamptz

  matchStatus      String   @default("PENDING") @map("match_status")
  matched1688Url   String?  @map("matched_1688_url")
  matched1688Price Decimal? @map("matched_1688_price") @db.Decimal(12, 2)
  matched1688Title String?  @map("matched_1688_title")
  matchScore       Decimal? @map("match_score") @db.Decimal(5, 4)
  matchedAt        DateTime? @map("matched_at") @db.Timestamptz

  liveRoom DouyinLiveRoom @relation(fields: [liveRoomId], references: [id], onDelete: Cascade)
  product  Product?       @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([liveRoomId])
  @@index([productId])
  @@index([promotionId])
  @@map("douyin_live_products")
}

// ─── Phase 2: Content ─────────────────────────────────────────────────────────

model ContentGeneration {
  id                   String   @id @default(uuid()) @db.Uuid
  companyId            String   @map("company_id") @db.Uuid
  productId            String   @map("product_id") @db.Uuid
  originalImages       Json?    @map("original_images")
  processedImages      Json?    @map("processed_images")
  generatedTitle       String?  @map("generated_title")
  generatedDescription String?  @map("generated_description")
  generatedCopy        String?  @map("generated_copy")
  detailPageHtml       String?  @map("detail_page_html")
  status               String   @default("PENDING")
  retryCount           Int      @default(0) @map("retry_count")
  errorMessage         String?  @map("error_message")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([productId])
  @@index([status])
  @@map("content_generations")
}

// ─── Phase 2: Listing ─────────────────────────────────────────────────────────

model CoupangListing {
  id               String   @id @default(uuid()) @db.Uuid
  companyId        String   @map("company_id") @db.Uuid
  productId        String   @map("product_id") @db.Uuid
  coupangProductId String   @map("coupang_product_id")
  listingUrl       String   @map("listing_url")
  status           String   @default("ACTIVE")
  currentPrice     Int      @map("current_price")
  viewsCount       Int      @default(0) @map("views_count")
  conversionRate   Decimal  @default(0) @map("conversion_rate") @db.Decimal(5, 4)
  adSpend          Decimal? @map("ad_spend") @db.Decimal(12, 2)
  adRoas           Decimal? @map("ad_roas") @db.Decimal(10, 2)
  listedAt         DateTime @default(now()) @map("listed_at") @db.Timestamptz
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  company      Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product      Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  performances ProductPerformance[]

  @@index([companyId])
  @@index([productId])
  @@map("coupang_listings")
}

model ProductPerformance {
  id           String   @id @default(uuid()) @db.Uuid
  listingId    String   @map("listing_id") @db.Uuid
  date         DateTime @db.Date
  views        Int      @default(0)
  clicks       Int      @default(0)
  orders       Int      @default(0)
  revenue      Int      @default(0)
  adSpendDaily Decimal  @default(0) @map("ad_spend_daily") @db.Decimal(12, 2)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  listing CoupangListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([date])
  @@map("product_performances")
}

// ─── Workflow Engine ──────────────────────────────────────────────────────────

model WorkflowTemplate {
  id          String   @id @default(uuid()) @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  name        String
  description String   @default("")
  module      String   @default("order")
  isActive    Boolean  @default(false) @map("is_active")
  triggerType String   @default("manual") @map("trigger_type")
  schedule    String?
  nodesJson   Json     @map("nodes_json")
  edgesJson   Json     @map("edges_json")
  version     Int      @default(1)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  company Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  runs    WorkflowRun[]

  @@index([companyId])
  @@index([isActive])
  @@index([module])
  @@map("workflow_templates")
}

model WorkflowRun {
  id          String    @id @default(uuid()) @db.Uuid
  templateId  String    @map("template_id") @db.Uuid
  status      String    @default("pending")
  triggeredBy String    @default("manual") @map("triggered_by")
  contextData Json?     @map("context_data")
  error       String?
  startedAt   DateTime? @map("started_at") @db.Timestamptz
  completedAt DateTime? @map("completed_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  template WorkflowTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  steps    WorkflowStepRun[]

  @@index([templateId])
  @@index([status])
  @@index([createdAt])
  @@map("workflow_runs")
}

model WorkflowStepRun {
  id          String    @id @default(uuid()) @db.Uuid
  runId       String    @map("run_id") @db.Uuid
  nodeId      String    @map("node_id")
  nodeType    String    @map("node_type")
  nodeLabel   String    @default("") @map("node_label")
  status      String    @default("pending")
  inputData   Json?     @map("input_data")
  outputData  Json?     @map("output_data")
  error       String?
  startedAt   DateTime? @map("started_at") @db.Timestamptz
  completedAt DateTime? @map("completed_at") @db.Timestamptz

  run WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([nodeId])
  @@map("workflow_step_runs")
}

model Credential {
  id             String    @id @default(uuid()) @db.Uuid
  companyId      String    @map("company_id") @db.Uuid
  provider       String
  name           String
  encryptedData  String    @map("encrypted_data")
  status         String    @default("active")
  lastVerifiedAt DateTime? @map("last_verified_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([provider])
  @@map("credentials")
}
