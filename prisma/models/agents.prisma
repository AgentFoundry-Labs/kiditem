// agents.prisma — Agent OS + Workflows
//
// Agent OS owns organization-scoped instances, runtime, policy, approvals,
// and cost ledgers. Shipped agent definitions live in the backend code
// registry, not in DB.
// Workflow models live alongside because the workflow runner triggers
// Agent OS through `AgentRunnerPort` and shares related FK columns.

/// @namespace AgentOS
/// @describe Organization-owned runnable subject. Type must match the code-owned Agent Definition Registry.
model AgentInstance {
  id                 String    @id @default(uuid()) @db.Uuid
  organizationId     String    @map("organization_id") @db.Uuid
  type               String
  name               String
  role               String    @default("specialist")
  title              String?
  icon               String?
  reportsToId        String?   @map("reports_to_id") @db.Uuid
  lifecycleStatus    String    @default("active") @map("lifecycle_status")
  pauseReason        String?   @map("pause_reason")
  pausedAt           DateTime? @map("paused_at") @db.Timestamptz
  trustLevel         Int       @default(0) @map("trust_level")
  adapterType        String    @map("adapter_type")
  modelOverride      String?   @map("model_override")
  adapterConfig      Json      @default("{}") @map("adapter_config") @db.JsonB
  runtimeConfig      Json      @default("{}") @map("runtime_config") @db.JsonB
  promptPathOverride String?   @map("prompt_path_override")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization         Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent               AgentInstance?            @relation("AgentInstanceHierarchy", fields: [reportsToId], references: [id], onDelete: SetNull)
  children             AgentInstance[]           @relation("AgentInstanceHierarchy")
  runtimeState         AgentRuntimeState?
  requests             AgentRunRequest[]
  runs                 AgentRun[]
  events               AgentRunEvent[]
  taskSessions         AgentTaskSession[]
  instanceToolPolicies AgentInstanceToolPolicy[]
  authorizationEvents  AgentAuthorizationEvent[]
  approvalRequests     AgentApprovalRequest[]
  costEvents           AgentCostEvent[]
  agentUsers           User[]
  conversationMessages AgentMessage[]
  toolInvocations      AgentToolInvocation[]
  artifacts            AgentArtifact[]

  @@unique([organizationId, type])
  @@index([organizationId])
  @@index([reportsToId])
  @@index([organizationId, lifecycleStatus])
  @@index([organizationId, reportsToId])
  @@map("agent_instances")
}

/// @namespace AgentOS
/// @describe Frequently-changing per-instance runtime state (last run, totals, cached aggregates). 1:1 with AgentInstance.
model AgentRuntimeState {
  id                      String    @id @default(uuid()) @db.Uuid
  organizationId          String    @map("organization_id") @db.Uuid
  agentInstanceId         String    @unique @map("agent_instance_id") @db.Uuid
  lastRunId               String?   @map("last_run_id") @db.Uuid
  lastRunStatus           String?   @map("last_run_status")
  lastError               String?   @map("last_error") @db.Text
  lastHeartbeatAt         DateTime? @map("last_heartbeat_at") @db.Timestamptz
  consecutiveFailureCount Int       @default(0) @map("consecutive_failure_count")
  totalRuns               Int       @default(0) @map("total_runs")
  totalInputTokens        Int       @default(0) @map("total_input_tokens")
  totalOutputTokens       Int       @default(0) @map("total_output_tokens")
  totalCostMicros         BigInt    @default(0) @map("total_cost_micros")
  stateJson               Json      @default("{}") @map("state_json") @db.JsonB
  createdAt               DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt               DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agentInstance AgentInstance @relation(fields: [agentInstanceId], references: [id], onDelete: Cascade)
  lastRun       AgentRun?     @relation("AgentRuntimeStateLastRun", fields: [lastRunId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([lastRunId])
  @@map("agent_runtime_states")
}

/// @namespace AgentOS
/// @describe Per-task durable session. taskKey defaults to "default" only at API boundary.
model AgentTaskSession {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  agentInstanceId String   @map("agent_instance_id") @db.Uuid
  adapterType     String   @map("adapter_type")
  taskKey         String   @map("task_key")
  title           String?
  metadata        Json     @default("{}") @db.JsonB
  sessionParams   Json?    @map("session_params") @db.JsonB
  sessionDisplay  String?  @map("session_display")
  lastRunId       String?  @map("last_run_id") @db.Uuid
  lastError       String?  @map("last_error") @db.Text
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization  Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agentInstance AgentInstance     @relation(fields: [agentInstanceId], references: [id], onDelete: Cascade)
  lastRun       AgentRun?         @relation("AgentTaskSessionLastRun", fields: [lastRunId], references: [id], onDelete: SetNull)
  requests      AgentRunRequest[]
  runs          AgentRun[]

  @@unique([organizationId, agentInstanceId, adapterType, taskKey])
  @@index([organizationId, agentInstanceId, updatedAt])
  @@index([agentInstanceId])
  @@index([lastRunId])
  @@map("agent_task_sessions")
}

/// @namespace AgentOS
/// @describe Durable request inbox + queue + dedupe + audit. Replaces AgentWakeupRequest. Queue state lives here, not on AgentRun.
model AgentRunRequest {
  id                     String    @id @default(uuid()) @db.Uuid
  organizationId         String    @map("organization_id") @db.Uuid
  agentInstanceId        String    @map("agent_instance_id") @db.Uuid
  taskSessionId          String    @map("task_session_id") @db.Uuid
  source                 String
  triggerDetail          String?   @map("trigger_detail")
  reason                 String?
  idempotencyKey         String?   @map("idempotency_key")
  priority               Int       @default(0)
  sourceWorkflowRunId    String?   @map("source_workflow_run_id") @db.Uuid
  sourceWorkflowNodeId   String?   @map("source_workflow_node_id")
  sourceResourceType     String?   @map("source_resource_type")
  sourceResourceId       String?   @map("source_resource_id")
  requestedByUserId      String?   @map("requested_by_user_id") @db.Uuid
  requestedByActorType   String?   @map("requested_by_actor_type")
  requestedByActorId     String?   @map("requested_by_actor_id")
  conversationId         String?   @map("conversation_id") @db.Uuid
  initiatedByMessageId   String?   @map("initiated_by_message_id") @db.Uuid
  parentRequestId        String?   @map("parent_request_id") @db.Uuid
  delegatedByRunId       String?   @map("delegated_by_run_id") @db.Uuid
  playbookKey            String?   @map("playbook_key")
  planStepKey            String?   @map("plan_step_key")
  displayName            String?   @map("display_name")
  statusReason           String?   @map("status_reason")
  dependencyKeys         Json      @default("[]") @map("dependency_keys") @db.JsonB
  payload                Json      @default("{}") @db.JsonB
  status                 String    @default("pending")
  scheduledFor           DateTime  @default(now()) @map("scheduled_for") @db.Timestamptz
  claimedAt              DateTime? @map("claimed_at") @db.Timestamptz
  claimedBy              String?   @map("claimed_by")
  attempts               Int       @default(0)
  maxAttempts            Int       @default(3) @map("max_attempts")
  finishedAt             DateTime? @map("finished_at") @db.Timestamptz
  coalescedIntoRequestId String?   @map("coalesced_into_request_id") @db.Uuid
  lastErrorCode          String?   @map("last_error_code")
  lastErrorMessage       String?   @map("last_error_message") @db.Text
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization         Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agentInstance        AgentInstance             @relation(fields: [agentInstanceId], references: [id], onDelete: Cascade)
  taskSession          AgentTaskSession          @relation(fields: [taskSessionId], references: [id], onDelete: Restrict)
  sourceWorkflowRun    WorkflowRun?              @relation(fields: [sourceWorkflowRunId], references: [id], onDelete: SetNull)
  requestedBy          User?                     @relation("AgentRunRequestRequestedBy", fields: [requestedByUserId], references: [id], onDelete: SetNull)
  coalescedIntoRequest AgentRunRequest?          @relation("AgentRunRequestCoalescing", fields: [coalescedIntoRequestId], references: [id], onDelete: SetNull)
  coalescedRequests    AgentRunRequest[]         @relation("AgentRunRequestCoalescing")
  conversation         AgentConversation?        @relation("AgentConversationRequests", fields: [conversationId], references: [id], onDelete: SetNull)
  initiatedByMessage   AgentMessage?             @relation("AgentRunRequestInitiatedByMessage", fields: [initiatedByMessageId], references: [id], onDelete: SetNull)
  parentRequest        AgentRunRequest?          @relation("AgentRunRequestTaskTree", fields: [parentRequestId], references: [id], onDelete: SetNull)
  childRequests        AgentRunRequest[]         @relation("AgentRunRequestTaskTree")
  delegatedByRun       AgentRun?                 @relation("AgentRunDelegatedRequests", fields: [delegatedByRunId], references: [id], onDelete: SetNull)
  rootForConversations AgentConversation[]       @relation("AgentConversationRootRequest")
  runs                 AgentRun[]                @relation("AgentRunRequestRuns")
  messages             AgentMessage[]            @relation("AgentRunRequestMessages")
  toolInvocations      AgentToolInvocation[]
  artifacts            AgentArtifact[]
  authorizationEvents  AgentAuthorizationEvent[]
  approvalRequests     AgentApprovalRequest[]
  costEvents           AgentCostEvent[]

  @@unique([organizationId, agentInstanceId, idempotencyKey], map: "agent_run_request_org_agent_idempotency_unique", where: raw("idempotency_key IS NOT NULL"))
  @@index([organizationId, status, scheduledFor, priority])
  @@index([organizationId, agentInstanceId, status, requestedByUserId])
  @@index([agentInstanceId, status, scheduledFor])
  @@index([organizationId, sourceResourceType, sourceResourceId])
  @@index([sourceWorkflowRunId])
  @@index([coalescedIntoRequestId])
  @@index([taskSessionId])
  @@index([requestedByUserId])
  @@index([conversationId])
  @@index([parentRequestId])
  @@index([delegatedByRunId])
  @@index([initiatedByMessageId])
  @@index([organizationId, conversationId, status])
  @@map("agent_run_requests")
}

/// @namespace AgentOS
/// @describe Accepted execution attempt. Replaces HeartbeatRun. Always starts at status="running"; queue state lives on AgentRunRequest.
model AgentRun {
  id                   String    @id @default(uuid()) @db.Uuid
  organizationId       String    @map("organization_id") @db.Uuid
  agentInstanceId      String    @map("agent_instance_id") @db.Uuid
  requestId            String    @map("request_id") @db.Uuid
  taskSessionId        String    @map("task_session_id") @db.Uuid
  retryOfRunId         String?   @map("retry_of_run_id") @db.Uuid
  status               String    @default("running")
  attempt              Int       @default(1)
  invocationSource     String    @map("invocation_source")
  adapterType          String    @map("adapter_type")
  model                String
  provider             String?
  taskKey              String?   @map("task_key")
  sessionDisplayBefore String?   @map("session_display_before")
  sessionDisplayAfter  String?   @map("session_display_after")
  input                Json      @default("{}") @db.JsonB
  output               Json?     @db.JsonB
  startedAt            DateTime  @default(now()) @map("started_at") @db.Timestamptz
  finishedAt           DateTime? @map("finished_at") @db.Timestamptz
  heartbeatAt          DateTime? @map("heartbeat_at") @db.Timestamptz
  exitCode             Int?      @map("exit_code")
  signal               String?
  errorCode            String?   @map("error_code")
  errorMessage         String?   @map("error_message") @db.Text
  usageJson            Json?     @map("usage_json") @db.JsonB
  resultJson           Json?     @map("result_json") @db.JsonB
  logStore             String?   @map("log_store")
  logRef               String?   @map("log_ref")
  logSha256            String?   @map("log_sha256")
  logBytes             BigInt?   @map("log_bytes")
  logCompressed        Boolean   @default(false) @map("log_compressed")
  stdoutExcerpt        String?   @map("stdout_excerpt") @db.Text
  stderrExcerpt        String?   @map("stderr_excerpt") @db.Text
  lastEventSeq         Int       @default(0) @map("last_event_seq")
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization        Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agentInstance       AgentInstance             @relation(fields: [agentInstanceId], references: [id], onDelete: Cascade)
  request             AgentRunRequest           @relation("AgentRunRequestRuns", fields: [requestId], references: [id], onDelete: Restrict)
  taskSession         AgentTaskSession          @relation(fields: [taskSessionId], references: [id], onDelete: Restrict)
  retryOfRun          AgentRun?                 @relation("AgentRunRetry", fields: [retryOfRunId], references: [id], onDelete: SetNull)
  retries             AgentRun[]                @relation("AgentRunRetry")
  delegatedRequests   AgentRunRequest[]         @relation("AgentRunDelegatedRequests")
  messages            AgentMessage[]
  toolInvocations     AgentToolInvocation[]
  artifacts           AgentArtifact[]
  events              AgentRunEvent[]
  costEvents          AgentCostEvent[]
  authorizationEvents AgentAuthorizationEvent[]
  approvalRequests    AgentApprovalRequest[]
  runtimeStateLastRun AgentRuntimeState[]       @relation("AgentRuntimeStateLastRun")
  taskSessionLastRun  AgentTaskSession[]        @relation("AgentTaskSessionLastRun")

  @@unique([requestId, attempt])
  @@index([organizationId, agentInstanceId, startedAt])
  @@index([organizationId, status, startedAt])
  @@index([requestId])
  @@index([taskSessionId])
  @@index([agentInstanceId])
  @@index([retryOfRunId])
  @@map("agent_runs")
}

/// @namespace AgentOS
/// @describe Run-local event timeline (status, tool, model, safety, fallback). Bulk logs go to external store via logRef.
model AgentRunEvent {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  runId           String   @map("run_id") @db.Uuid
  agentInstanceId String   @map("agent_instance_id") @db.Uuid
  seq             Int
  type            String
  level           String   @default("info")
  stream          String?
  message         String?  @db.Text
  data            Json     @default("{}") @db.JsonB
  logRef          String?  @map("log_ref")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  run           AgentRun      @relation(fields: [runId], references: [id], onDelete: Cascade)
  agentInstance AgentInstance @relation(fields: [agentInstanceId], references: [id], onDelete: Cascade)

  @@unique([runId, seq])
  @@index([organizationId, runId, seq])
  @@index([organizationId, type, createdAt])
  @@index([agentInstanceId])
  @@map("agent_run_events")
}

/// @namespace AgentOS
/// @describe Catalog of business tools agents may invoke. KidItem ships a curated set; not a generic HTTP/DB tool marketplace.
model AgentToolDefinition {
  id               String   @id @default(uuid()) @db.Uuid
  key              String   @unique
  name             String
  description      String?
  riskLevel        String   @default("low") @map("risk_level")
  credentialKind   String   @default("none") @map("credential_kind")
  inputSchemaJson  Json?    @map("input_schema_json") @db.JsonB
  outputSchemaJson Json?    @map("output_schema_json") @db.JsonB
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  instancePolicies    AgentInstanceToolPolicy[]
  authorizationEvents AgentAuthorizationEvent[]

  @@index([riskLevel])
  @@index([isActive])
  @@map("agent_tool_definitions")
}

/// @namespace AgentOS
/// @describe Per-instance override for tool policy. Registry defaults are code-owned; DB stores organization overrides.
model AgentInstanceToolPolicy {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  agentInstanceId String   @map("agent_instance_id") @db.Uuid
  toolId          String   @map("tool_id") @db.Uuid
  effect          String
  approvalMode    String   @default("none") @map("approval_mode")
  dryRunMode      String   @default("optional") @map("dry_run_mode")
  constraints     Json     @default("{}") @db.JsonB
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization  Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agentInstance AgentInstance       @relation(fields: [agentInstanceId], references: [id], onDelete: Cascade)
  tool          AgentToolDefinition @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@unique([organizationId, agentInstanceId, toolId])
  @@index([agentInstanceId])
  @@index([toolId])
  @@index([organizationId, effect])
  @@map("agent_instance_tool_policies")
}

/// @namespace AgentOS
/// @describe Authorization audit. Logged before, during, and outside runs (eg. admin policy widening).
model AgentAuthorizationEvent {
  id                String   @id @default(uuid()) @db.Uuid
  organizationId    String   @map("organization_id") @db.Uuid
  agentInstanceId   String   @map("agent_instance_id") @db.Uuid
  requestId         String?  @map("request_id") @db.Uuid
  runId             String?  @map("run_id") @db.Uuid
  toolId            String?  @map("tool_id") @db.Uuid
  actorType         String?  @map("actor_type")
  actorId           String?  @map("actor_id")
  action            String
  decision          String
  reasonCode        String?  @map("reason_code")
  reason            String?
  resourceType      String?  @map("resource_type")
  resourceId        String?  @map("resource_id")
  policySnapshot    Json     @default("{}") @map("policy_snapshot") @db.JsonB
  requestedByUserId String?  @map("requested_by_user_id") @db.Uuid
  decidedByUserId   String?  @map("decided_by_user_id") @db.Uuid
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz

  organization  Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agentInstance AgentInstance        @relation(fields: [agentInstanceId], references: [id], onDelete: Cascade)
  request       AgentRunRequest?     @relation(fields: [requestId], references: [id], onDelete: SetNull)
  run           AgentRun?            @relation(fields: [runId], references: [id], onDelete: SetNull)
  tool          AgentToolDefinition? @relation(fields: [toolId], references: [id], onDelete: SetNull)
  requestedBy   User?                @relation("AgentAuthorizationRequestedBy", fields: [requestedByUserId], references: [id], onDelete: SetNull)
  decidedBy     User?                @relation("AgentAuthorizationDecidedBy", fields: [decidedByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, agentInstanceId, createdAt])
  @@index([organizationId, decision, createdAt])
  @@index([requestId])
  @@index([runId])
  @@index([toolId])
  @@index([requestedByUserId])
  @@index([decidedByUserId])
  @@map("agent_authorization_events")
}

/// @namespace AgentOS
/// @describe Human approval state. While pending, AgentRunRequest.status = requires_approval.
model AgentApprovalRequest {
  id                   String    @id @default(uuid()) @db.Uuid
  organizationId       String    @map("organization_id") @db.Uuid
  agentInstanceId      String    @map("agent_instance_id") @db.Uuid
  requestId            String    @map("request_id") @db.Uuid
  runId                String?   @map("run_id") @db.Uuid
  status               String    @default("pending")
  reasonCode           String?   @map("reason_code")
  reason               String?
  prompt               String?   @db.Text
  payload              Json      @default("{}") @db.JsonB
  actionSnapshot       Json?     @map("action_snapshot") @db.JsonB
  requestedByActorType String?   @map("requested_by_actor_type")
  requestedByActorId   String?   @map("requested_by_actor_id")
  requestedByUserId    String?   @map("requested_by_user_id") @db.Uuid
  approverUserId       String?   @map("approver_user_id") @db.Uuid
  decidedByUserId      String?   @map("decided_by_user_id") @db.Uuid
  decidedAt            DateTime? @map("decided_at") @db.Timestamptz
  decisionReason       String?   @map("decision_reason") @db.Text
  expiresAt            DateTime? @map("expires_at") @db.Timestamptz
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization    Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agentInstance   AgentInstance         @relation(fields: [agentInstanceId], references: [id], onDelete: Cascade)
  request         AgentRunRequest       @relation(fields: [requestId], references: [id], onDelete: Cascade)
  run             AgentRun?             @relation(fields: [runId], references: [id], onDelete: SetNull)
  requestedBy     User?                 @relation("AgentApprovalRequestedBy", fields: [requestedByUserId], references: [id], onDelete: SetNull)
  approver        User?                 @relation("AgentApprovalApprover", fields: [approverUserId], references: [id], onDelete: SetNull)
  decidedBy       User?                 @relation("AgentApprovalDecidedBy", fields: [decidedByUserId], references: [id], onDelete: SetNull)
  toolInvocations AgentToolInvocation[]

  @@index([organizationId, status, createdAt])
  @@index([organizationId, approverUserId, status])
  @@index([requestId])
  @@index([runId])
  @@index([agentInstanceId])
  @@index([approverUserId])
  @@index([requestedByUserId])
  @@index([decidedByUserId])
  @@map("agent_approval_requests")
}

/// @namespace AgentOS
/// @describe Cost ledger source of truth. Insert + AgentRuntimeState aggregate update share one transaction.
model AgentCostEvent {
  id                String   @id @default(uuid()) @db.Uuid
  organizationId    String   @map("organization_id") @db.Uuid
  agentInstanceId   String   @map("agent_instance_id") @db.Uuid
  requestId         String   @map("request_id") @db.Uuid
  runId             String   @map("run_id") @db.Uuid
  provider          String
  model             String
  biller            String?
  billingType       String?  @map("billing_type")
  inputTokens       Int      @default(0) @map("input_tokens")
  outputTokens      Int      @default(0) @map("output_tokens")
  cachedInputTokens Int      @default(0) @map("cached_input_tokens")
  costMicros        BigInt   @default(0) @map("cost_micros")
  metadata          Json     @default("{}") @db.JsonB
  occurredAt        DateTime @default(now()) @map("occurred_at") @db.Timestamptz
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz

  organization  Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agentInstance AgentInstance   @relation(fields: [agentInstanceId], references: [id], onDelete: Cascade)
  request       AgentRunRequest @relation(fields: [requestId], references: [id], onDelete: Restrict)
  run           AgentRun        @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([organizationId, agentInstanceId, occurredAt])
  @@index([organizationId, provider, model, occurredAt])
  @@index([requestId])
  @@index([runId])
  @@map("agent_cost_events")
}

/// @namespace AgentOS
/// @describe User-facing Agent OS conversation thread.
model AgentConversation {
  id              String    @id @default(uuid()) @db.Uuid
  organizationId  String    @map("organization_id") @db.Uuid
  title           String
  status          String    @default("active")
  createdByUserId String?   @map("created_by_user_id") @db.Uuid
  rootRequestId   String?   @map("root_request_id") @db.Uuid
  lastMessageAt   DateTime? @map("last_message_at") @db.Timestamptz
  metadata        Json      @default("{}") @db.JsonB
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization    Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy       User?                 @relation("AgentConversationCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  rootRequest     AgentRunRequest?      @relation("AgentConversationRootRequest", fields: [rootRequestId], references: [id], onDelete: SetNull)
  messages        AgentMessage[]
  requests        AgentRunRequest[]     @relation("AgentConversationRequests")
  toolInvocations AgentToolInvocation[]
  artifacts       AgentArtifact[]

  @@index([organizationId, status, updatedAt])
  @@index([createdByUserId])
  @@index([rootRequestId])
  @@map("agent_conversations")
}

/// @namespace AgentOS
/// @describe Visible conversation message tied to user, Operator, agent, or tool output.
model AgentMessage {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  conversationId  String   @map("conversation_id") @db.Uuid
  role            String
  content         String   @db.Text
  agentInstanceId String?  @map("agent_instance_id") @db.Uuid
  requestId       String?  @map("request_id") @db.Uuid
  runId           String?  @map("run_id") @db.Uuid
  metadata        Json     @default("{}") @db.JsonB
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversation      AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  agentInstance     AgentInstance?    @relation(fields: [agentInstanceId], references: [id], onDelete: SetNull)
  request           AgentRunRequest?  @relation("AgentRunRequestMessages", fields: [requestId], references: [id], onDelete: SetNull)
  run               AgentRun?         @relation(fields: [runId], references: [id], onDelete: SetNull)
  initiatedRequests AgentRunRequest[] @relation("AgentRunRequestInitiatedByMessage")

  @@index([organizationId, conversationId, createdAt])
  @@index([agentInstanceId])
  @@index([requestId])
  @@index([runId])
  @@map("agent_messages")
}

/// @namespace AgentOS
/// @describe Durable capability/tool invocation audit record.
model AgentToolInvocation {
  id                String    @id @default(uuid()) @db.Uuid
  organizationId    String    @map("organization_id") @db.Uuid
  conversationId    String?   @map("conversation_id") @db.Uuid
  agentInstanceId   String    @map("agent_instance_id") @db.Uuid
  requestId         String?   @map("request_id") @db.Uuid
  runId             String?   @map("run_id") @db.Uuid
  approvalRequestId String?   @map("approval_request_id") @db.Uuid
  capabilityKey     String    @map("capability_key")
  status            String    @default("requested")
  policyDecision    String    @map("policy_decision")
  reasonCode        String?   @map("reason_code")
  resourceType      String?   @map("resource_type")
  resourceId        String?   @map("resource_id")
  idempotencyKey    String?   @map("idempotency_key")
  inputSummary      Json      @default("{}") @map("input_summary") @db.JsonB
  outputSummary     Json?     @map("output_summary") @db.JsonB
  errorCode         String?   @map("error_code")
  errorMessage      String?   @map("error_message") @db.Text
  startedAt         DateTime? @map("started_at") @db.Timestamptz
  completedAt       DateTime? @map("completed_at") @db.Timestamptz
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization    Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversation    AgentConversation?    @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  agentInstance   AgentInstance         @relation(fields: [agentInstanceId], references: [id], onDelete: Cascade)
  request         AgentRunRequest?      @relation(fields: [requestId], references: [id], onDelete: SetNull)
  run             AgentRun?             @relation(fields: [runId], references: [id], onDelete: SetNull)
  approvalRequest AgentApprovalRequest? @relation(fields: [approvalRequestId], references: [id], onDelete: SetNull)
  artifacts       AgentArtifact[]

  @@unique([organizationId, capabilityKey, idempotencyKey], map: "agent_tool_invocation_org_key_idempotency_unique", where: raw("idempotency_key IS NOT NULL"))
  @@index([organizationId, conversationId, createdAt])
  @@index([organizationId, agentInstanceId, createdAt])
  @@index([requestId])
  @@index([runId])
  @@index([approvalRequestId])
  @@index([capabilityKey])
  @@map("agent_tool_invocations")
}

/// @namespace AgentOS
/// @describe User-visible output card linked to task, tool, or domain record.
model AgentArtifact {
  id               String   @id @default(uuid()) @db.Uuid
  organizationId   String   @map("organization_id") @db.Uuid
  conversationId   String?  @map("conversation_id") @db.Uuid
  agentInstanceId  String?  @map("agent_instance_id") @db.Uuid
  requestId        String?  @map("request_id") @db.Uuid
  runId            String?  @map("run_id") @db.Uuid
  toolInvocationId String?  @map("tool_invocation_id") @db.Uuid
  artifactType     String   @map("artifact_type")
  targetDomain     String   @map("target_domain")
  targetModel      String   @map("target_model")
  targetId         String?  @map("target_id")
  title            String
  href             String?
  summary          Json     @default("{}") @db.JsonB
  status           String   @default("active")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversation   AgentConversation?   @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  agentInstance  AgentInstance?       @relation(fields: [agentInstanceId], references: [id], onDelete: SetNull)
  request        AgentRunRequest?     @relation(fields: [requestId], references: [id], onDelete: SetNull)
  run            AgentRun?            @relation(fields: [runId], references: [id], onDelete: SetNull)
  toolInvocation AgentToolInvocation? @relation(fields: [toolInvocationId], references: [id], onDelete: SetNull)

  @@index([organizationId, conversationId, createdAt])
  @@index([organizationId, artifactType, status])
  @@index([targetDomain, targetModel, targetId])
  @@index([requestId])
  @@index([runId])
  @@index([toolInvocationId])
  @@map("agent_artifacts")
}

/// @namespace AgentOS
/// @describe Workflow run record. Workflow runner triggers Agent OS via AgentRunnerPort with sourceWorkflowRunId.
model WorkflowRun {
  id                String    @id @default(uuid()) @db.Uuid
  organizationId    String?   @map("organization_id") @db.Uuid
  templateId        String    @map("template_id") @db.Uuid
  status            String    @default("pending")
  triggeredBy       String    @default("manual") @map("triggered_by")
  triggeredByUserId String?   @map("triggered_by_user_id") @db.Uuid
  contextData       Json?     @map("context_data")
  steps             Json      @default("[]") @db.JsonB
  error             String?
  startedAt         DateTime? @map("started_at") @db.Timestamptz
  completedAt       DateTime? @map("completed_at") @db.Timestamptz
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  template         WorkflowTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  triggeredByUser  User?             @relation("WorkflowRunTriggeredBy", fields: [triggeredByUserId], references: [id], onDelete: SetNull)
  agentRunRequests AgentRunRequest[]

  @@index([organizationId])
  @@index([templateId])
  @@index([status])
  @@index([createdAt])
  @@index([organizationId, triggeredByUserId])
  @@index([triggeredByUserId])
  @@map("workflow_runs")
}

/// @namespace AgentOS
/// @describe Workflow definition. Trigger config + nodes/edges.
model WorkflowTemplate {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String
  description    String   @default("")
  module         String   @default("order")
  isActive       Boolean  @default(false) @map("is_active")
  triggerType    String   @default("manual") @map("trigger_type")
  schedule       String?
  nodesJson      Json     @map("nodes_json")
  edgesJson      Json     @map("edges_json")
  version        Int      @default(1)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  marketplaceId String? @map("marketplace_id") @db.Uuid

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  marketplace  Marketplace?  @relation(fields: [marketplaceId], references: [id], onDelete: SetNull)
  runs         WorkflowRun[]

  @@index([organizationId])
  @@index([isActive])
  @@index([module])
  @@index([marketplaceId])
  @@map("workflow_templates")
}
