// core.prisma — Core domain

/// @namespace Core
model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Core
  memberships                     OrganizationMembership[]
  legalEntities                   LegalEntity[]
  channelAccounts                 ChannelAccount[]
  sourceImportRuns                SourceImportRun[]
  orders                          Order[]
  purchaseOrders                  PurchaseOrder[]
  purchaseOrderSubmissionAttempts PurchaseOrderSubmissionAttempt[]
  profitLoss                      ProfitLoss[]
  thumbnails                      Thumbnail[]
  thumbnailAnalyses               ThumbnailAnalysis[]
  thumbnailGenerations            ThumbnailGeneration[]
  thumbnailGenerationCandidates   ThumbnailGenerationCandidate[]
  thumbnailGenerationInputImages  ThumbnailGenerationInputImage[]
  thumbnailGenerationEvents       ThumbnailGenerationEvent[]
  thumbnailRegistrationAttempts   ThumbnailRegistrationAttempt[]
  thumbnailTrackings              ThumbnailTracking[]
  thumbnailTrackingDailySnapshots ThumbnailTrackingDailySnapshot[]
  reviews                         Review[]
  alerts                          Alert[]

  // Sourcing & Content
  contentGenerations                  ContentGeneration[]
  contentGenerationGroups             ContentGenerationGroup[]
  contentGenerationSources            ContentGenerationSource[]
  contentAssets                       ContentAsset[]
  contentGenerationAssetUsages        ContentGenerationAssetUsage[]
  contentWorkspaces                   ContentWorkspace[]
  contentWorkspaceThumbnailSelections ContentWorkspaceThumbnailSelection[]
  productPreparations                 ProductPreparation[]
  detailPageArtifacts                 DetailPageArtifact[]
  detailPageRevisions                 DetailPageRevision[]

  // Workflow & Agent
  workflowTemplates WorkflowTemplate[]
  activityEvents    ActivityEvent[]

  // Agent OS
  agentInstances            AgentInstance[]
  agentRuntimeStates        AgentRuntimeState[]
  agentTaskSessions         AgentTaskSession[]
  agentRunRequests          AgentRunRequest[]
  agentRuns                 AgentRun[]
  agentRunEvents            AgentRunEvent[]
  agentInstanceToolPolicies AgentInstanceToolPolicy[]
  agentAuthorizationEvents  AgentAuthorizationEvent[]
  agentApprovalRequests     AgentApprovalRequest[]
  agentCostEvents           AgentCostEvent[]
  agentConversations        AgentConversation[]
  agentMessages             AgentMessage[]
  agentToolInvocations      AgentToolInvocation[]
  agentArtifacts            AgentArtifact[]

  // Order domain (Plan A.5)
  orderLineItems       OrderLineItem[]
  orderReturns         OrderReturn[]
  orderReturnLineItems OrderReturnLineItem[]

  // Supplier & Procurement
  suppliers          Supplier[]
  supplierPayments   SupplierPayment[]
  supplierProducts   SupplierProduct[]
  purchaseOrderItems PurchaseOrderItem[]

  // Warehouse & record-only inventory operations
  warehouses                                    Warehouse[]
  stockTransfers                                StockTransfer[]
  stockAudits                                   StockAudit[]
  sellpiaReceiptUploadBatches                   SellpiaReceiptUploadBatch[]
  sellpiaInventoryState                         SellpiaInventoryState?
  sellpiaOrderTransmissionIntents               SellpiaOrderTransmissionIntent[]
  sellpiaOrderTransmissionIntentReconciliations SellpiaOrderTransmissionIntentReconciliation[]

  // Logistics
  shipments       Shipment[]
  shipmentItems   ShipmentItem[]
  unshippedItems  UnshippedItem[]
  pickingLists    PickingList[]
  pickingItems    PickingItem[]
  returnTransfers ReturnTransfer[]

  // Product Extensions
  processingCosts ProcessingCost[]

  // Finance
  settlements   Settlement[]
  manualLedgers ManualLedger[]

  // Operations & Config
  csRecords        CSRecord[]
  categoryMappings CategoryMapping[]

  // Analytics
  salesPlans                 SalesPlan[]
  rocketSupplyDailySnapshots RocketSupplyDailySnapshot[]
  rocketPurchaseOrders       RocketPurchaseOrder[]

  // Ontology
  businessRules  BusinessRule[]
  systemSettings SystemSetting[]

  // Ad Scrape Targets
  scrapeTargets ScrapeTarget[]

  // Ad Execution
  adActions        AdAction[]
  executionWorkers ExecutionWorker[]

  // Action Board
  actionTasks ActionTask[]

  // Product operations, Sellpia physical items, and channel catalogs
  masterProducts           MasterProduct[]
  productVariants          ProductVariant[]
  productVariantComponents ProductVariantComponent[]
  sellpiaInventorySkus     SellpiaInventorySku[]
  channelListings          ChannelListing[]
  channelListingOptions    ChannelListingOption[]

  // Channels — market-data snapshots (Wave C0)
  channelScrapeRuns                  ChannelScrapeRun[]
  channelScrapeChunks                ChannelScrapeChunk[]
  channelScrapeSnapshots             ChannelScrapeSnapshot[]
  channelListingDailySnapshots       ChannelListingDailySnapshot[]
  channelListingOptionDailySnapshots ChannelListingOptionDailySnapshot[]

  // Channels — daily fact extensions (Hard rewrite H1)
  channelAdTargetDailySnapshots   ChannelAdTargetDailySnapshot[]
  channelAccountDailyKpiSnapshots ChannelAccountDailyKpiSnapshot[]

  // Channels — Coupang keyword and competitor rank tracking
  coupangRepresentativeKeywordOverrides   CoupangRepresentativeKeywordOverride[]
  coupangKeywordTrackers                  CoupangKeywordTracker[]
  coupangKeywordRankDailySnapshots        CoupangKeywordRankDailySnapshot[]
  coupangKeywordSerpDailySnapshots        CoupangKeywordSerpDailySnapshot[]
  coupangWingSalesRankDailySnapshots      CoupangWingSalesRankDailySnapshot[]
  coupangWingTrackedProducts              CoupangWingTrackedProduct[]
  coupangWingTrackedProductDailySnapshots CoupangWingTrackedProductDailySnapshot[]

  // Additional back-relations for FK rename additions
  gradeHistory GradeHistory[] // Task 8 Step 2 adds organizationId to GradeHistory

  // Sourcing (issue #192)
  sourcingCandidates         SourcingCandidate[]
  candidateImages            CandidateImage[]
  sourcingWorkspaceSnapshots SourcingWorkspaceSnapshot[]

  // Sourcing — market trend and live-commerce snapshots
  trendSeedKeywords                    TrendSeedKeyword[]
  naverKeywordDailySnapshots           NaverKeywordDailySnapshot[]
  naverPopularKeywordDailySnapshots    NaverPopularKeywordDailySnapshot[]
  sourcing1688HotProductDailySnapshots Sourcing1688HotProductDailySnapshot[]
  shortsTrendDailySnapshots            ShortsTrendDailySnapshot[]
  liveCommerceBroadcastDailySnapshots  LiveCommerceBroadcastDailySnapshot[]
  liveCommerceProductDailySnapshots    LiveCommerceProductDailySnapshot[]

  @@map("organizations")
}

/// @namespace Core
/// @describe human(직원) / agent(AI, agentInstanceId 연결) / system(챗봇). 조직 소속은 OrganizationMembership 이 source of truth.
model User {
  id              String    @id @default(uuid()) @db.Uuid
  email           String    @unique
  name            String
  password        String?
  role            String    @default("member") // global/default role; per-organization role lives on OrganizationMembership.
  type            String    @default("human")
  team            String?
  avatarUrl       String?   @map("avatar_url")
  agentInstanceId String?   @map("agent_instance_id") @db.Uuid
  isActive        Boolean   @default(true) @map("is_active")
  lastLoginAt     DateTime? @map("last_login_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  agentInstance                              AgentInstance?                                 @relation(fields: [agentInstanceId], references: [id], onDelete: SetNull)
  memberships                                OrganizationMembership[]
  invitedOrganizationMemberships             OrganizationMembership[]                       @relation("OrganizationMembershipInviter")
  triggeredWorkflowRuns                      WorkflowRun[]                                  @relation("WorkflowRunTriggeredBy")
  triggeredThumbnailGenerations              ThumbnailGeneration[]                          @relation("ThumbnailGenerationTriggeredBy")
  thumbnailGenerationEvents                  ThumbnailGenerationEvent[]                     @relation("ThumbnailGenerationEventActor")
  triggeredContentGenerations                ContentGeneration[]                            @relation("ContentGenerationTriggeredBy")
  createdContentAssets                       ContentAsset[]                                 @relation("ContentAssetCreatedBy")
  createdContentWorkspaces                   ContentWorkspace[]                             @relation("ContentWorkspaceCreatedBy")
  createdContentWorkspaceThumbnailSelections ContentWorkspaceThumbnailSelection[]           @relation("ContentWorkspaceThumbnailSelectionCreatedBy")
  createdProductPreparations                 ProductPreparation[]                           @relation("ProductPreparationCreatedBy")
  createdDetailPageArtifacts                 DetailPageArtifact[]                           @relation("DetailPageArtifactCreatedBy")
  createdDetailPageRevisions                 DetailPageRevision[]                           @relation("DetailPageRevisionCreatedBy")
  actorAlerts                                Alert[]                                        @relation("AlertActor")
  assignedActionTasks                        ActionTask[]                                   @relation("ActionTaskAssignee")
  activeSellpiaInventoryStates               SellpiaInventoryState[]                        @relation("SellpiaInventoryStateActiveSyncOwner")
  createdSellpiaOrderTransmissionIntents     SellpiaOrderTransmissionIntent[]               @relation("SellpiaOrderTransmissionIntentCreator")
  reconciledSellpiaOrderTransmissionIntents  SellpiaOrderTransmissionIntentReconciliation[] @relation("SellpiaOrderTransmissionIntentReconciler")
  confirmedSourceImportRuns                  SourceImportRun[]                              @relation("SourceImportRunManualFreshExportConfirmer")
  reconciledPurchaseOrderSubmissionAttempts  PurchaseOrderSubmissionAttempt[]               @relation("PurchaseOrderSubmissionAttemptReconciler")

  // Agent OS — actor relations
  requestedAgentRunRequests         AgentRunRequest[]         @relation("AgentRunRequestRequestedBy")
  requestedAgentAuthorizationEvents AgentAuthorizationEvent[] @relation("AgentAuthorizationRequestedBy")
  decidedAgentAuthorizationEvents   AgentAuthorizationEvent[] @relation("AgentAuthorizationDecidedBy")
  requestedAgentApprovalRequests    AgentApprovalRequest[]    @relation("AgentApprovalRequestedBy")
  approverAgentApprovalRequests     AgentApprovalRequest[]    @relation("AgentApprovalApprover")
  decidedAgentApprovalRequests      AgentApprovalRequest[]    @relation("AgentApprovalDecidedBy")
  createdAgentConversations         AgentConversation[]       @relation("AgentConversationCreatedBy")

  // Sourcing (issue #192)
  rejectedSourcingCandidates  SourcingCandidate[] @relation("SourcingCandidateRejectedBy")
  triggeredSourcingCandidates SourcingCandidate[] @relation("SourcingCandidateTriggeredBy")

  @@index([agentInstanceId])
  @@map("users")
}

/// @namespace Core
/// @describe B2B customer/workspace membership. A user may belong to multiple organizations; this row supplies request organization and role.
model OrganizationMembership {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  role           String    @default("member")
  status         String    @default("active")
  invitedById    String?   @map("invited_by_id") @db.Uuid
  joinedAt       DateTime  @default(now()) @map("joined_at") @db.Timestamptz
  lastSelectedAt DateTime? @map("last_selected_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitedBy    User?        @relation("OrganizationMembershipInviter", fields: [invitedById], references: [id], onDelete: SetNull)

  @@unique([organizationId, userId])
  @@index([userId, status])
  @@index([organizationId, role])
  @@index([invitedById])
  @@map("organization_memberships")
}

/// @namespace Core
/// @describe Legal/business entity under an organization. This stores tax, invoice, and settlement identity separately from the SaaS organization boundary.
model LegalEntity {
  id                 String   @id @default(uuid()) @db.Uuid
  organizationId     String   @map("organization_id") @db.Uuid
  name               String
  businessNumber     String?  @map("business_number")
  countryCode        String   @default("KR") @map("country_code")
  representativeName String?  @map("representative_name")
  address            String?
  isPrimary          Boolean  @default(false) @map("is_primary")
  metadata           Json?    @db.JsonB
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, isPrimary])
  @@map("legal_entities")
}

/// @namespace Core
/// @describe Marketplace/store account such as Coupang Wing or Naver SmartStore. Operational channel ownership is distinct from the SaaS organization.
model ChannelAccount {
  id                String   @id @default(uuid()) @db.Uuid
  organizationId    String   @map("organization_id") @db.Uuid
  channel           String
  name              String
  externalAccountId String?  @map("external_account_id")
  sellerId          String?  @map("seller_id")
  vendorId          String?  @map("vendor_id")
  status            String   @default("active")
  isPrimary         Boolean  @default(false) @map("is_primary")
  config            Json?    @db.JsonB
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization                    Organization                     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  listings                        ChannelListing[]
  sourceImportRuns                SourceImportRun[]
  productPreparations             ProductPreparation[]
  orders                          Order[]
  orderReturns                    OrderReturn[]
  channelScrapeRuns               ChannelScrapeRun[]
  channelAccountDailyKpiSnapshots ChannelAccountDailyKpiSnapshot[]

  @@unique([organizationId, channel, externalAccountId])
  @@unique([id, organizationId], map: "channel_accounts_id_org_key")
  @@index([organizationId, channel])
  @@index([organizationId, isPrimary])
  @@map("channel_accounts")
}

/// @namespace Core
/// @describe Durable provenance and publication fence for Sellpia and channel full-snapshot imports.
model SourceImportRun {
  id                           String    @id @default(uuid()) @db.Uuid
  organizationId               String    @map("organization_id") @db.Uuid
  sourceType                   String    @map("source_type")
  channelAccountId             String?   @map("channel_account_id") @db.Uuid
  fileName                     String?   @map("file_name")
  fileHash                     String?   @map("file_hash")
  status                       String    @default("running")
  rowCount                     Int       @default(0) @map("row_count")
  importedAt                   DateTime? @map("imported_at") @db.Timestamptz
  lastVerifiedAt               DateTime? @map("last_verified_at") @db.Timestamptz
  verificationCount            Int       @default(0) @map("verification_count")
  lastTrigger                  String?   @map("last_trigger")
  freshnessGeneration          BigInt?   @map("freshness_generation") @db.BigInt
  manualFreshExportConfirmedAt DateTime? @map("manual_fresh_export_confirmed_at") @db.Timestamptz
  manualFreshExportConfirmedBy String?   @map("manual_fresh_export_confirmed_by") @db.Uuid
  qualityReport                Json?     @map("quality_report") @db.JsonB
  errorCode                    String?   @map("error_code")
  errorMessage                 String?   @map("error_message")
  createdBy                    String?   @map("created_by")
  attemptToken                 String    @default(uuid()) @map("attempt_token") @db.Uuid
  publicationSequence          BigInt?   @map("publication_sequence") @db.BigInt
  createdAt                    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization                        Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  channelAccount                      ChannelAccount?         @relation(fields: [channelAccountId, organizationId], references: [id, organizationId], onDelete: Restrict)
  manualFreshExportConfirmer          User?                   @relation("SourceImportRunManualFreshExportConfirmer", fields: [manualFreshExportConfirmedBy], references: [id], onDelete: SetNull)
  sellpiaInventorySkus                SellpiaInventorySku[]   @relation("SellpiaInventorySkuLastImport")
  channelProducts                     ChannelListing[]        @relation("ChannelProductLastImport")
  channelSkus                         ChannelListingOption[]  @relation("ChannelSkuLastImport")
  channelScrapeRuns                   ChannelScrapeRun[]
  lastCompletedSellpiaInventoryStates SellpiaInventoryState[] @relation("SellpiaInventoryStateLastCompletedRun")

  @@unique([organizationId, sourceType, channelAccountId, fileHash], map: "source_import_runs_org_source_account_hash_key", where: raw("channel_account_id IS NOT NULL AND file_hash IS NOT NULL"))
  @@unique([organizationId, sourceType, fileHash], map: "source_import_runs_org_source_hash_null_account_key", where: raw("channel_account_id IS NULL AND file_hash IS NOT NULL"))
  @@unique([organizationId, sourceType, freshnessGeneration], map: "source_import_runs_org_source_failed_generation_key", where: raw("file_hash IS NULL AND source_type = 'sellpia_inventory' AND status = 'failed' AND freshness_generation IS NOT NULL"))
  @@unique([organizationId, sourceType, publicationSequence], map: "source_import_runs_org_source_publication_key", where: raw("publication_sequence IS NOT NULL"))
  @@unique([id, organizationId], map: "source_import_runs_id_org_key")
  @@index([organizationId, sourceType, status, createdAt])
  @@index([channelAccountId])
  @@index([manualFreshExportConfirmedBy])
  @@map("source_import_runs")
}

/// @namespace Core
model CategoryMapping {
  id                  String   @id @default(uuid()) @db.Uuid
  organizationId      String   @map("organization_id") @db.Uuid
  internalCategory    String   @map("internal_category")
  coupangCategoryId   String?  @map("coupang_category_id")
  coupangCategoryName String?  @map("coupang_category_name")
  keywords            String?
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, internalCategory])
  @@map("category_mappings")
}

/// @namespace Core
/// @describe KidItem-operated product identity and product-level operating metadata.
model MasterProduct {
  id              String    @id @default(uuid()) @db.Uuid
  organizationId  String    @map("organization_id") @db.Uuid
  code            String
  name            String
  description     String?
  category        String?
  brand           String?
  tags            String[]  @default([])
  imageUrls       String[]  @default([]) @map("image_urls")
  abcGrade        String?   @map("abc_grade")
  profitTag       String?   @map("profit_tag")
  adTier          String?   @map("ad_tier")
  adBudgetLimit   Int?      @map("ad_budget_limit")
  healthScore     Int?      @map("health_score")
  healthUpdatedAt DateTime? @map("health_updated_at") @db.Timestamptz
  isActive        Boolean   @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization        Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  provenanceCandidate SourcingCandidate? @relation("SourcingCandidateProvenance")
  variants            ProductVariant[]
  channelListings     ChannelListing[]
  processingCosts     ProcessingCost[]

  @@unique([organizationId, code])
  @@unique([id, organizationId], map: "master_products_id_org_key")
  @@index([organizationId])
  @@index([organizationId, isActive])
  @@map("master_products")
}

/// @namespace Core
/// @describe Reusable sellable unit beneath one MasterProduct. Code is stable organization-scoped identity.
model ProductVariant {
  id              String  @id @default(uuid()) @db.Uuid
  organizationId  String  @map("organization_id") @db.Uuid
  masterProductId String  @map("master_product_id") @db.Uuid
  code            String
  name            String
  optionLabel     String? @map("option_label")
  isDefault       Boolean @default(false) @map("is_default")
  isActive        Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization          Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  masterProduct         MasterProduct             @relation(fields: [masterProductId, organizationId], references: [id, organizationId], onDelete: Cascade)
  components            ProductVariantComponent[]
  channelListingOptions ChannelListingOption[]

  @@unique([organizationId, code])
  @@unique([id, organizationId], map: "product_variants_id_org_key")
  @@unique([masterProductId], map: "product_variants_active_default_master_key", where: raw("is_default = true AND is_active = true"))
  @@index([organizationId])
  @@index([masterProductId])
  @@index([organizationId, isActive])
  @@map("product_variants")
}

/// @namespace Core
/// @describe Central confirmed variant recipe. source: manual | deterministic; quantity is positive and validated by shared/service contracts.
model ProductVariantComponent {
  id                    String   @id @default(uuid()) @db.Uuid
  organizationId        String   @map("organization_id") @db.Uuid
  productVariantId      String   @map("product_variant_id") @db.Uuid
  sellpiaInventorySkuId String   @map("sellpia_inventory_sku_id") @db.Uuid
  quantity              Int // positive; validated by shared/service contracts
  source                String // manual | deterministic
  confirmedBy           String?  @map("confirmed_by") @db.Uuid
  confirmedAt           DateTime @default(now()) @map("confirmed_at") @db.Timestamptz
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization        Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  productVariant      ProductVariant      @relation(fields: [productVariantId, organizationId], references: [id, organizationId], onDelete: Cascade)
  sellpiaInventorySku SellpiaInventorySku @relation(fields: [sellpiaInventorySkuId, organizationId], references: [id, organizationId], onDelete: Restrict)

  @@unique([productVariantId, sellpiaInventorySkuId])
  @@index([organizationId])
  @@index([productVariantId])
  @@index([sellpiaInventorySkuId])
  @@index([organizationId, productVariantId])
  @@index([organizationId, sellpiaInventorySkuId])
  @@map("product_variant_components")
}

/// @namespace Core
/// @describe 채널에 올라간 판매 등록상품. 쿠팡 등록상품ID, 네이버 상품번호 등.
model ChannelListing {
  id                String  @id @default(uuid()) @db.Uuid
  organizationId    String  @map("organization_id") @db.Uuid
  channelAccountId  String  @map("channel_account_id") @db.Uuid
  sourceCandidateId String? @map("source_candidate_id") @db.Uuid
  masterProductId   String? @map("master_product_id") @db.Uuid

  externalId String @map("external_id")

  channelName     String? @map("channel_name")
  displayName     String? @map("display_name")
  category        String?
  brand           String?
  manufacturer    String?
  rawJson         Json?   @map("raw_json")
  lastImportRunId String? @map("last_import_run_id") @db.Uuid

  status         String?
  exposureStatus String? @map("exposure_status")

  deliveryChargeType String? @map("delivery_charge_type")
  freeShipOverAmount Int?    @map("free_ship_over_amount")
  returnCharge       Int?    @map("return_charge")
  deliveryInfo       Json?   @map("delivery_info")

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization        Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  channelAccount      ChannelAccount         @relation(fields: [channelAccountId, organizationId], references: [id, organizationId], onDelete: Restrict)
  sourceCandidate     SourcingCandidate?     @relation(fields: [sourceCandidateId, organizationId], references: [id, organizationId], onDelete: Restrict)
  masterProduct       MasterProduct?         @relation(fields: [masterProductId, organizationId], references: [id, organizationId], onDelete: Restrict)
  lastImportRun       SourceImportRun?       @relation("ChannelProductLastImport", fields: [lastImportRunId, organizationId], references: [id, organizationId], onDelete: Restrict)
  options             ChannelListingOption[]
  contentWorkspaces   ContentWorkspace[]
  productPreparations ProductPreparation[]

  reviews            Review[]
  thumbnails         Thumbnail[]
  thumbnailTrackings ThumbnailTracking[]
  adActions          AdAction[]
  csRecords          CSRecord[]
  profitLoss         ProfitLoss[]
  gradeHistory       GradeHistory[]

  // Channels — market-data snapshots (Wave C0)
  channelScrapeSnapshots             ChannelScrapeSnapshot[]
  channelListingDailySnapshots       ChannelListingDailySnapshot[]
  channelListingOptionDailySnapshots ChannelListingOptionDailySnapshot[]

  // Channels — daily fact extensions (Hard rewrite H1)
  channelAdTargetDailySnapshots ChannelAdTargetDailySnapshot[]

  @@unique([organizationId, channelAccountId, externalId])
  @@unique([organizationId, sourceCandidateId, channelAccountId], map: "channel_listings_org_source_account_active_key", where: raw("source_candidate_id IS NOT NULL AND is_active = true"))
  @@unique([id, organizationId], map: "channel_listings_id_org_key")
  @@index([organizationId])
  @@index([channelAccountId])
  @@index([sourceCandidateId])
  @@index([masterProductId])
  @@index([organizationId, masterProductId])
  @@index([lastImportRunId])
  @@index([organizationId, channelAccountId, isActive])
  @@index([organizationId, updatedAt, id])
  @@map("channel_listings")
}

/// @namespace Core
/// @describe One sellable SKU under a channel listing.
model ChannelListingOption {
  id               String  @id @default(uuid()) @db.Uuid
  listingId        String  @map("listing_id") @db.Uuid
  organizationId   String  @map("organization_id") @db.Uuid
  productVariantId String? @map("product_variant_id") @db.Uuid

  externalOptionId  String   @map("external_option_id") @db.VarChar(60)
  itemName          String?  @map("item_name")
  salePrice         Int?     @map("sale_price")
  costPriceOverride Int?     @map("cost_price_override")
  commissionRate    Decimal? @map("commission_rate") @db.Decimal(5, 4)
  shippingCost      Int?     @map("shipping_cost")
  otherCost         Int?     @map("other_cost")
  sellerSku         String?  @map("seller_sku")
  barcode           String?
  modelNumber       String?  @map("model_number")
  status            String?
  attributesJson    Json?    @map("attributes_json")
  rawJson           Json?    @map("raw_json")
  lastImportRunId   String?  @map("last_import_run_id") @db.Uuid

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  listing              ChannelListing        @relation(fields: [listingId, organizationId], references: [id, organizationId], onDelete: Cascade)
  organization         Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  productVariant       ProductVariant?       @relation(fields: [productVariantId, organizationId], references: [id, organizationId], onDelete: Restrict)
  lastImportRun        SourceImportRun?      @relation("ChannelSkuLastImport", fields: [lastImportRunId, organizationId], references: [id, organizationId], onDelete: Restrict)
  orderLineItems       OrderLineItem[]
  orderReturnLineItems OrderReturnLineItem[]
  adActions            AdAction[]

  // Channels — market-data snapshots (Wave C0)
  channelScrapeSnapshots             ChannelScrapeSnapshot[]
  channelListingOptionDailySnapshots ChannelListingOptionDailySnapshot[]

  // Channels — daily fact extensions (Hard rewrite H1)
  channelAdTargetDailySnapshots ChannelAdTargetDailySnapshot[]

  @@unique([listingId, externalOptionId])
  @@unique([id, organizationId], map: "channel_listing_options_id_org_key")
  @@index([organizationId, externalOptionId])
  @@index([externalOptionId])
  @@index([productVariantId])
  @@index([organizationId, productVariantId])
  @@index([lastImportRunId])
  @@map("channel_listing_options")
}
