// core.prisma — Core domain

/// @namespace Core
model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Core
  memberships                     OrganizationMembership[]
  legalEntities                   LegalEntity[]
  channelAccounts                 ChannelAccount[]
  sourceImportRuns                SourceImportRun[]
  orders                          Order[]
  purchaseOrders                  PurchaseOrder[]
  profitLoss                      ProfitLoss[]
  thumbnails                      Thumbnail[]
  thumbnailAnalyses               ThumbnailAnalysis[]
  thumbnailGenerations            ThumbnailGeneration[]
  thumbnailGenerationCandidates   ThumbnailGenerationCandidate[]
  thumbnailGenerationInputImages  ThumbnailGenerationInputImage[]
  thumbnailGenerationEvents       ThumbnailGenerationEvent[]
  thumbnailRegistrationAttempts   ThumbnailRegistrationAttempt[]
  thumbnailTrackings              ThumbnailTracking[]
  thumbnailTrackingDailySnapshots ThumbnailTrackingDailySnapshot[]
  reviews                         Review[]
  alerts                          Alert[]

  // Sourcing & Content
  contentGenerations           ContentGeneration[]
  contentGenerationGroups      ContentGenerationGroup[]
  contentGenerationSources     ContentGenerationSource[]
  contentAssets                ContentAsset[]
  contentGenerationAssetUsages ContentGenerationAssetUsage[]
  contentWorkspaces            ContentWorkspace[]
  contentWorkspaceThumbnailSelections ContentWorkspaceThumbnailSelection[]
  productPreparations          ProductPreparation[]
  detailPageArtifacts          DetailPageArtifact[]
  detailPageRevisions          DetailPageRevision[]

  // Workflow & Agent
  workflowTemplates WorkflowTemplate[]
  activityEvents    ActivityEvent[]

  // Agent OS
  agentInstances            AgentInstance[]
  agentRuntimeStates        AgentRuntimeState[]
  agentTaskSessions         AgentTaskSession[]
  agentRunRequests          AgentRunRequest[]
  agentRuns                 AgentRun[]
  agentRunEvents            AgentRunEvent[]
  agentInstanceToolPolicies AgentInstanceToolPolicy[]
  agentAuthorizationEvents  AgentAuthorizationEvent[]
  agentApprovalRequests     AgentApprovalRequest[]
  agentCostEvents           AgentCostEvent[]
  agentConversations        AgentConversation[]
  agentMessages             AgentMessage[]
  agentToolInvocations      AgentToolInvocation[]
  agentArtifacts            AgentArtifact[]

  // Order domain (Plan A.5)
  orderLineItems       OrderLineItem[]
  orderReturns         OrderReturn[]
  orderReturnLineItems OrderReturnLineItem[]

  // Supplier & Procurement
  suppliers        Supplier[]
  supplierPayments SupplierPayment[]
  supplierProducts SupplierProduct[]
  purchaseOrderItems PurchaseOrderItem[]

  // Warehouse & Inventory Ops
  warehouses        Warehouse[]
  stockTransfers    StockTransfer[]
  stockTransactions StockTransaction[]
  stockAudits       StockAudit[]
  inventorySkus                  InventorySku[]
  inventorySkuMasterProductMaps InventorySkuMasterProductMap[]
  sellpiaStockSnapshots       SellpiaStockSnapshot[]
  sellpiaStockSnapshotItems   SellpiaStockSnapshotItem[]
  sellpiaNewProductCandidates SellpiaNewProductCandidate[]
  sellpiaReceiptUploadBatches SellpiaReceiptUploadBatch[]
  rocketInventoryLedger       RocketInventoryLedger[]

  // Logistics
  shipments       Shipment[]
  shipmentItems   ShipmentItem[]
  unshippedItems  UnshippedItem[]
  pickingLists    PickingList[]
  pickingItems    PickingItem[]
  returnTransfers ReturnTransfer[]

  // Product Extensions
  processingCosts ProcessingCost[]

  // Finance
  settlements   Settlement[]
  manualLedgers ManualLedger[]

  // Operations & Config
  csRecords        CSRecord[]
  categoryMappings CategoryMapping[]

  // Analytics
  salesPlans                 SalesPlan[]
  rocketSupplyDailySnapshots RocketSupplyDailySnapshot[]
  rocketPurchaseOrders       RocketPurchaseOrder[]

  // Ontology
  businessRules  BusinessRule[]
  systemSettings SystemSetting[]

  // Ad Scrape Targets
  scrapeTargets ScrapeTarget[]

  // Ad Execution
  adActions        AdAction[]
  executionWorkers ExecutionWorker[]

  // Action Board
  actionTasks ActionTask[]

  // 3-layer product schema (new)
  masterProducts        MasterProduct[]
  masterProductImages   MasterProductImage[]
  productOptions        ProductOption[]
  channelListings       ChannelListing[]
  channelListingOptions ChannelListingOption[]
  bundleComponents      BundleComponent[]
  inventory             Inventory[]
  channelSkuComponents  ChannelSkuComponent[]

  // Channels — market-data snapshots (Wave C0)
  channelScrapeRuns                  ChannelScrapeRun[]
  channelScrapeSnapshots             ChannelScrapeSnapshot[]
  channelListingDailySnapshots       ChannelListingDailySnapshot[]
  channelListingOptionDailySnapshots ChannelListingOptionDailySnapshot[]

  // Channels — daily fact extensions (Hard rewrite H1)
  channelAdTargetDailySnapshots   ChannelAdTargetDailySnapshot[]
  channelAccountDailyKpiSnapshots ChannelAccountDailyKpiSnapshot[]
  channelReconciliationRuns       ChannelReconciliationRun[]
  channelReconciliationItems      ChannelReconciliationItem[]

  // Additional back-relations for FK rename additions
  gradeHistory GradeHistory[] // Task 8 Step 2 adds organizationId to GradeHistory

  // Sourcing (issue #192)
  sourcingCandidates         SourcingCandidate[]
  candidateImages            CandidateImage[]
  sourcingWorkspaceSnapshots SourcingWorkspaceSnapshot[]

  @@map("organizations")
}

/// @namespace Core
/// @describe human(직원) / agent(AI, agentInstanceId 연결) / system(챗봇). 조직 소속은 OrganizationMembership 이 source of truth.
model User {
  id              String    @id @default(uuid()) @db.Uuid
  email           String    @unique
  name            String
  password        String?
  role            String    @default("member") // global/default role; per-organization role lives on OrganizationMembership.
  type            String    @default("human")
  team            String?
  avatarUrl       String?   @map("avatar_url")
  agentInstanceId String?   @map("agent_instance_id") @db.Uuid
  isActive        Boolean   @default(true) @map("is_active")
  lastLoginAt     DateTime? @map("last_login_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  agentInstance                  AgentInstance?             @relation(fields: [agentInstanceId], references: [id], onDelete: SetNull)
  memberships                    OrganizationMembership[]
  invitedOrganizationMemberships OrganizationMembership[]   @relation("OrganizationMembershipInviter")
  triggeredWorkflowRuns          WorkflowRun[]              @relation("WorkflowRunTriggeredBy")
  triggeredThumbnailGenerations  ThumbnailGeneration[]      @relation("ThumbnailGenerationTriggeredBy")
  thumbnailGenerationEvents      ThumbnailGenerationEvent[] @relation("ThumbnailGenerationEventActor")
  triggeredContentGenerations    ContentGeneration[]        @relation("ContentGenerationTriggeredBy")
  createdContentAssets           ContentAsset[]             @relation("ContentAssetCreatedBy")
  createdContentWorkspaces       ContentWorkspace[]         @relation("ContentWorkspaceCreatedBy")
  createdContentWorkspaceThumbnailSelections ContentWorkspaceThumbnailSelection[] @relation("ContentWorkspaceThumbnailSelectionCreatedBy")
  createdProductPreparations     ProductPreparation[]       @relation("ProductPreparationCreatedBy")
  createdDetailPageArtifacts     DetailPageArtifact[]       @relation("DetailPageArtifactCreatedBy")
  createdDetailPageRevisions     DetailPageRevision[]       @relation("DetailPageRevisionCreatedBy")
  actorAlerts                    Alert[]                    @relation("AlertActor")
  assignedActionTasks            ActionTask[]               @relation("ActionTaskAssignee")

  // Agent OS — actor relations
  requestedAgentRunRequests         AgentRunRequest[]         @relation("AgentRunRequestRequestedBy")
  requestedAgentAuthorizationEvents AgentAuthorizationEvent[] @relation("AgentAuthorizationRequestedBy")
  decidedAgentAuthorizationEvents   AgentAuthorizationEvent[] @relation("AgentAuthorizationDecidedBy")
  requestedAgentApprovalRequests    AgentApprovalRequest[]    @relation("AgentApprovalRequestedBy")
  approverAgentApprovalRequests     AgentApprovalRequest[]    @relation("AgentApprovalApprover")
  decidedAgentApprovalRequests      AgentApprovalRequest[]    @relation("AgentApprovalDecidedBy")
  createdAgentConversations         AgentConversation[]       @relation("AgentConversationCreatedBy")

  // Sourcing (issue #192)
  rejectedSourcingCandidates  SourcingCandidate[] @relation("SourcingCandidateRejectedBy")
  triggeredSourcingCandidates SourcingCandidate[] @relation("SourcingCandidateTriggeredBy")

  @@index([agentInstanceId])
  @@map("users")
}

/// @namespace Core
/// @describe B2B customer/workspace membership. A user may belong to multiple organizations; this row supplies request organization and role.
model OrganizationMembership {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  role           String    @default("member")
  status         String    @default("active")
  invitedById    String?   @map("invited_by_id") @db.Uuid
  joinedAt       DateTime  @default(now()) @map("joined_at") @db.Timestamptz
  lastSelectedAt DateTime? @map("last_selected_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitedBy    User?        @relation("OrganizationMembershipInviter", fields: [invitedById], references: [id], onDelete: SetNull)

  @@unique([organizationId, userId])
  @@index([userId, status])
  @@index([organizationId, role])
  @@index([invitedById])
  @@map("organization_memberships")
}

/// @namespace Core
/// @describe Legal/business entity under an organization. This stores tax, invoice, and settlement identity separately from the SaaS organization boundary.
model LegalEntity {
  id                 String   @id @default(uuid()) @db.Uuid
  organizationId     String   @map("organization_id") @db.Uuid
  name               String
  businessNumber     String?  @map("business_number")
  countryCode        String   @default("KR") @map("country_code")
  representativeName String?  @map("representative_name")
  address            String?
  isPrimary          Boolean  @default(false) @map("is_primary")
  metadata           Json?    @db.JsonB
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, isPrimary])
  @@map("legal_entities")
}

/// @namespace Core
/// @describe Marketplace/store account such as Coupang Wing or Naver SmartStore. Operational channel ownership is distinct from the SaaS organization.
model ChannelAccount {
  id                String   @id @default(uuid()) @db.Uuid
  organizationId    String   @map("organization_id") @db.Uuid
  channel           String
  name              String
  externalAccountId String?  @map("external_account_id")
  sellerId          String?  @map("seller_id")
  vendorId          String?  @map("vendor_id")
  status            String   @default("active")
  isPrimary         Boolean  @default(false) @map("is_primary")
  config            Json?    @db.JsonB
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization       Organization                     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  listings           ChannelListing[]
  listingOptions     ChannelListingOption[]
  sourceImportRuns   SourceImportRun[]
  productPreparations ProductPreparation[]
  orders             Order[]
  orderReturns       OrderReturn[]
  channelScrapeRuns  ChannelScrapeRun[]
  channelAccountDailyKpiSnapshots ChannelAccountDailyKpiSnapshot[]

  @@unique([organizationId, channel, externalAccountId])
  @@unique([id, organizationId], map: "channel_accounts_id_org_key")
  @@index([organizationId, channel])
  @@index([organizationId, isPrimary])
  @@map("channel_accounts")
}

/// @namespace Core
/// @describe Durable provenance and publication fence for Sellpia and channel full-snapshot imports.
model SourceImportRun {
  id                  String    @id @default(uuid()) @db.Uuid
  organizationId      String    @map("organization_id") @db.Uuid
  sourceType          String    @map("source_type")
  channelAccountId    String?   @map("channel_account_id") @db.Uuid
  fileName            String    @map("file_name")
  fileHash            String    @map("file_hash")
  status              String    @default("running")
  rowCount            Int       @default(0) @map("row_count")
  importedAt          DateTime? @map("imported_at") @db.Timestamptz
  createdBy           String?   @map("created_by")
  attemptToken        String    @default(uuid()) @map("attempt_token") @db.Uuid
  publicationSequence BigInt?   @map("publication_sequence") @db.BigInt
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization    Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  channelAccount  ChannelAccount?        @relation(fields: [channelAccountId, organizationId], references: [id, organizationId], onDelete: Restrict)
  inventorySkus   InventorySku[]          @relation("InventorySkuLastImport")
  masterProducts  MasterProduct[]         @relation("MasterProductLastImport")
  channelProducts ChannelListing[]        @relation("ChannelProductLastImport")
  channelSkus     ChannelListingOption[]  @relation("ChannelSkuLastImport")

  @@unique([organizationId, sourceType, channelAccountId, fileHash], map: "source_import_runs_org_source_account_hash_key", where: raw("channel_account_id IS NOT NULL"))
  @@unique([organizationId, sourceType, fileHash], map: "source_import_runs_org_source_hash_null_account_key", where: raw("channel_account_id IS NULL"))
  @@unique([organizationId, sourceType, publicationSequence], map: "source_import_runs_org_source_publication_key", where: raw("publication_sequence IS NOT NULL"))
  @@unique([id, organizationId], map: "source_import_runs_id_org_key")
  @@index([organizationId, sourceType, status, createdAt])
  @@index([channelAccountId])
  @@map("source_import_runs")
}

/// @namespace Core
model CategoryMapping {
  id                  String   @id @default(uuid()) @db.Uuid
  organizationId      String   @map("organization_id") @db.Uuid
  internalCategory    String   @map("internal_category")
  coupangCategoryId   String?  @map("coupang_category_id")
  coupangCategoryName String?  @map("coupang_category_name")
  keywords            String?
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, internalCategory])
  @@map("category_mappings")
}

/// @namespace Core
/// @describe 기획상품 family. 같은 컨셉의 옵션들을 묶는 entity. 운영/광고/전략 단위.
model MasterProduct {
  id             String  @id @default(uuid()) @db.Uuid
  organizationId String  @map("organization_id") @db.Uuid
  code           String  @unique
  legacyCode     String? @map("legacy_code")
  /// Source barcode/EAN. 비어있을 수 있고 (organizationId, barcode) 가
  /// **non-unique** — 한 EAN 이 여러 product family 에 걸칠 수 있는 외부 데이터를
  /// 그대로 보존한다. 실제 옵션/스캐너 단위 unique 는 ProductOption.barcode 가 담당.
  barcode        String?
  name           String
  description    String  @default("")
  category       String?
  brand          String?
  tags           Json    @default("[]")
  optionCounter  Int     @default(0) @map("option_counter")

  // 0.1.8 expand-only physical identity. Legacy family rows keep these null.
  sellpiaProductCode String?   @map("sellpia_product_code")
  sellpiaName        String?   @map("sellpia_name")
  sellpiaBarcode     String?   @map("sellpia_barcode")
  optionName         String?   @map("option_name")
  currentStock       Int?      @map("current_stock")
  purchasePrice      Int?      @map("purchase_price")
  salePrice          Int?      @map("sale_price")
  isActive           Boolean?  @map("is_active")
  rawJson            Json?     @map("raw_json")
  lastImportRunId    String?   @map("last_import_run_id") @db.Uuid

  thumbnailUrl String?              @map("thumbnail_url")
  images       MasterProductImage[]
  imageUrl     String?              @map("image_url")

  abcGrade        String?   @map("abc_grade")
  profitTag       String?   @map("profit_tag")
  adTier          String?   @map("ad_tier")
  adBudgetLimit   Int?      @map("ad_budget_limit")
  healthScore     Int?      @map("health_score")
  healthUpdatedAt DateTime? @map("health_updated_at") @db.Timestamptz

  // Deprecated sourcing columns retained for one expand/contract release.
  // New code writes sourcing history to SourcingCandidate; cleanup drops these
  // only after data_migration_runs confirms the backfill landed everywhere.
  sourceUrl      String?  @map("source_url")
  sourcePlatform String?  @map("source_platform")
  costCny        Decimal? @map("cost_cny") @db.Decimal(12, 2)
  marginRate     Decimal? @map("margin_rate") @db.Decimal(5, 4)
  rawData        Json?    @map("raw_data")
  pipelineStep   String?  @map("pipeline_step")

  processedData     Json?   @map("processed_data")
  draftContent      Json?   @map("draft_content")
  detailPageUrl     String? @map("detail_page_url")
  thumbnailStrategy String  @default("standard") @map("thumbnail_strategy")

  isDeleted       Boolean   @default(false) @map("is_deleted")
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz
  isTemporary     Boolean   @default(false) @map("is_temporary")
  lifecycleState  String    @default("active") @map("lifecycle_state")
  temporaryReason String?   @map("temporary_reason")
  memo            String?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  options      ProductOption[]
  listings     ChannelListing[]

  contentGenerationGroups ContentGenerationGroup[]
  detailPageArtifacts     DetailPageArtifact[]     @relation("DetailPageArtifactTargetMaster")
  contentWorkspaces       ContentWorkspace[]       @relation("ContentWorkspaceTargetMaster")
  productPreparations     ProductPreparation[]
  thumbnailAnalyses       ThumbnailAnalysis[]
  thumbnailGenerations    ThumbnailGeneration[]
  gradeHistory            GradeHistory[]
  processingCosts         ProcessingCost[]
  masterSupplierProducts  MasterSupplierProduct[]
  promotedFromCandidate   SourcingCandidate[]      @relation("PromotedFromCandidate")
  provenanceCandidate     SourcingCandidate?       @relation("SourcingCandidateProvenance")
  lastImportRun           SourceImportRun?          @relation("MasterProductLastImport", fields: [lastImportRunId, organizationId], references: [id, organizationId], onDelete: Restrict)
  inventorySkuMap         InventorySkuMasterProductMap?
  channelSkuComponents    ChannelSkuComponent[]
  supplierProducts        SupplierProduct[]         @relation("SupplierProductMasterProduct")
  purchaseOrderItems      PurchaseOrderItem[]       @relation("PurchaseOrderItemMasterProduct")
  stockTransfers          StockTransfer[]           @relation("StockTransferMasterProduct")
  pickingItems            PickingItem[]             @relation("PickingItemMasterProduct")
  returnTransfers         ReturnTransfer[]          @relation("ReturnTransferMasterProduct")
  sellpiaSnapshotItems    SellpiaStockSnapshotItem[] @relation("SellpiaSnapshotItemMasterProduct")
  rocketInventoryLedger   RocketInventoryLedger[]   @relation("RocketInventoryLedgerMasterProduct")

  @@unique([organizationId, legacyCode], map: "master_products_organization_id_legacy_code_key", where: raw("is_deleted = false AND legacy_code IS NOT NULL"))
  @@unique([organizationId, sellpiaProductCode], map: "master_products_org_sellpia_product_code_key", where: raw("sellpia_product_code IS NOT NULL"))
  @@unique([id, organizationId], map: "master_products_id_org_key")
  @@index([organizationId])
  @@index([organizationId, isDeleted])
  @@index([organizationId, isDeleted, isTemporary])
  @@index([organizationId, legacyCode])
  @@index([organizationId, barcode])
  @@index([lastImportRunId])
  @@index([abcGrade])
  @@index([pipelineStep])
  @@index([category])
  @@index([brand])
  @@map("master_products")
}

/// @namespace Core
/// @describe MasterProduct.code allocator. Prisma-owned replacement for the former PostgreSQL sequence.
model MasterCodeCounter {
  key       String   @id
  value     Int      @default(0)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("master_code_counters")
}

/// @namespace Core
/// @describe MasterProduct 이미지 갤러리. Source of truth 이며 MasterProduct.imageUrl 은 대표 이미지 캐시로만 동기화된다.
model MasterProductImage {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @map("organization_id") @db.Uuid
  masterId       String @map("master_id") @db.Uuid

  url        String
  storageKey String? @map("storage_key")
  role       String  @default("product")
  label      String?
  sortOrder  Int     @default(0) @map("sort_order")
  source     String  @default("upload")

  mimeType String? @map("mime_type")
  width    Int?
  height   Int?
  fileSize Int?    @map("file_size")

  isPrimary Boolean   @default(false) @map("is_primary")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization              Organization                    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  master                    MasterProduct                   @relation(fields: [masterId], references: [id], onDelete: Cascade)
  thumbnailGenerationInputs ThumbnailGenerationInputImage[]

  @@index([organizationId])
  @@index([masterId])
  @@index([organizationId, masterId])
  @@index([organizationId, role])
  @@index([masterId, role, sortOrder])
  @@index([masterId, isPrimary])
  @@map("master_product_images")
}

/// @namespace Core
/// @describe 물리 SKU. 바코드 1:1. 재고/매입/창고 단위. isBundle 이면 구성품 기반 계산.
model ProductOption {
  id             String @id @default(uuid()) @db.Uuid
  masterId       String @map("master_id") @db.Uuid
  organizationId String @map("organization_id") @db.Uuid

  sku        String  @unique
  barcode    String?
  legacyCode String? @map("legacy_code")
  optionName String? @map("option_name")
  sortOrder  Int     @default(0) @map("sort_order")

  costPrice      Int?     @map("cost_price")
  sellPrice      Int?     @map("sell_price")
  commissionRate Decimal? @map("commission_rate") @db.Decimal(5, 4)
  shippingCost   Int?     @map("shipping_cost")
  otherCost      Int?     @default(0) @map("other_cost")

  isBundle       Boolean @default(false) @map("is_bundle")
  availableStock Int?    @map("available_stock")

  isDeleted       Boolean   @default(false) @map("is_deleted")
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz
  isTemporary     Boolean   @default(false) @map("is_temporary")
  temporaryReason String?   @map("temporary_reason")
  isActive        Boolean   @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  master       MasterProduct @relation(fields: [masterId], references: [id], onDelete: Restrict)
  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inventory    Inventory?

  components  BundleComponent[] @relation("BundleOption")
  containedIn BundleComponent[] @relation("ComponentOption")

  channelListingOptions ChannelListingOption[]

  stockTransactions  StockTransaction[]
  stockTransfers     StockTransfer[]
  pickingItems       PickingItem[]
  returnTransfers    ReturnTransfer[]
  sellpiaStockSnapshotItems   SellpiaStockSnapshotItem[]
  sellpiaNewProductCandidates SellpiaNewProductCandidate[]
  rocketInventoryLedger       RocketInventoryLedger[]
  purchaseOrderItems PurchaseOrderItem[]
  supplierProducts   SupplierProduct[]
  shipments          Shipment[]
  unshippedItems     UnshippedItem[]

  // Order domain (Plan A.5)
  orderLineItems       OrderLineItem[]
  orderReturnLineItems OrderReturnLineItem[]

  // Channels — market-data snapshots (Wave C0)
  channelScrapeSnapshots             ChannelScrapeSnapshot[]
  channelListingOptionDailySnapshots ChannelListingOptionDailySnapshot[]

  // Channels — daily fact extensions (Hard rewrite H1)
  channelAdTargetDailySnapshots ChannelAdTargetDailySnapshot[]

  @@unique([masterId], map: "product_options_master_null_option", where: raw("option_name IS NULL"))
  @@unique([masterId, optionName], map: "product_options_master_id_option_name_key", where: raw("is_deleted = false AND option_name IS NOT NULL"))
  @@unique([organizationId, barcode], map: "product_options_organization_id_barcode_key", where: raw("is_deleted = false AND barcode IS NOT NULL"))
  @@unique([organizationId, legacyCode], map: "product_options_organization_id_legacy_code_key", where: raw("is_deleted = false AND legacy_code IS NOT NULL"))
  @@index([organizationId])
  @@index([masterId])
  @@index([masterId, isDeleted])
  @@index([organizationId, isTemporary])
  @@index([organizationId, legacyCode])
  @@index([isBundle])
  @@map("product_options")
}

/// @namespace Core
/// @describe 채널에 올라간 판매 등록상품. 쿠팡 등록상품ID, 네이버 상품번호 등.
model ChannelListing {
  id               String  @id @default(uuid()) @db.Uuid
  masterId         String? @map("master_id") @db.Uuid
  organizationId   String  @map("organization_id") @db.Uuid
  channelAccountId String? @map("channel_account_id") @db.Uuid
  sourceCandidateId String? @map("source_candidate_id") @db.Uuid

  channel    String
  externalId String @map("external_id")

  channelName     String? @map("channel_name")
  channelPrice    Int?    @map("channel_price")
  displayName     String? @map("display_name")
  category        String?
  brand           String?
  manufacturer    String?
  rawJson         Json?   @map("raw_json")
  lastImportRunId String? @map("last_import_run_id") @db.Uuid

  status         String?
  exposureStatus String? @map("exposure_status")

  deliveryChargeType String? @map("delivery_charge_type")
  freeShipOverAmount Int?    @map("free_ship_over_amount")
  returnCharge       Int?    @map("return_charge")
  deliveryInfo       Json?   @map("delivery_info")

  // KidItem-authored listing operations; channel collection never overwrites these.
  abcGrade        String?   @map("abc_grade")
  profitTag       String?   @map("profit_tag")
  adTier          String?   @map("ad_tier")
  adBudgetLimit   Int?      @map("ad_budget_limit")
  healthScore     Int?      @map("health_score")
  healthUpdatedAt DateTime? @map("health_updated_at") @db.Timestamptz
  isActive        Boolean   @default(true) @map("is_active")

  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  master         MasterProduct?         @relation(fields: [masterId], references: [id], onDelete: Restrict)
  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  channelAccount ChannelAccount?        @relation(fields: [channelAccountId, organizationId], references: [id, organizationId], onDelete: Restrict)
  sourceCandidate SourcingCandidate?    @relation(fields: [sourceCandidateId, organizationId], references: [id, organizationId], onDelete: Restrict)
  lastImportRun  SourceImportRun?       @relation("ChannelProductLastImport", fields: [lastImportRunId, organizationId], references: [id, organizationId], onDelete: Restrict)
  options        ChannelListingOption[]
  contentWorkspaces ContentWorkspace[]
  productPreparations ProductPreparation[]

  reviews            Review[]
  thumbnails         Thumbnail[]
  thumbnailTrackings ThumbnailTracking[]
  adActions          AdAction[]
  orders             Order[]
  unshippedItems     UnshippedItem[]
  shipments          Shipment[]
  csRecords          CSRecord[]
  profitLoss         ProfitLoss[]
  gradeHistory       GradeHistory[]

  // Channels — market-data snapshots (Wave C0)
  channelScrapeSnapshots             ChannelScrapeSnapshot[]
  channelListingDailySnapshots       ChannelListingDailySnapshot[]
  channelListingOptionDailySnapshots ChannelListingOptionDailySnapshot[]

  // Channels — daily fact extensions (Hard rewrite H1)
  channelAdTargetDailySnapshots ChannelAdTargetDailySnapshot[]

  @@unique([organizationId, channelAccountId, externalId], map: "channel_listings_org_account_external_id_key", where: raw("is_deleted = false AND channel_account_id IS NOT NULL"))
  @@unique([organizationId, channelAccountId, externalId], map: "channel_listings_org_account_external_all_key", where: raw("channel_account_id IS NOT NULL"))
  @@unique([organizationId, sourceCandidateId, channelAccountId], map: "channel_listings_org_source_account_active_key", where: raw("source_candidate_id IS NOT NULL AND channel_account_id IS NOT NULL AND is_active = true AND is_deleted = false"))
  @@unique([id, organizationId], map: "channel_listings_id_org_key")
  @@index([organizationId])
  @@index([masterId])
  @@index([channelAccountId])
  @@index([sourceCandidateId])
  @@index([lastImportRunId])
  @@index([channel, isDeleted])
  @@index([masterId, isDeleted])
  @@index([organizationId, channelAccountId, isDeleted])
  @@index([organizationId, channel, isDeleted])
  @@index([organizationId, masterId, isDeleted])
  @@index([organizationId, isDeleted, updatedAt, id])
  @@index([channel])
  @@map("channel_listings")
}

/// @namespace Core
/// @describe 채널 listing 내 옵션 externalOptionId 와 내부 ProductOption 매핑.
model ChannelListingOption {
  id             String  @id @default(uuid()) @db.Uuid
  listingId      String  @map("listing_id") @db.Uuid
  optionId       String? @map("option_id") @db.Uuid
  organizationId String  @map("organization_id") @db.Uuid
  channelAccountId String? @map("channel_account_id") @db.Uuid

  externalOptionId String  @map("external_option_id") @db.VarChar(60)
  itemName         String? @map("item_name")
  salePrice        Int?    @map("sale_price")
  costPriceOverride Int?    @map("cost_price_override")
  commissionRate   Decimal? @map("commission_rate") @db.Decimal(5, 4)
  shippingCost     Int?     @map("shipping_cost")
  otherCost        Int?     @map("other_cost")
  sellerSku        String?  @map("seller_sku")
  barcode          String?
  modelNumber      String?  @map("model_number")
  status           String?
  mappingStatus    String   @default("unmatched") @map("mapping_status")
  attributesJson   Json?    @map("attributes_json")
  rawJson          Json?    @map("raw_json")
  lastImportRunId  String?  @map("last_import_run_id") @db.Uuid

  isActive    Boolean @default(true) @map("is_active")
  isUnmatched Boolean @default(false) @map("is_unmatched")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  listing        ChannelListing  @relation(fields: [listingId, organizationId], references: [id, organizationId], onDelete: Cascade)
  option         ProductOption?  @relation(fields: [optionId], references: [id], onDelete: SetNull)
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  channelAccount ChannelAccount? @relation(fields: [channelAccountId, organizationId], references: [id, organizationId], onDelete: Restrict)
  lastImportRun  SourceImportRun? @relation("ChannelSkuLastImport", fields: [lastImportRunId, organizationId], references: [id, organizationId], onDelete: Restrict)
  components     ChannelSkuComponent[]
  orderLineItems OrderLineItem[]
  orderReturnLineItems OrderReturnLineItem[]
  adActions      AdAction[]

  // Channels — market-data snapshots (Wave C0)
  channelScrapeSnapshots             ChannelScrapeSnapshot[]
  channelListingOptionDailySnapshots ChannelListingOptionDailySnapshot[]

  // Channels — daily fact extensions (Hard rewrite H1)
  channelAdTargetDailySnapshots ChannelAdTargetDailySnapshot[]

  @@unique([listingId, externalOptionId])
  @@unique([id, organizationId], map: "channel_listing_options_id_org_key")
  @@unique([organizationId, channelAccountId, externalOptionId], map: "channel_listing_options_org_account_external_option_key", where: raw("channel_account_id IS NOT NULL"))
  @@index([organizationId, externalOptionId])
  @@index([optionId])
  @@index([externalOptionId])
  @@index([organizationId, isUnmatched])
  @@index([channelAccountId])
  @@index([organizationId, channelAccountId, mappingStatus])
  @@index([lastImportRunId])
  @@map("channel_listing_options")
}

/// @namespace Core
/// @describe 세트 옵션의 구성품 관계. bundleOption(isBundle=true) ↔ componentOption. Cross-master 허용, cross-organization 금지.
model BundleComponent {
  id                String @id @default(uuid()) @db.Uuid
  bundleOptionId    String @map("bundle_option_id") @db.Uuid
  componentOptionId String @map("component_option_id") @db.Uuid
  organizationId    String @map("organization_id") @db.Uuid
  qty               Int    @default(1)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  bundleOption    ProductOption @relation("BundleOption", fields: [bundleOptionId], references: [id], onDelete: Cascade)
  componentOption ProductOption @relation("ComponentOption", fields: [componentOptionId], references: [id], onDelete: Restrict)
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([bundleOptionId, componentOptionId])
  @@index([componentOptionId])
  @@index([organizationId])
  @@map("bundle_components")
}
