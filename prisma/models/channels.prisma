// channels.prisma — Channel market-data foundation (Wave C0)
//
// Provides a channel-generic schema layer for raw scrape capture and daily
// listing/option state snapshots. `channel = "coupang"` is row data, not a
// table name — provider-specific column names live only in adapter DTOs and
// `rawJson`/`metaJson`. See `.omx/plans/channel-market-data-daily-snapshots-plan.md`.
//
// C0 scope: schema foundation only. No service/runtime change in this PR.
// Subsequent waves (C1 product identity sync, C2 raw scrape dual-write,
// C3 daily upserts, C4 strategy reads) wire ingestion paths.

/// @namespace Channels
/// @describe 채널별 상품/광고/트래픽 스크래핑 실행 단위. 원본 row 는 ChannelScrapeSnapshot 에 저장.
model ChannelScrapeRun {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @map("organization_id") @db.Uuid

  channel      String
  source       String
  pageType     String    @map("page_type")
  businessDate DateTime? @map("business_date") @db.Date
  periodStart  DateTime? @map("period_start") @db.Date
  periodEnd    DateTime? @map("period_end") @db.Date

  status        String  @default("running")
  targetUrl     String? @map("target_url")
  period        String?
  parserVersion String? @map("parser_version")

  rowCount       Int @default(0) @map("row_count")
  matchedCount   Int @default(0) @map("matched_count")
  unmatchedCount Int @default(0) @map("unmatched_count")
  errorCount     Int @default(0) @map("error_count")

  startedAt  DateTime  @default(now()) @map("started_at") @db.Timestamptz
  finishedAt DateTime? @map("finished_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  metaJson  Json? @map("meta_json")
  errorJson Json? @map("error_json")

  organization Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  snapshots    ChannelScrapeSnapshot[]

  @@index([organizationId, channel, source, businessDate])
  @@index([organizationId, status, startedAt])
  @@index([startedAt])
  @@map("channel_scrape_runs")
}

/// @namespace Channels
/// @describe 채널 스크래퍼/API 가 본 원본 row. 매칭 실패/파서 변경 대비 rawJson 을 보존.
model ChannelScrapeSnapshot {
  id             String  @id @default(uuid()) @db.Uuid
  organizationId String  @map("organization_id") @db.Uuid
  scrapeRunId    String? @map("scrape_run_id") @db.Uuid

  channel      String
  source       String
  pageType     String    @map("page_type")
  businessDate DateTime? @map("business_date") @db.Date
  observedAt   DateTime  @default(now()) @map("observed_at") @db.Timestamptz

  externalId       String? @map("external_id")
  externalOptionId String? @map("external_option_id")
  listingId        String? @map("listing_id") @db.Uuid
  listingOptionId  String? @map("listing_option_id") @db.Uuid
  optionId         String? @map("option_id") @db.Uuid

  matchStatus String  @default("unmatched") @map("match_status")
  matchReason String? @map("match_reason")
  rowHash     String? @map("row_hash")

  rawJson        Json  @map("raw_json")
  normalizedJson Json? @map("normalized_json")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  organization  Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  scrapeRun     ChannelScrapeRun?     @relation(fields: [scrapeRunId], references: [id], onDelete: SetNull)
  listing       ChannelListing?       @relation(fields: [listingId], references: [id], onDelete: SetNull)
  listingOption ChannelListingOption? @relation(fields: [listingOptionId], references: [id], onDelete: SetNull)
  option        ProductOption?        @relation(fields: [optionId], references: [id], onDelete: SetNull)

  listingDailySnapshots  ChannelListingDailySnapshot[]       @relation("ListingDailyRawSnapshot")
  optionDailySnapshots   ChannelListingOptionDailySnapshot[] @relation("OptionDailyRawSnapshot")
  adTargetDailySnapshots ChannelAdTargetDailySnapshot[]      @relation("AdTargetDailyRawSnapshot")
  accountKpiSnapshots    ChannelAccountDailyKpiSnapshot[]    @relation("AccountKpiRawSnapshot")

  @@index([organizationId, channel, source, businessDate])
  @@index([organizationId, channel, pageType, businessDate])
  @@index([scrapeRunId])
  @@index([listingId, businessDate])
  @@index([listingOptionId, businessDate])
  @@index([optionId, businessDate])
  @@index([organizationId, channel, externalId])
  @@index([organizationId, channel, externalOptionId])
  @@index([organizationId, matchStatus])
  @@index([observedAt])
  @@map("channel_scrape_snapshots")
}

/// @namespace Channels
/// @describe 채널 listing 의 일별 정규화 상태. 반복 scrape 는 businessDate row 를 upsert.
model ChannelListingDailySnapshot {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @map("organization_id") @db.Uuid
  listingId      String @map("listing_id") @db.Uuid

  channel      String
  externalId   String   @map("external_id")
  businessDate DateTime @map("business_date") @db.Date

  productName    String? @map("product_name")
  status         String?
  exposureStatus String? @map("exposure_status")
  saleStatus     String? @map("sale_status")
  channelPrice   Int?    @map("channel_price")

  reviewCount Int?     @map("review_count")
  avgRating   Decimal? @map("avg_rating") @db.Decimal(4, 2)

  isOfferWinner  Boolean? @map("is_offer_winner")
  myPrice        Int?     @map("my_price")
  winnerPrice    Int?     @map("winner_price")
  winnerGapPrice Int?     @map("winner_gap_price")

  productRank  Int? @map("product_rank")
  categoryRank Int? @map("category_rank")

  // Ad additive metrics (Hard rewrite H1) — sums only, ratios recompute in reads.
  adSpend              Int @default(0) @map("ad_spend")
  adRevenue            Int @default(0) @map("ad_revenue")
  adImpressions        Int @default(0) @map("ad_impressions")
  adClicks             Int @default(0) @map("ad_clicks")
  adConversions        Int @default(0) @map("ad_conversions")
  adOrders             Int @default(0) @map("ad_orders")
  adDirectOrders1d     Int @default(0) @map("ad_direct_orders_1d")
  adIndirectOrders1d   Int @default(0) @map("ad_indirect_orders_1d")
  adDirectQty1d        Int @default(0) @map("ad_direct_qty_1d")
  adIndirectQty1d      Int @default(0) @map("ad_indirect_qty_1d")
  adDirectRevenue1d    Int @default(0) @map("ad_direct_revenue_1d")
  adIndirectRevenue1d  Int @default(0) @map("ad_indirect_revenue_1d")
  adTotalOrders14d     Int @default(0) @map("ad_total_orders_14d")
  adDirectOrders14d    Int @default(0) @map("ad_direct_orders_14d")
  adIndirectOrders14d  Int @default(0) @map("ad_indirect_orders_14d")
  adTotalQty14d        Int @default(0) @map("ad_total_qty_14d")
  adDirectQty14d       Int @default(0) @map("ad_direct_qty_14d")
  adIndirectQty14d     Int @default(0) @map("ad_indirect_qty_14d")
  adTotalRevenue14d    Int @default(0) @map("ad_total_revenue_14d")
  adDirectRevenue14d   Int @default(0) @map("ad_direct_revenue_14d")
  adIndirectRevenue14d Int @default(0) @map("ad_indirect_revenue_14d")

  // Traffic additive metrics (Hard rewrite H1)
  trafficVisitors Int @default(0) @map("traffic_visitors")
  trafficViews    Int @default(0) @map("traffic_views")
  trafficCartAdds Int @default(0) @map("traffic_cart_adds")
  trafficOrders   Int @default(0) @map("traffic_orders")
  trafficSalesQty Int @default(0) @map("traffic_sales_qty")
  trafficRevenue  Int @default(0) @map("traffic_revenue")

  sampleCount     Int      @default(1) @map("sample_count")
  firstObservedAt DateTime @default(now()) @map("first_observed_at") @db.Timestamptz
  lastObservedAt  DateTime @default(now()) @map("last_observed_at") @db.Timestamptz
  rawSnapshotId   String?  @map("raw_snapshot_id") @db.Uuid

  metaJson  Json?    @map("meta_json")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  listing      ChannelListing         @relation(fields: [listingId], references: [id], onDelete: Cascade)
  rawSnapshot  ChannelScrapeSnapshot? @relation("ListingDailyRawSnapshot", fields: [rawSnapshotId], references: [id], onDelete: SetNull)

  @@unique([organizationId, listingId, businessDate])
  @@index([organizationId, channel, externalId, businessDate])
  @@index([rawSnapshotId])
  @@index([organizationId, businessDate])
  @@index([listingId, businessDate])
  @@index([organizationId, channel, businessDate])
  @@index([organizationId, isOfferWinner])
  @@map("channel_listing_daily_snapshots")
}

/// @namespace Channels
/// @describe 채널 listing option/vendor item 의 일별 정규화 상태.
model ChannelListingOptionDailySnapshot {
  id              String  @id @default(uuid()) @db.Uuid
  organizationId  String  @map("organization_id") @db.Uuid
  listingId       String  @map("listing_id") @db.Uuid
  listingOptionId String  @map("listing_option_id") @db.Uuid
  optionId        String? @map("option_id") @db.Uuid

  channel          String
  externalId       String   @map("external_id")
  externalOptionId String   @map("external_option_id")
  businessDate     DateTime @map("business_date") @db.Date

  optionName String?  @map("option_name")
  salePrice  Int?     @map("sale_price")
  stockQty   Int?     @map("stock_qty")
  saleStatus String?  @map("sale_status")
  isActive   Boolean? @map("is_active")

  isOfferWinner  Boolean? @map("is_offer_winner")
  myPrice        Int?     @map("my_price")
  winnerPrice    Int?     @map("winner_price")
  winnerGapPrice Int?     @map("winner_gap_price")

  sampleCount     Int      @default(1) @map("sample_count")
  firstObservedAt DateTime @default(now()) @map("first_observed_at") @db.Timestamptz
  lastObservedAt  DateTime @default(now()) @map("last_observed_at") @db.Timestamptz
  rawSnapshotId   String?  @map("raw_snapshot_id") @db.Uuid

  metaJson  Json?    @map("meta_json")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization  Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  listing       ChannelListing         @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingOption ChannelListingOption   @relation(fields: [listingOptionId], references: [id], onDelete: Cascade)
  option        ProductOption?         @relation(fields: [optionId], references: [id], onDelete: SetNull)
  rawSnapshot   ChannelScrapeSnapshot? @relation("OptionDailyRawSnapshot", fields: [rawSnapshotId], references: [id], onDelete: SetNull)

  @@unique([organizationId, listingOptionId, businessDate])
  @@index([organizationId, channel, externalId, externalOptionId, businessDate])
  @@index([rawSnapshotId])
  @@index([organizationId, businessDate])
  @@index([listingId, businessDate])
  @@index([listingOptionId, businessDate])
  @@index([optionId, businessDate])
  @@index([organizationId, externalOptionId])
  @@map("channel_listing_option_daily_snapshots")
}

/// @namespace Channels
/// @describe 채널 광고 타겟(캠페인/키워드/상품)의 일별 정규화 fact. 기간 view 는 SUM 으로 derive.
model ChannelAdTargetDailySnapshot {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  channel        String
  businessDate   DateTime @map("business_date") @db.Date

  listingId        String? @map("listing_id") @db.Uuid
  listingOptionId  String? @map("listing_option_id") @db.Uuid
  optionId         String? @map("option_id") @db.Uuid
  externalId       String? @map("external_id")
  externalOptionId String? @map("external_option_id")

  targetType   String  @map("target_type") // 'campaign' | 'keyword' | 'product'
  targetKey    String  @map("target_key") // deterministic canonical key, NOT NULL
  campaignId   String? @map("campaign_id")
  campaignName String? @map("campaign_name")
  adGroup      String? @map("ad_group")
  keyword      String?
  placement    String?
  status       String?
  onOff        String? @map("on_off")
  currentBid   Int?    @map("current_bid")
  dailyBudget  Int?    @map("daily_budget")

  spend       Int @default(0)
  revenue     Int @default(0)
  impressions Int @default(0)
  clicks      Int @default(0)
  conversions Int @default(0)
  orders      Int @default(0)
  adSpend     Int @default(0) @map("ad_spend")
  adRevenue   Int @default(0) @map("ad_revenue")

  rawSnapshotId String? @map("raw_snapshot_id") @db.Uuid
  metaJson      Json?   @map("meta_json")

  sampleCount     Int      @default(1) @map("sample_count")
  firstObservedAt DateTime @default(now()) @map("first_observed_at") @db.Timestamptz
  lastObservedAt  DateTime @default(now()) @map("last_observed_at") @db.Timestamptz
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization  Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  listing       ChannelListing?        @relation(fields: [listingId], references: [id], onDelete: SetNull)
  listingOption ChannelListingOption?  @relation(fields: [listingOptionId], references: [id], onDelete: SetNull)
  option        ProductOption?         @relation(fields: [optionId], references: [id], onDelete: SetNull)
  rawSnapshot   ChannelScrapeSnapshot? @relation("AdTargetDailyRawSnapshot", fields: [rawSnapshotId], references: [id], onDelete: SetNull)

  adActions AdAction[]

  @@unique([organizationId, channel, businessDate, targetType, targetKey])
  @@index([organizationId, channel, businessDate])
  @@index([listingId, businessDate])
  @@index([listingOptionId, businessDate])
  @@index([organizationId, targetType, businessDate])
  @@index([rawSnapshotId])
  @@index([optionId, businessDate])
  @@map("channel_ad_target_daily_snapshots")
}

/// @namespace Channels
/// @describe 채널 계정/스토어 단위 KPI 일별 정규화 fact (listing 에 귀속되지 않는 dashboard KPI 용).
model ChannelAccountDailyKpiSnapshot {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  channel        String
  source         String // 'wing' | 'advertising' | ...
  kpiType        String    @map("kpi_type") // e.g. 'wing_dashboard' | 'wing_itemwinner_kpi'
  businessDate   DateTime  @map("business_date") @db.Date
  periodStart    DateTime? @map("period_start") @db.Date
  periodEnd      DateTime? @map("period_end") @db.Date

  normalizedJson Json    @map("normalized_json")
  rawJson        Json?   @map("raw_json")
  rawSnapshotId  String? @map("raw_snapshot_id") @db.Uuid

  sampleCount     Int      @default(1) @map("sample_count")
  firstObservedAt DateTime @default(now()) @map("first_observed_at") @db.Timestamptz
  lastObservedAt  DateTime @default(now()) @map("last_observed_at") @db.Timestamptz
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  rawSnapshot  ChannelScrapeSnapshot? @relation("AccountKpiRawSnapshot", fields: [rawSnapshotId], references: [id], onDelete: SetNull)

  @@unique([organizationId, channel, source, businessDate, kpiType])
  @@index([organizationId, channel, businessDate])
  @@index([rawSnapshotId])
  @@map("channel_account_daily_kpi_snapshots")
}

/// @namespace Channels
/// @describe 쿠팡 로켓(공급사 발주) 일별 매출 fact. po-web 발주리스트의 발주금액(공급가)을 입고예정일(KST) 기준으로 집계한 값으로, 윙 매출과 분리된 로켓 매출 소스.
model RocketSupplyDailySnapshot {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  businessDate   DateTime @map("business_date") @db.Date

  revenueKrw Int @default(0) @map("revenue_krw") // 발주금액 합계 (KRW)
  poCount    Int @default(0) @map("po_count") // 발주서 수
  itemQty    Int @default(0) @map("item_qty") // 발주 총 수량

  source  String @default("rocket")
  rawJson Json?  @map("raw_json")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, businessDate])
  @@index([organizationId, businessDate])
  @@map("rocket_supply_daily_snapshots")
}

/// @namespace Channels
/// @describe 쿠팡 로켓 발주 단건(per-PO) 상세 — 매출분석 드릴다운(일자→발주→품목)용. items 는 발주서 품목(SKU) 라인 JSON(표시 전용).
model RocketPurchaseOrder {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  poSeq          Int      @map("po_seq") // purchaseOrderSeq
  businessDate   DateTime @map("business_date") @db.Date // 입고예정일(KST)
  orderedAt      DateTime @map("ordered_at") @db.Timestamptz

  status       String? // 거래처확인요청 등
  vendorName   String? @map("vendor_name")
  centerName   String? @map("center_name")
  firstSkuName String? @map("first_sku_name")
  skuCount     Int     @default(0) @map("sku_count")
  orderQty     Int     @default(0) @map("order_qty")
  orderAmount  Int     @default(0) @map("order_amount") // 발주금액 KRW

  items Json? // [{ name, qty, unitPrice, amount, productNo, barcode }] (표시 전용)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, poSeq])
  @@index([organizationId, businessDate])
  @@map("rocket_purchase_orders")
}

/// @namespace Channels
/// @describe 채널-KidItem 상품 매칭 스캔 실행 이력. 실제 연결 source of truth 는 ChannelListing / ChannelListingOption.
model ChannelReconciliationRun {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @map("organization_id") @db.Uuid

  channel String // 'coupang'
  source  String // 'wing_inventory' | 'seller_products' | 'manual'

  status String @default("running") // running | completed | failed

  totalCount         Int @default(0) @map("total_count")
  alreadyLinkedCount Int @default(0) @map("already_linked_count")
  autoLinkedCount    Int @default(0) @map("auto_linked_count")
  needsReviewCount   Int @default(0) @map("needs_review_count")
  conflictCount      Int @default(0) @map("conflict_count")
  ignoredCount       Int @default(0) @map("ignored_count")
  errorCount         Int @default(0) @map("error_count")

  startedAt  DateTime  @default(now()) @map("started_at") @db.Timestamptz
  finishedAt DateTime? @map("finished_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  metaJson  Json? @map("meta_json")
  errorJson Json? @map("error_json")

  organization Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items        ChannelReconciliationItem[]

  @@index([organizationId, channel, source, startedAt])
  @@index([organizationId, status, startedAt])
  @@index([startedAt])
  @@map("channel_reconciliation_runs")
}

/// @namespace Channels
/// @describe 사용자가 처리하는 채널-내부 상품 매칭 queue. MasterProduct 자동 생성 없이 기존 ProductOption/ChannelListing 연결만 추적.
model ChannelReconciliationItem {
  id             String  @id @default(uuid()) @db.Uuid
  organizationId String  @map("organization_id") @db.Uuid
  lastSeenRunId  String? @map("last_seen_run_id") @db.Uuid

  channel  String // 'coupang'
  source   String // 'wing_inventory' | 'seller_products'
  itemType String @map("item_type") // channel_listing | channel_option | kiditem_master | kiditem_option
  itemKey  String @map("item_key") // listing:<externalId>, option:<externalId>:<externalOptionId>

  status String @default("needs_review") // linked | needs_review | conflict | ignored | stale

  externalId       String? @map("external_id")
  externalOptionId String? @map("external_option_id")
  legacyCode       String? @map("legacy_code")

  channelProductName String? @map("channel_product_name")
  channelOptionName  String? @map("channel_option_name")
  channelImageUrl    String? @map("channel_image_url")
  channelUrl         String? @map("channel_url")
  channelStatus      String? @map("channel_status")

  linkedListingId       String? @map("linked_listing_id") @db.Uuid
  linkedListingOptionId String? @map("linked_listing_option_id") @db.Uuid
  linkedMasterProductId String? @map("linked_master_product_id") @db.Uuid
  linkedProductOptionId String? @map("linked_product_option_id") @db.Uuid

  matchReason      String? @map("match_reason") // external_id | legacy_code_exact | manual | none | conflict
  resolutionSource String? @map("resolution_source") // existing_external_id | auto_legacy_code | manual | ignored
  confidence       Int?

  rawJson        Json? @map("raw_json")
  normalizedJson Json? @map("normalized_json")
  conflictJson   Json? @map("conflict_json")

  resolvedAt       DateTime? @map("resolved_at") @db.Timestamptz
  resolvedByUserId String?   @map("resolved_by_user_id") @db.Uuid
  ignoredReason    String?   @map("ignored_reason")

  firstObservedAt DateTime @default(now()) @map("first_observed_at") @db.Timestamptz
  lastObservedAt  DateTime @default(now()) @map("last_observed_at") @db.Timestamptz
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lastSeenRun  ChannelReconciliationRun? @relation(fields: [lastSeenRunId], references: [id], onDelete: SetNull)

  @@unique([organizationId, channel, source, itemKey])
  @@index([organizationId, channel, status])
  @@index([organizationId, channel, itemType, status])
  @@index([organizationId, channel, externalId], map: "channel_reconciliation_items_org_channel_ext_id_idx")
  @@index([organizationId, channel, externalOptionId], map: "channel_reconciliation_items_org_channel_ext_option_idx")
  @@index([organizationId, legacyCode])
  @@index([lastSeenRunId])
  @@index([lastObservedAt])
  @@map("channel_reconciliation_items")
}
