// inventory.prisma — Record-only inventory operations.
// Current stock belongs exclusively to MasterProduct and is replaced by a
// completed Sellpia full-snapshot import.

/// @namespace Inventory
/// @describe Organization-scoped Sellpia inventory trust state, source binding, generation fence, and active collection lease.
model SellpiaInventoryState {
  organizationId           String    @id @map("organization_id") @db.Uuid
  sourceOrigin             String    @default("https://kiditem.sellpia.com") @map("source_origin")
  sourceAccountKey         String?   @map("source_account_key")
  lastVerifiedAt           DateTime? @map("last_verified_at") @db.Timestamptz
  lastCompletedImportRunId String?   @map("last_completed_import_run_id") @db.Uuid
  refreshRequestedAt       DateTime? @map("refresh_requested_at") @db.Timestamptz
  refreshReason            String?   @map("refresh_reason")
  syncNotBefore            DateTime? @map("sync_not_before") @db.Timestamptz
  activeSyncToken          String?   @map("active_sync_token") @db.Uuid
  activeSyncOwnerUserId    String?   @map("active_sync_owner_user_id") @db.Uuid
  activeSyncStartedAt      DateTime? @map("active_sync_started_at") @db.Timestamptz
  activeSyncLeaseExpiresAt DateTime? @map("active_sync_lease_expires_at") @db.Timestamptz
  requestedGeneration      BigInt    @default(1) @map("requested_generation") @db.BigInt
  activeGeneration         BigInt?   @map("active_generation") @db.BigInt
  verifiedGeneration       BigInt    @default(0) @map("verified_generation") @db.BigInt
  failedGeneration         BigInt?   @map("failed_generation") @db.BigInt
  lastAttemptAt            DateTime? @map("last_attempt_at") @db.Timestamptz
  lastAttemptStatus        String?   @map("last_attempt_status")
  lastErrorCode            String?   @map("last_error_code")
  lastErrorMessage         String?   @map("last_error_message")
  freshnessFence           String    @default(uuid()) @map("freshness_fence") @db.Uuid
  createdAt                DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization           Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lastCompletedImportRun SourceImportRun? @relation("SellpiaInventoryStateLastCompletedRun", fields: [lastCompletedImportRunId, organizationId], references: [id, organizationId], onDelete: Restrict)
  activeSyncOwner        User?            @relation("SellpiaInventoryStateActiveSyncOwner", fields: [activeSyncOwnerUserId], references: [id], onDelete: SetNull)

  @@index([lastCompletedImportRunId])
  @@index([activeSyncOwnerUserId])
  @@map("sellpia_inventory_states")
}

/// @namespace Inventory
/// @describe Organization-scoped idempotency fence for browser Sellpia order transmission and its post-submit inventory generation.
model SellpiaOrderTransmissionIntent {
  id                  String    @id @default(uuid()) @db.Uuid
  organizationId      String    @map("organization_id") @db.Uuid
  intentKey           String    @map("intent_key") @db.VarChar(500)
  status              String    @default("prepared")
  createdBy           String    @map("created_by") @db.Uuid
  preparedAt          DateTime  @default(now()) @map("prepared_at") @db.Timestamptz
  finalizedAt         DateTime? @map("finalized_at") @db.Timestamptz
  abortedAt           DateTime? @map("aborted_at") @db.Timestamptz
  finalizedGeneration BigInt?   @map("finalized_generation") @db.BigInt
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator      User         @relation("SellpiaOrderTransmissionIntentCreator", fields: [createdBy], references: [id], onDelete: Restrict)

  @@unique([organizationId, intentKey], map: "sellpia_order_transmission_intents_org_key")
  @@index([organizationId, status])
  @@index([createdBy])
  @@map("sellpia_order_transmission_intents")
}

/// @namespace Inventory
/// @describe Warehouse-to-warehouse movement record. It never mutates MasterProduct.currentStock.
model StockTransfer {
  id              String    @id @default(uuid()) @db.Uuid
  organizationId  String    @map("organization_id") @db.Uuid
  masterProductId String    @map("master_product_id") @db.Uuid
  optionName      String?   @map("option_name")
  fromWarehouseId String    @map("from_warehouse_id") @db.Uuid
  toWarehouseId   String    @map("to_warehouse_id") @db.Uuid
  quantity        Int
  status          String    @default("pending")
  requestedBy     String?   @map("requested_by")
  completedAt     DateTime? @map("completed_at") @db.Timestamptz
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  masterProduct MasterProduct @relation("StockTransferMasterProduct", fields: [masterProductId, organizationId], references: [id, organizationId], onDelete: Restrict)
  fromWarehouse Warehouse     @relation("TransferFromWarehouse", fields: [fromWarehouseId, organizationId], references: [id, organizationId])
  toWarehouse   Warehouse     @relation("TransferToWarehouse", fields: [toWarehouseId, organizationId], references: [id, organizationId])

  @@index([organizationId])
  @@index([masterProductId])
  @@index([fromWarehouseId])
  @@index([toWarehouseId])
  @@index([status])
  @@map("stock_transfers")
}

/// @namespace Inventory
model StockAudit {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  auditNumber    String    @map("audit_number")
  status         String    @default("in_progress")
  totalProducts  Int       @default(0) @map("total_products")
  matchedCount   Int       @default(0) @map("matched_count")
  diffCount      Int       @default(0) @map("diff_count")
  auditedBy      String?   @map("audited_by")
  completedAt    DateTime? @map("completed_at") @db.Timestamptz
  notes          String?
  items          Json?
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, auditNumber])
  @@index([organizationId])
  @@map("stock_audits")
}

/// @namespace Inventory
model Warehouse {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String
  code           String?
  address        String?
  manager        String?
  phone          String?
  isDefault      Boolean  @default(false) @map("is_default")
  status         String   @default("active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization       Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  stockTransfersFrom StockTransfer[] @relation("TransferFromWarehouse")
  stockTransfersTo   StockTransfer[] @relation("TransferToWarehouse")
  shipments          Shipment[]

  @@unique([organizationId, code])
  @@unique([id, organizationId], map: "warehouses_id_org_key")
  @@index([organizationId])
  @@map("warehouses")
}

/// @namespace Inventory
model PickingList {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  listNumber     String    @map("list_number")
  status         String    @default("pending")
  totalItems     Int       @default(0) @map("total_items")
  pickedItems    Int       @default(0) @map("picked_items")
  assignedTo     String?   @map("assigned_to")
  startedAt      DateTime? @map("started_at") @db.Timestamptz
  completedAt    DateTime? @map("completed_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items        PickingItem[]

  @@unique([organizationId, listNumber])
  @@unique([id, organizationId], map: "picking_lists_id_org_key")
  @@index([organizationId])
  @@map("picking_lists")
}

/// @namespace Inventory
model PickingItem {
  id              String    @id @default(uuid()) @db.Uuid
  organizationId  String    @map("organization_id") @db.Uuid
  pickingListId   String    @map("picking_list_id") @db.Uuid
  orderId         String?   @map("order_id") @db.Uuid
  masterProductId String    @map("master_product_id") @db.Uuid
  productName     String    @map("product_name")
  sku             String?
  quantity        Int       @default(1)
  location        String?
  isPicked        Boolean   @default(false) @map("is_picked")
  isVerified      Boolean   @default(false) @map("is_verified")
  pickedAt        DateTime? @map("picked_at") @db.Timestamptz
  verifiedAt      DateTime? @map("verified_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz

  pickingList   PickingList   @relation(fields: [pickingListId, organizationId], references: [id, organizationId], onDelete: Cascade)
  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  masterProduct MasterProduct @relation("PickingItemMasterProduct", fields: [masterProductId, organizationId], references: [id, organizationId], onDelete: Restrict)

  @@index([pickingListId])
  @@index([organizationId])
  @@index([masterProductId])
  @@map("picking_items")
}

/// @namespace Inventory
model ReturnTransfer {
  id              String    @id @default(uuid()) @db.Uuid
  organizationId  String    @map("organization_id") @db.Uuid
  rtNumber        String    @map("rt_number")
  orderId         String?   @map("order_id") @db.Uuid
  masterProductId String    @map("master_product_id") @db.Uuid
  optionName      String?   @map("option_name")
  quantity        Int
  status          String    @default("received")
  condition       String    @default("good")
  restockedQty    Int       @default(0) @map("restocked_qty")
  disposedQty     Int       @default(0) @map("disposed_qty")
  notes           String?
  processedBy     String?   @map("processed_by")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  completedAt     DateTime? @map("completed_at") @db.Timestamptz
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  masterProduct MasterProduct @relation("ReturnTransferMasterProduct", fields: [masterProductId, organizationId], references: [id, organizationId], onDelete: Restrict)

  @@unique([organizationId, rtNumber])
  @@index([organizationId])
  @@index([masterProductId])
  @@index([status])
  @@map("return_transfers")
}

/// @namespace Inventory
/// @describe Record of an operator-confirmed receipt file upload to Sellpia.
model SellpiaReceiptUploadBatch {
  id              String    @id @default(uuid()) @db.Uuid
  organizationId  String    @map("organization_id") @db.Uuid
  status          String    @default("template_pending")
  sourceType      String    @map("source_type")
  sourceRef       String    @map("source_ref")
  templateVersion String?   @map("template_version")
  uploadedBy      String?   @map("uploaded_by")
  uploadedAt      DateTime? @map("uploaded_at") @db.Timestamptz
  note            String?
  metaJson        Json?     @map("meta_json")
  createdBy       String?   @map("created_by")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@map("sellpia_receipt_upload_batches")
}
