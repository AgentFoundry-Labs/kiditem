// sourcing.prisma — Sourcing domain (issue #192)

/// @namespace Sourcing
/// @describe 외부 플랫폼에서 스크랩한 소싱 후보. MasterProduct와 분리된 sourcing inbox.
model SourcingCandidate {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @map("organization_id") @db.Uuid

  sourceUrl      String @map("source_url")
  sourcePlatform String @map("source_platform")
  rawData        Json   @default("{}") @map("raw_data")

  name         String
  description  String  @default("")
  category     String?
  tags         Json    @default("[]")
  thumbnailUrl String? @map("thumbnail_url")
  imageUrl     String? @map("image_url")

  costCny Decimal? @map("cost_cny") @db.Decimal(12, 2)

  status                    String  @default("sourced")
  provenanceMasterProductId String? @map("provenance_master_product_id") @db.Uuid

  rejectedReason   String?   @map("rejected_reason")
  rejectedAt       DateTime? @map("rejected_at") @db.Timestamptz
  rejectedByUserId String?   @map("rejected_by_user_id") @db.Uuid

  triggeredByUserId String? @map("triggered_by_user_id") @db.Uuid

  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization             Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  provenanceMasterProduct  MasterProduct?            @relation("SourcingCandidateProvenance", fields: [provenanceMasterProductId, organizationId], references: [id, organizationId], onDelete: Restrict)
  rejectedByUser           User?                     @relation("SourcingCandidateRejectedBy", fields: [rejectedByUserId], references: [id], onDelete: SetNull)
  triggeredByUser          User?                     @relation("SourcingCandidateTriggeredBy", fields: [triggeredByUserId], references: [id], onDelete: SetNull)
  images                   CandidateImage[]
  contentGenerationSources ContentGenerationSource[]
  contentGenerations       ContentGeneration[]       @relation("ContentGenerationPrimarySourcingCandidate")
  contentWorkspaces        ContentWorkspace[]        @relation("ContentWorkspaceSourcingCandidate")
  productPreparations      ProductPreparation[]
  thumbnailGenerations     ThumbnailGeneration[]     @relation("ThumbnailGenerationSourcingCandidate")
  channelListings          ChannelListing[]

  @@unique([organizationId, sourceUrl], map: "sourcing_candidates_organization_id_source_url_key", where: raw("is_deleted = false AND status = 'sourced'"))
  @@unique([provenanceMasterProductId, organizationId], map: "sourcing_candidates_org_provenance_master_key")
  @@unique([id, organizationId], map: "sourcing_candidates_id_org_key")
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, isDeleted])
  @@index([provenanceMasterProductId])
  @@map("sourcing_candidates")
}

/// @namespace Sourcing
/// @describe 소싱 후보의 이미지 갤러리. 승격 시 MasterProductImage로 clone.
/// ThumbnailGenerationInputImage.sourceCandidate가 이 테이블 참조 (Task 8에서 repoint).
model CandidateImage {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @map("organization_id") @db.Uuid
  candidateId    String @map("candidate_id") @db.Uuid

  url        String
  storageKey String? @map("storage_key")
  role       String  @default("product")
  label      String?
  sortOrder  Int     @default(0) @map("sort_order")
  source     String  @default("sourcing-extension")

  mimeType String? @map("mime_type")
  width    Int?
  height   Int?
  fileSize Int?    @map("file_size")

  isPrimary Boolean   @default(false) @map("is_primary")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization              Organization                    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  candidate                 SourcingCandidate               @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  thumbnailGenerationInputs ThumbnailGenerationInputImage[]

  @@index([organizationId])
  @@index([candidateId])
  @@index([organizationId, candidateId])
  @@map("sourcing_candidate_images")
}

/// @namespace Sourcing
/// @describe 조직/KST 날짜/scope 단위의 소싱 AI 결과 캐시. 오늘의 추천/키워드 분석 결과를 최신 1개로 재사용한다.
model SourcingWorkspaceSnapshot {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  scope          String
  businessDate   DateTime @map("business_date") @db.Date
  payload        Json     @default("{}") @map("payload") @db.JsonB

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, scope, businessDate])
  @@map("sourcing_workspace_snapshots")
}
