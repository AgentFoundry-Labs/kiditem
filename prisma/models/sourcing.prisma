/// @namespace Sourcing
/// @describe нғҖмҳӨл°”мҳӨ кіөмӢқ API лҳҗлҠ” лЎңк·ёмқёлҗң 1688В·лҸ„мҡ°мқё лёҢлқјмҡ°м Җ нҷ”л©ҙм—җм„ң мҲҳм§‘н•ң лқјмқҙлёҢ л°©мҶЎ мқјлі„ мҠӨлғ…мғ·. sourceмҷҖ broadcastIdк°Җ мҷёл¶Җ л°©мҶЎ мӢқлі„мһҗлҘј мқҙлЈ¬лӢӨ.
model LiveCommerceBroadcastDailySnapshot {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  businessDate   DateTime @map("business_date") @db.Date
  source         String
  broadcastId    String   @map("broadcast_id")

  title           String?
  broadcasterId   String?   @map("broadcaster_id")
  broadcasterName String?   @map("broadcaster_name")
  status          String?
  viewerCount     Int?      @map("viewer_count")
  likeCount       Int?      @map("like_count")
  startedAt       DateTime? @map("started_at") @db.Timestamptz
  endedAt         DateTime? @map("ended_at") @db.Timestamptz
  coverImageUrl   String?   @map("cover_image_url")
  sourceUrl       String?   @map("source_url")
  capturedAt      DateTime  @map("captured_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, businessDate, source, broadcastId])
  @@index([organizationId, source, businessDate])
  @@map("live_commerce_broadcast_daily_snapshots")
}

/// @namespace Sourcing
/// @describe мӨ‘көӯ лқјмқҙлёҢ л°©мҶЎм—җ л…ём¶ңлҗң мғҒн’Ҳмқҳ мқјлі„ мҠӨлғ…мғ·. broadcastIdлЎң л°©мҶЎ мҠӨлғ…мғ·кіј л…јлҰ¬м ҒмңјлЎң м—°кІ°н•ҳкі  мғҒн’Ҳ лӢЁмң„ л№„көҗлҘј м§Җмӣҗн•ңлӢӨ.
model LiveCommerceProductDailySnapshot {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  businessDate   DateTime @map("business_date") @db.Date
  source         String
  broadcastId    String   @map("broadcast_id")
  productId      String   @map("product_id")

  rank       Int?
  title      String?
  priceCny   Decimal? @map("price_cny") @db.Decimal(12, 2)
  salesCount Int?     @map("sales_count")
  imageUrl   String?  @map("image_url")
  sourceUrl  String?  @map("source_url")
  capturedAt DateTime @map("captured_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, businessDate, source, broadcastId, productId])
  @@index([organizationId, source, businessDate], map: "live_commerce_product_source_date_idx")
  @@index([organizationId, source, productId], map: "live_commerce_product_source_product_idx")
  @@map("live_commerce_product_daily_snapshots")
}

/// @namespace Sourcing
/// @describe Reviewed product preparationмқҳ marketplace create/reconcile side effect мӢӨн–ү кё°лЎқ. мӨҖл№„ мһ…л Ҙкіј provider lifecycleмқ„ л¶„лҰ¬н•ҙ ліҙмЎҙн•ңлӢӨ.
model ProductRegistrationExecution {
  id                   String  @id @default(uuid()) @db.Uuid
  organizationId       String  @map("organization_id") @db.Uuid
  productPreparationId String  @map("product_preparation_id") @db.Uuid
  channelAccountId     String  @map("channel_account_id") @db.Uuid
  channelListingId     String? @map("channel_listing_id") @db.Uuid

  executionKind  String @default("create") @map("execution_kind")
  idempotencyKey String @map("idempotency_key")
  requestHash    String @map("request_hash")

  submissionPayloadJson Json?   @map("submission_payload_json") @db.JsonB
  submissionPayloadHash String? @map("submission_payload_hash")

  status          String @default("prepared")
  providerOutcome String @default("not_attempted") @map("provider_outcome")

  providerSubmissionId String? @map("provider_submission_id")
  externalListingId    String? @map("external_listing_id")
  resultJson           Json?   @map("result_json") @db.JsonB
  lastErrorCode        String? @map("last_error_code")
  lastErrorMessage     String? @map("last_error_message")

  leaseToken        String?   @map("lease_token") @db.Uuid
  leaseClaimedAt    DateTime? @map("lease_claimed_at") @db.Timestamptz
  requestedByUserId String?   @map("requested_by_user_id") @db.Uuid
  startedAt         DateTime? @map("started_at") @db.Timestamptz
  completedAt       DateTime? @map("completed_at") @db.Timestamptz
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization       Organization       @relation("ProductRegistrationExecutionOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  productPreparation ProductPreparation @relation("ProductPreparationExecutions", fields: [productPreparationId, organizationId, channelAccountId], references: [id, organizationId, channelAccountId], onDelete: Restrict)
  channelAccount     ChannelAccount     @relation("ChannelAccountProductRegistrationExecutions", fields: [channelAccountId, organizationId], references: [id, organizationId], onDelete: Restrict)
  channelListing     ChannelListing?    @relation("ChannelListingProductRegistrationExecutions", fields: [channelListingId, organizationId, channelAccountId], references: [id, organizationId, channelAccountId], onDelete: Restrict)
  requestedByUser    User?              @relation("ProductRegistrationExecutionRequestedBy", fields: [requestedByUserId], references: [id], onDelete: SetNull)

  @@unique([organizationId, idempotencyKey], map: "product_registration_executions_org_idempotency_key")
  @@unique([organizationId, productPreparationId], map: "product_registration_executions_org_preparation_key")
  @@unique([organizationId, channelListingId], map: "product_registration_executions_active_listing_key", where: raw("channel_listing_id IS NOT NULL AND status = ANY (ARRAY['prepared'::text, 'executing'::text, 'reconciling'::text])"))
  @@unique([organizationId, channelAccountId, externalListingId], map: "product_registration_executions_active_external_listing_key", where: raw("external_listing_id IS NOT NULL AND status = ANY (ARRAY['prepared'::text, 'executing'::text, 'reconciling'::text])"))
  @@index([productPreparationId])
  @@index([channelAccountId])
  @@index([channelListingId])
  @@index([requestedByUserId])
  @@index([organizationId, status, createdAt])
  @@map("product_registration_executions")
}
