// sourcing.prisma — Sourcing domain (issue #192)

/// @namespace Sourcing
/// @describe 외부 플랫폼에서 스크랩한 소싱 후보. MasterProduct와 분리된 sourcing inbox.
model SourcingCandidate {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @map("organization_id") @db.Uuid

  sourceUrl      String @map("source_url")
  sourcePlatform String @map("source_platform")
  rawData        Json   @default("{}") @map("raw_data")

  name         String
  description  String  @default("")
  category     String?
  tags         Json    @default("[]")
  thumbnailUrl String? @map("thumbnail_url")
  imageUrl     String? @map("image_url")

  costCny Decimal? @map("cost_cny") @db.Decimal(12, 2)

  status                    String  @default("sourced")
  provenanceMasterProductId String? @map("provenance_master_product_id") @db.Uuid

  rejectedReason   String?   @map("rejected_reason")
  rejectedAt       DateTime? @map("rejected_at") @db.Timestamptz
  rejectedByUserId String?   @map("rejected_by_user_id") @db.Uuid

  triggeredByUserId String? @map("triggered_by_user_id") @db.Uuid

  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization             Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  provenanceMasterProduct  MasterProduct?            @relation("SourcingCandidateProvenance", fields: [provenanceMasterProductId, organizationId], references: [id, organizationId], onDelete: Restrict)
  rejectedByUser           User?                     @relation("SourcingCandidateRejectedBy", fields: [rejectedByUserId], references: [id], onDelete: SetNull)
  triggeredByUser          User?                     @relation("SourcingCandidateTriggeredBy", fields: [triggeredByUserId], references: [id], onDelete: SetNull)
  images                   CandidateImage[]
  contentGenerationSources ContentGenerationSource[]
  contentGenerations       ContentGeneration[]       @relation("ContentGenerationPrimarySourcingCandidate")
  contentWorkspaces        ContentWorkspace[]        @relation("ContentWorkspaceSourcingCandidate")
  productPreparations      ProductPreparation[]
  thumbnailGenerations     ThumbnailGeneration[]     @relation("ThumbnailGenerationSourcingCandidate")
  channelListings          ChannelListing[]

  @@unique([organizationId, sourceUrl], map: "sourcing_candidates_organization_id_source_url_key", where: raw("is_deleted = false AND status = 'sourced'"))
  @@unique([provenanceMasterProductId, organizationId], map: "sourcing_candidates_org_provenance_master_key")
  @@unique([id, organizationId], map: "sourcing_candidates_id_org_key")
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, isDeleted])
  @@index([provenanceMasterProductId])
  @@map("sourcing_candidates")
}

/// @namespace Sourcing
/// @describe 소싱 후보가 소유하는 이미지 갤러리. 소싱 콘텐츠와 썸네일 생성 입력으로 사용한다.
/// ThumbnailGenerationInputImage이 선택된 후보 이미지를 이 테이블에서 참조한다.
model CandidateImage {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @map("organization_id") @db.Uuid
  candidateId    String @map("candidate_id") @db.Uuid

  url        String
  storageKey String? @map("storage_key")
  role       String  @default("product")
  label      String?
  sortOrder  Int     @default(0) @map("sort_order")
  source     String  @default("sourcing-extension")

  mimeType String? @map("mime_type")
  width    Int?
  height   Int?
  fileSize Int?    @map("file_size")

  isPrimary Boolean   @default(false) @map("is_primary")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization              Organization                    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  candidate                 SourcingCandidate               @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  thumbnailGenerationInputs ThumbnailGenerationInputImage[]

  @@index([organizationId])
  @@index([candidateId])
  @@index([organizationId, candidateId])
  @@map("sourcing_candidate_images")
}

/// @namespace Sourcing
/// @describe 조직/KST 날짜/scope 단위의 소싱 AI 결과 캐시. 오늘의 추천/키워드 분석 결과를 최신 1개로 재사용한다.
model SourcingWorkspaceSnapshot {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  scope          String
  businessDate   DateTime @map("business_date") @db.Date
  payload        Json     @default("{}") @map("payload") @db.JsonB

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, scope, businessDate])
  @@map("sourcing_workspace_snapshots")
}

/// @namespace Sourcing
/// @describe 문구·완구 시장 트렌드 정기 수집의 시드 키워드. sources 로 몰별(naver/shorts/1688) 수집 대상을 제어. keywordCn 은 1688 中文 검색어(null이면 keyword 사용).
model TrendSeedKeyword {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @map("organization_id") @db.Uuid

  keyword   String
  keywordCn String?  @map("keyword_cn")
  sources   String[] @default(["naver", "shorts", "1688"])
  enabled   Boolean  @default(true)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, keyword])
  @@index([organizationId])
  @@map("trend_seed_keywords")
}

/// @namespace Sourcing
/// @describe 네이버 키워드(검색광고 월검색량 + 데이터랩 검색어트렌드) 일별 스냅샷. 시드 키워드당 하루 1행(최신본 upsert). trendRatio 는 latestRatio 반올림(0-100).
model NaverKeywordDailySnapshot {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  keyword        String
  businessDate   DateTime @map("business_date") @db.Date

  monthlyTotalSearchCount  Int?    @map("monthly_total_search_count")
  monthlyPcSearchCount     Int?    @map("monthly_pc_search_count")
  monthlyMobileSearchCount Int?    @map("monthly_mobile_search_count")
  competitionIndex         String? @map("competition_index")
  averageAdRank            Int?    @map("average_ad_rank")
  trendRatio               Int?    @map("trend_ratio")
  trendDelta               Int?    @map("trend_delta")

  source     String   @default("naver")
  capturedAt DateTime @map("captured_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, keyword, businessDate])
  @@index([organizationId, keyword, businessDate])
  @@map("naver_keyword_daily_snapshots")
}

/// @namespace Sourcing
/// @describe 네이버 데이터랩 인기키워드 보드(출산/육아·완구/인형·문구/사무 등)의 일별 순위 스냅샷. 보드×키워드 identity를 사용하고 매 수집마다 보드×일자 범위를 통째로 교체한다.
model NaverPopularKeywordDailySnapshot {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  boardKey       String   @map("board_key")
  boardLabel     String?  @map("board_label")
  cid            String?
  businessDate   DateTime @map("business_date") @db.Date

  rank    Int
  keyword String
  linkId  String? @map("link_id")

  capturedAt DateTime @map("captured_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, boardKey, businessDate, keyword])
  @@index([organizationId, boardKey, businessDate])
  @@map("naver_popular_keyword_daily_snapshots")
}

/// @namespace Sourcing
/// @describe 1688 키워드별 핫셀링 offer 일별 스냅샷. sourceKeyword 는 시드 키워드, rank 는 해당 키워드 결과셋 내 monthlySales 내림차순 순위. offer×일자당 1행.
model Sourcing1688HotProductDailySnapshot {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  businessDate   DateTime @map("business_date") @db.Date
  offerId        String   @map("offer_id")
  sourceKeyword  String   @map("source_keyword")

  rank           Int?
  title          String?
  priceCny       Decimal? @map("price_cny") @db.Decimal(12, 2)
  monthlySales   Int?     @map("monthly_sales")
  repurchaseRate String?  @map("repurchase_rate")
  tradeScore     String?  @map("trade_score")
  supplierName   String?  @map("supplier_name")
  imageUrl       String?  @map("image_url")
  sourceUrl      String?  @map("source_url")

  capturedAt DateTime @map("captured_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, businessDate, offerId])
  @@index([organizationId, businessDate])
  @@map("sourcing_1688_hot_product_daily_snapshots")
}

/// @namespace Sourcing
/// @describe 쇼츠트렌드(shortstrend.co.kr) 급상승 쇼츠 일별 스냅샷. rank 는 소스 노출 순위, videoKey 는 영상 식별자. video×일자당 1행.
model ShortsTrendDailySnapshot {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  businessDate   DateTime @map("business_date") @db.Date
  videoKey       String   @map("video_key")

  rank         Int?
  title        String?
  channelName  String?   @map("channel_name")
  viewCount    Int?      @map("view_count")
  likeCount    Int?      @map("like_count")
  commentCount Int?      @map("comment_count")
  keyword      String?
  publishedAt  DateTime? @map("published_at") @db.Timestamptz
  thumbnailUrl String?   @map("thumbnail_url")
  videoUrl     String?   @map("video_url")

  source     String   @default("shortstrend")
  capturedAt DateTime @map("captured_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, businessDate, videoKey])
  @@index([organizationId, businessDate])
  @@map("shorts_trend_daily_snapshots")
}

/// @namespace Sourcing
/// @describe 타오바오 공식 API 또는 로그인된 1688·도우인 브라우저 화면에서 수집한 라이브 방송 일별 스냅샷. source와 broadcastId가 외부 방송 식별자를 이룬다.
model LiveCommerceBroadcastDailySnapshot {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  businessDate   DateTime @map("business_date") @db.Date
  source         String
  broadcastId    String   @map("broadcast_id")

  title           String?
  broadcasterId   String?   @map("broadcaster_id")
  broadcasterName String?   @map("broadcaster_name")
  status          String?
  viewerCount     Int?      @map("viewer_count")
  likeCount       Int?      @map("like_count")
  startedAt       DateTime? @map("started_at") @db.Timestamptz
  endedAt         DateTime? @map("ended_at") @db.Timestamptz
  coverImageUrl   String?   @map("cover_image_url")
  sourceUrl       String?   @map("source_url")
  capturedAt      DateTime  @map("captured_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, businessDate, source, broadcastId])
  @@index([organizationId, source, businessDate])
  @@map("live_commerce_broadcast_daily_snapshots")
}

/// @namespace Sourcing
/// @describe 중국 라이브 방송에 노출된 상품의 일별 스냅샷. broadcastId로 방송 스냅샷과 논리적으로 연결하고 상품 단위 비교를 지원한다.
model LiveCommerceProductDailySnapshot {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  businessDate   DateTime @map("business_date") @db.Date
  source         String
  broadcastId    String   @map("broadcast_id")
  productId      String   @map("product_id")

  rank       Int?
  title      String?
  priceCny   Decimal? @map("price_cny") @db.Decimal(12, 2)
  salesCount Int?     @map("sales_count")
  imageUrl   String?  @map("image_url")
  sourceUrl  String?  @map("source_url")
  capturedAt DateTime @map("captured_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, businessDate, source, broadcastId, productId])
  @@index([organizationId, source, businessDate], map: "live_commerce_product_source_date_idx")
  @@index([organizationId, source, productId], map: "live_commerce_product_source_product_idx")
  @@map("live_commerce_product_daily_snapshots")
}

/// @namespace Sourcing
/// @describe Reviewed product preparation의 marketplace create/reconcile side effect 실행 기록. 준비 입력과 provider lifecycle을 분리해 보존한다.
model ProductRegistrationExecution {
  id                   String  @id @default(uuid()) @db.Uuid
  organizationId       String  @map("organization_id") @db.Uuid
  productPreparationId String  @map("product_preparation_id") @db.Uuid
  channelAccountId     String  @map("channel_account_id") @db.Uuid
  channelListingId     String? @map("channel_listing_id") @db.Uuid

  executionKind             String  @default("create") @map("execution_kind")
  expectedProviderAccountId String? @map("expected_provider_account_id")
  idempotencyKey            String  @map("idempotency_key")
  requestHash               String  @map("request_hash")

  submissionPayloadJson Json?   @map("submission_payload_json") @db.JsonB
  submissionPayloadHash String? @map("submission_payload_hash")

  status          String @default("prepared")
  providerOutcome String @default("not_attempted") @map("provider_outcome")

  providerSubmissionId String? @map("provider_submission_id")
  externalListingId    String? @map("external_listing_id")
  resultJson           Json?   @map("result_json") @db.JsonB
  lastErrorCode        String? @map("last_error_code")
  lastErrorMessage     String? @map("last_error_message")

  leaseToken        String?   @map("lease_token") @db.Uuid
  leaseClaimedAt    DateTime? @map("lease_claimed_at") @db.Timestamptz
  requestedByUserId String?   @map("requested_by_user_id") @db.Uuid
  startedAt         DateTime? @map("started_at") @db.Timestamptz
  completedAt       DateTime? @map("completed_at") @db.Timestamptz
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization       Organization       @relation("ProductRegistrationExecutionOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  productPreparation ProductPreparation @relation("ProductPreparationExecutions", fields: [productPreparationId, organizationId, channelAccountId], references: [id, organizationId, channelAccountId], onDelete: Restrict)
  channelAccount     ChannelAccount     @relation("ChannelAccountProductRegistrationExecutions", fields: [channelAccountId, organizationId], references: [id, organizationId], onDelete: Restrict)
  channelListing     ChannelListing?    @relation("ChannelListingProductRegistrationExecutions", fields: [channelListingId, organizationId, channelAccountId], references: [id, organizationId, channelAccountId], onDelete: Restrict)
  requestedByUser    User?              @relation("ProductRegistrationExecutionRequestedBy", fields: [requestedByUserId], references: [id], onDelete: SetNull)

  @@unique([organizationId, idempotencyKey], map: "product_registration_executions_org_idempotency_key")
  @@unique([organizationId, productPreparationId], map: "product_registration_executions_org_preparation_key")
  @@unique([organizationId, channelListingId], map: "product_registration_executions_active_listing_key", where: raw("channel_listing_id IS NOT NULL AND status = ANY (ARRAY['prepared'::text, 'executing'::text, 'reconciling'::text])"))
  @@unique([organizationId, channelAccountId, externalListingId], map: "product_registration_executions_active_external_listing_key", where: raw("external_listing_id IS NOT NULL AND status = ANY (ARRAY['prepared'::text, 'executing'::text, 'reconciling'::text])"))
  @@index([productPreparationId])
  @@index([channelAccountId])
  @@index([channelListingId])
  @@index([requestedByUserId])
  @@index([organizationId, status, createdAt])
  @@map("product_registration_executions")
}
