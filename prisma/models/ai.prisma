// ai.prisma — AI domain

/// @namespace AI
/// @describe CTR 기반 썸네일 트래킹 (ThumbnailAnalysis 와 별도 시스템).
model Thumbnail {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @map("organization_id") @db.Uuid
  listingId      String @map("listing_id") @db.Uuid

  imageUrl      String   @map("image_url")
  strategy      String   @default("standard")
  status        String   @default("active")
  ctr           Decimal? @db.Decimal(5, 4)
  prevClickRate Decimal? @default(0) @map("prev_click_rate") @db.Decimal(5, 4)
  impressions   Int      @default(0)
  clicks        Int      @default(0)

  measuredAt DateTime? @map("measured_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  listing      ChannelListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([listingId])
  @@map("thumbnails")
}

/// @namespace AI
/// @describe 5차원 scores(heroShot·composition·branding·mobile·differentiation) + complianceGrade(PASS/WARN/FAIL) + imageSpec(사전검수). 스펙 FAIL 시 AI 호출 생략.
model ThumbnailAnalysis {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @map("organization_id") @db.Uuid
  masterId       String @unique @map("master_id") @db.Uuid

  imageUrl     String @map("image_url")
  overallScore Int    @default(0) @map("overall_score")
  grade        String @default("F")
  scores       Json? // { heroShot, composition, branding, mobile, differentiation }
  issues       Json   @default("[]")
  suggestions  Json   @default("[]")
  method       String @default("ai") // "ai" | "rule"

  complianceGrade  String? @map("compliance_grade") // PASS | WARN | FAIL
  complianceScores Json?   @map("compliance_scores") // { violations, confidence, quality, violationCount }
  imageSpec        Json?   @map("image_spec") // { width, height, aspectRatio, fileSizeKB, format, issues }
  recompose        Json? // { kind, requiresChoice, options, recommended, reasoning }

  qualityAnalyzedAt    DateTime? @map("quality_analyzed_at") @db.Timestamptz
  complianceAnalyzedAt DateTime? @map("compliance_analyzed_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  master       MasterProduct @relation(fields: [masterId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([grade])
  @@index([complianceGrade])
  @@map("thumbnail_analyses")
}

/// @namespace AI
/// @describe 상태: status=pending/running/succeeded/failed/cancelled, phase=ready/applied. method=generate/creative/auto.
model ThumbnailGeneration {
  id                 String  @id @default(uuid()) @db.Uuid
  organizationId     String  @map("organization_id") @db.Uuid
  masterId           String? @map("master_id") @db.Uuid
  sourceCandidateId  String? @map("source_candidate_id") @db.Uuid
  contentWorkspaceId String? @map("content_workspace_id") @db.Uuid

  originalUrl          String?                         @map("original_url")
  candidates           ThumbnailGenerationCandidate[]
  inputImages          ThumbnailGenerationInputImage[]
  events               ThumbnailGenerationEvent[]
  registrationAttempts ThumbnailRegistrationAttempt[]
  selectedUrl          String?                         @map("selected_url")
  status               String                          @default("pending")
  phase                String?                         @map("phase")
  grade                String                          @default("F")
  score                Int                             @default(0)
  prompt               String?
  method               String                          @default("edit") @map("method")
  editAnalysis         Json?                           @map("edit_analysis")
  inputMeta            Json?                           @map("input_meta")
  inputMetaVersion     Int                             @default(1) @map("input_meta_version")
  errorMessage         String?                         @map("error_message")
  attemptCount         Int                             @default(0) @map("attempt_count")

  triggeredByUserId String? @map("triggered_by_user_id") @db.Uuid

  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization                   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  master                         MasterProduct?       @relation(fields: [masterId], references: [id], onDelete: Cascade)
  sourceCandidate                SourcingCandidate?   @relation("ThumbnailGenerationSourcingCandidate", fields: [sourceCandidateId], references: [id], onDelete: SetNull)
  contentWorkspace               ContentWorkspace?    @relation("ThumbnailGenerationContentWorkspace", fields: [contentWorkspaceId], references: [id], onDelete: SetNull)
  trackings                      ThumbnailTracking[]
  triggeredByUser                User?                @relation("ThumbnailGenerationTriggeredBy", fields: [triggeredByUserId], references: [id], onDelete: SetNull)
  selectedForProductPreparations ProductPreparation[] @relation("ProductPreparationSelectedThumbnailGeneration")
  thumbnailSelections            ContentWorkspaceThumbnailSelection[] @relation("ContentWorkspaceThumbnailSelectionGeneration")

  @@unique([id, organizationId], map: "thumbnail_generations_id_org_key")
  @@index([organizationId])
  @@index([masterId])
  @@index([sourceCandidateId])
  @@index([contentWorkspaceId])
  @@index([status])
  @@index([method])
  @@index([organizationId, isDeleted])
  @@index([organizationId, sourceCandidateId])
  @@index([organizationId, sourceCandidateId, isDeleted])
  @@index([organizationId, contentWorkspaceId], map: "thumbnail_generations_org_content_workspace_idx")
  @@index([organizationId, contentWorkspaceId, isDeleted], map: "thumbnail_generations_org_content_workspace_deleted_idx")
  @@index([organizationId, triggeredByUserId])
  @@index([triggeredByUserId])
  @@map("thumbnail_generations")
}

/// @namespace AI
/// @describe 썸네일 생성 후보 이미지. 바이너리는 object storage 에 저장하고 DB 는 URL/key 메타데이터만 보관한다.
model ThumbnailGenerationCandidate {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @map("organization_id") @db.Uuid
  generationId   String @map("generation_id") @db.Uuid

  url        String
  storageKey String? @map("storage_key")
  filename   String?
  sortOrder  Int     @default(0) @map("sort_order")

  mimeType String? @map("mime_type")
  width    Int?
  height   Int?
  fileSize Int?    @map("file_size")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization                   Organization                    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  generation                     ThumbnailGeneration             @relation(fields: [generationId], references: [id], onDelete: Cascade)
  derivedInputs                  ThumbnailGenerationInputImage[]
  selectedForProductPreparations ProductPreparation[]            @relation("ProductPreparationSelectedThumbnailGenerationCandidate")
  thumbnailSelections            ContentWorkspaceThumbnailSelection[] @relation("ContentWorkspaceThumbnailSelectionCandidate")

  @@unique([id, organizationId], map: "thumbnail_generation_candidates_id_org_key")
  @@index([organizationId])
  @@index([generationId])
  @@index([organizationId, generationId])
  @@index([generationId, sortOrder])
  @@map("thumbnail_generation_candidates")
}

/// @namespace AI
/// @describe 썸네일 편집/생성 입력 이미지. base64 원문 대신 object storage 참조와 역할 메타데이터만 저장한다.
model ThumbnailGenerationInputImage {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @map("organization_id") @db.Uuid
  generationId   String @map("generation_id") @db.Uuid

  url                        String
  storageKey                 String? @map("storage_key")
  role                       String  @default("product")
  label                      String?
  sortOrder                  Int     @default(0) @map("sort_order")
  source                     String  @default("upload")
  masterImageId              String? @map("master_image_id") @db.Uuid
  candidateImageId           String? @map("candidate_image_id") @db.Uuid
  sourceThumbnailCandidateId String? @map("source_candidate_id") @db.Uuid

  mimeType String? @map("mime_type")
  width    Int?
  height   Int?
  fileSize Int?    @map("file_size")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization             Organization                  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  generation               ThumbnailGeneration           @relation(fields: [generationId], references: [id], onDelete: Cascade)
  masterImage              MasterProductImage?           @relation(fields: [masterImageId], references: [id], onDelete: SetNull)
  candidateImage           CandidateImage?               @relation(fields: [candidateImageId], references: [id], onDelete: SetNull)
  sourceThumbnailCandidate ThumbnailGenerationCandidate? @relation(fields: [sourceThumbnailCandidateId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([generationId])
  @@index([masterImageId])
  @@index([candidateImageId])
  @@index([sourceThumbnailCandidateId])
  @@index([organizationId, generationId])
  @@index([generationId, role, sortOrder])
  @@map("thumbnail_generation_input_images")
}

/// @namespace AI
/// @describe ThumbnailGeneration 의 status/phase/attempt/error 전이 audit ledger. row 누적, 덮어쓰기 X.
model ThumbnailGenerationEvent {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @map("organization_id") @db.Uuid
  generationId   String @map("generation_id") @db.Uuid

  eventType     String  @map("event_type")
  fromStatus    String? @map("from_status")
  toStatus      String? @map("to_status")
  fromPhase     String? @map("from_phase")
  toPhase       String? @map("to_phase")
  attemptNumber Int?    @map("attempt_number")
  errorMessage  String? @map("error_message")
  payload       Json?

  actorUserId String? @map("actor_user_id") @db.Uuid

  occurredAt DateTime @default(now()) @map("occurred_at") @db.Timestamptz
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  generation   ThumbnailGeneration @relation(fields: [generationId], references: [id], onDelete: Cascade)
  actor        User?               @relation("ThumbnailGenerationEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([generationId])
  @@index([generationId, occurredAt])
  @@index([organizationId, generationId])
  @@index([eventType])
  @@index([actorUserId])
  @@map("thumbnail_generation_events")
}

/// @namespace AI
/// @describe Wing 등 외부 채널 등록 시도 이력. 마지막 상태만 덮어쓰지 않고 재시도/실패 원인을 보존한다.
model ThumbnailRegistrationAttempt {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @map("organization_id") @db.Uuid
  generationId   String @map("generation_id") @db.Uuid

  status        String  @default("uploaded")
  errorMessage  String? @map("error_message")
  screenshotUrl String? @map("screenshot_url")
  externalId    String? @map("external_id")

  startedAt  DateTime? @map("started_at") @db.Timestamptz
  finishedAt DateTime? @map("finished_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  generation   ThumbnailGeneration @relation(fields: [generationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([generationId])
  @@index([organizationId, generationId])
  @@index([status])
  @@map("thumbnail_registration_attempts")
}

/// @namespace AI
model ThumbnailTracking {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @map("organization_id") @db.Uuid
  listingId      String @map("listing_id") @db.Uuid
  generationId   String @map("generation_id") @db.Uuid

  originalGrade String   @map("original_grade") // S|A|B|C|F
  originalScore Int      @default(0) @map("original_score")
  appliedAt     DateTime @default(now()) @map("applied_at") @db.Timestamptz

  // 성과 지표 (나중에 채워짐)
  ctrBefore     Float? @map("ctr_before")
  ctrAfter      Float? @map("ctr_after")
  reviewsBefore Int?   @map("reviews_before")
  reviewsAfter  Int?   @map("reviews_after")
  salesBefore   Int?   @map("sales_before")
  salesAfter    Int?   @map("sales_after")

  status String @default("tracking") // tracking|measured|inconclusive

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization   Organization                     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  listing        ChannelListing                   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  generation     ThumbnailGeneration              @relation(fields: [generationId], references: [id], onDelete: Cascade)
  dailySnapshots ThumbnailTrackingDailySnapshot[]

  @@unique([listingId, generationId])
  @@index([organizationId])
  @@index([listingId])
  @@index([generationId])
  @@index([status])
  @@map("thumbnail_trackings")
}

/// @namespace AI
/// @describe 적용된 썸네일의 30일 매출/판매량 시계열 — playwriter 로 Wing vendor-inventory 검색해서 매일 한 row 씩 적재.
model ThumbnailTrackingDailySnapshot {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  trackingId     String   @map("tracking_id") @db.Uuid
  capturedAt     DateTime @default(now()) @map("captured_at") @db.Timestamptz
  capturedDate   DateTime @map("captured_date") @db.Date

  // 정규화 추출값 (Wing DOM 에서 파싱) — null 가능 (스크래퍼가 못 찾으면)
  unitsSold30d Int?   @map("units_sold_30d") // 최근 30일 누적 판매량
  unitsSold7d  Int?   @map("units_sold_7d") // 최근 7일 누적 판매량
  revenueKrw   Int?   @map("revenue_krw") // 매출 (KRW)
  reviewCount  Int?   @map("review_count") // 리뷰 개수
  ratingAvg    Float? @map("rating_avg") // 평균 별점

  // 원본 row HTML/text — 패턴 분화 시 재파싱 가능하도록 보존
  rawCellTexts Json? @map("raw_cell_texts")

  // scrape 메타
  scrapeStatus String  @default("ok") @map("scrape_status") // ok|not_found|error
  errorMessage String? @map("error_message")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tracking     ThumbnailTracking @relation(fields: [trackingId], references: [id], onDelete: Cascade)

  @@unique([trackingId, capturedDate]) // 하루 한 row
  @@index([organizationId])
  @@index([trackingId])
  @@index([capturedDate])
  @@map("thumbnail_tracking_daily_snapshots")
}

/// @namespace AI
model ContentGeneration {
  id                   String    @id @default(uuid()) @db.Uuid
  organizationId       String    @map("organization_id") @db.Uuid
  generationGroupId    String    @map("generation_group_id") @db.Uuid
  contentWorkspaceId   String?   @map("content_workspace_id") @db.Uuid
  sourceCandidateId    String?   @map("source_candidate_id") @db.Uuid
  detailPageArtifactId String?   @map("detail_page_artifact_id") @db.Uuid
  contentType          String    @default("detail_page") @map("content_type")
  templateId           String?   @map("template_id")
  generationInput      Json      @default("{}") @map("generation_input")
  generationResult     Json      @default("{}") @map("generation_result")
  generatedTitle       String?   @map("generated_title")
  generatedDescription String?   @map("generated_description")
  generatedCopy        String?   @map("generated_copy")
  editedHtml           String?   @map("edited_html")
  editedHtmlSavedAt    DateTime? @map("edited_html_saved_at") @db.Timestamptz
  status               String    @default("PENDING")
  retryCount           Int       @default(0) @map("retry_count")
  errorMessage         String?   @map("error_message")
  triggeredByUserId    String?   @map("triggered_by_user_id") @db.Uuid
  isDeleted            Boolean   @default(false) @map("is_deleted")
  deletedAt            DateTime? @map("deleted_at") @db.Timestamptz
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization                   Organization                  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  generationGroup                ContentGenerationGroup        @relation("ContentGenerationGroupMembers", fields: [generationGroupId], references: [id], onDelete: Cascade)
  contentWorkspace               ContentWorkspace?             @relation("ContentGenerationContentWorkspace", fields: [contentWorkspaceId], references: [id], onDelete: SetNull)
  sourceCandidate                SourcingCandidate?            @relation("ContentGenerationPrimarySourcingCandidate", fields: [sourceCandidateId], references: [id], onDelete: SetNull)
  detailPageArtifact             DetailPageArtifact?           @relation("ContentGenerationDetailPageArtifact", fields: [detailPageArtifactId], references: [id], onDelete: SetNull)
  triggeredByUser                User?                         @relation("ContentGenerationTriggeredBy", fields: [triggeredByUserId], references: [id], onDelete: SetNull)
  assetUsages                    ContentGenerationAssetUsage[]
  sources                        ContentGenerationSource[]     @relation("ContentGenerationSources")
  sourceLinks                    ContentGenerationSource[]     @relation("ContentGenerationDerivedSources")
  baseForGroups                  ContentGenerationGroup[]      @relation("ContentGenerationGroupBase")
  sourceDetailPageArtifacts      DetailPageArtifact[]          @relation("DetailPageArtifactSourceGeneration")
  detailPageRevisions            DetailPageRevision[]          @relation("DetailPageRevisionContentGeneration")
  selectedForProductPreparations ProductPreparation[]          @relation("ProductPreparationSelectedDetailPageGeneration")

  @@unique([id, organizationId], map: "content_generations_id_org_key")
  @@index([organizationId])
  @@index([generationGroupId])
  @@index([contentWorkspaceId])
  @@index([sourceCandidateId])
  @@index([detailPageArtifactId])
  @@index([organizationId, contentType])
  @@index([organizationId, generationGroupId])
  @@index([organizationId, contentWorkspaceId])
  @@index([organizationId, sourceCandidateId])
  @@index([organizationId, detailPageArtifactId])
  @@index([organizationId, isDeleted])
  @@index([organizationId, sourceCandidateId, isDeleted])
  @@index([templateId])
  @@index([organizationId, templateId])
  @@index([status])
  @@index([organizationId, triggeredByUserId])
  @@index([triggeredByUserId])
  @@map("content_generations")
}

/// @namespace AI
/// @describe Candidate-centered editable detail-page artifact. One artifact owns the user-visible draft line; revisions keep generated/manual HTML history.
model DetailPageArtifact {
  id                        String    @id @default(uuid()) @db.Uuid
  organizationId            String    @map("organization_id") @db.Uuid
  contentWorkspaceId        String?   @map("content_workspace_id") @db.Uuid
  sourceCandidateId         String?   @map("source_candidate_id") @db.Uuid
  targetMasterId            String?   @map("target_master_id") @db.Uuid
  sourceContentGenerationId String?   @map("source_content_generation_id") @db.Uuid
  currentRevisionId         String?   @map("current_revision_id") @db.Uuid
  title                     String?
  status                    String    @default("draft")
  metadata                  Json      @default("{}")
  createdByUserId           String?   @map("created_by_user_id") @db.Uuid
  isDeleted                 Boolean   @default(false) @map("is_deleted")
  deletedAt                 DateTime? @map("deleted_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization                   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contentWorkspace               ContentWorkspace?    @relation("DetailPageArtifactContentWorkspace", fields: [contentWorkspaceId], references: [id], onDelete: SetNull)
  sourceCandidate                SourcingCandidate?   @relation("DetailPageArtifactSourcingCandidate", fields: [sourceCandidateId], references: [id], onDelete: SetNull)
  targetMaster                   MasterProduct?       @relation("DetailPageArtifactTargetMaster", fields: [targetMasterId], references: [id], onDelete: SetNull)
  sourceContentGeneration        ContentGeneration?   @relation("DetailPageArtifactSourceGeneration", fields: [sourceContentGenerationId], references: [id], onDelete: SetNull)
  currentRevision                DetailPageRevision?  @relation("DetailPageArtifactCurrentRevision", fields: [currentRevisionId], references: [id], onDelete: SetNull)
  createdByUser                  User?                @relation("DetailPageArtifactCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  revisions                      DetailPageRevision[] @relation("DetailPageArtifactRevisions")
  contentGenerations             ContentGeneration[]  @relation("ContentGenerationDetailPageArtifact")
  currentForContentWorkspaces    ContentWorkspace[]   @relation("ContentWorkspaceCurrentArtifact")
  selectedForProductPreparations ProductPreparation[] @relation("ProductPreparationSelectedDetailPageArtifact")

  @@unique([id, organizationId], map: "detail_page_artifacts_id_org_key")
  @@index([organizationId])
  @@index([contentWorkspaceId])
  @@index([sourceCandidateId])
  @@index([targetMasterId])
  @@index([sourceContentGenerationId])
  @@index([currentRevisionId])
  @@index([createdByUserId])
  @@index([organizationId, sourceCandidateId])
  @@index([organizationId, contentWorkspaceId])
  @@index([organizationId, targetMasterId])
  @@index([organizationId, status])
  @@index([organizationId, isDeleted])
  @@index([organizationId, sourceCandidateId, isDeleted])
  @@map("detail_page_artifacts")
}

/// @namespace AI
/// @describe Product content workspace. Detail-page and thumbnail generations for the same owner/title accumulate here as versioned content history before or after MasterProduct creation.
model ContentWorkspace {
  id                          String    @id @default(uuid()) @db.Uuid
  organizationId              String    @map("organization_id") @db.Uuid
  ownerType                   String    @map("owner_type")
  sourceCandidateId           String?   @map("source_candidate_id") @db.Uuid
  targetMasterId              String?   @map("target_master_id") @db.Uuid
  channelListingId            String?   @map("channel_listing_id") @db.Uuid
  originWorkspaceId           String?   @map("origin_workspace_id") @db.Uuid
  displayName                 String    @map("display_name")
  normalizedTitle             String    @map("normalized_title")
  status                      String    @default("active")
  currentDetailPageArtifactId String?   @map("current_detail_page_artifact_id") @db.Uuid
  currentDetailPageRevisionId String?   @map("current_detail_page_revision_id") @db.Uuid
  currentThumbnailSelectionId String?   @map("current_thumbnail_selection_id") @db.Uuid
  createdByUserId             String?   @map("created_by_user_id") @db.Uuid
  isDeleted                   Boolean   @default(false) @map("is_deleted")
  deletedAt                   DateTime? @map("deleted_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization              Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sourceCandidate           SourcingCandidate?    @relation("ContentWorkspaceSourcingCandidate", fields: [sourceCandidateId, organizationId], references: [id, organizationId], onDelete: Restrict)
  targetMaster              MasterProduct?        @relation("ContentWorkspaceTargetMaster", fields: [targetMasterId, organizationId], references: [id, organizationId], onDelete: Restrict)
  channelListing            ChannelListing?       @relation(fields: [channelListingId, organizationId], references: [id, organizationId], onDelete: Restrict)
  originWorkspace           ContentWorkspace?     @relation("ContentWorkspaceBranches", fields: [originWorkspaceId, organizationId], references: [id, organizationId], onDelete: Restrict)
  derivedWorkspaces         ContentWorkspace[]     @relation("ContentWorkspaceBranches")
  currentDetailPageArtifact DetailPageArtifact?   @relation("ContentWorkspaceCurrentArtifact", fields: [currentDetailPageArtifactId, organizationId], references: [id, organizationId], onDelete: Restrict)
  currentDetailPageRevision DetailPageRevision?   @relation("ContentWorkspaceCurrentRevision", fields: [currentDetailPageRevisionId, organizationId], references: [id, organizationId], onDelete: Restrict)
  currentThumbnailSelection ContentWorkspaceThumbnailSelection? @relation("ContentWorkspaceCurrentThumbnail", fields: [currentThumbnailSelectionId, organizationId], references: [id, organizationId], onDelete: Restrict)
  createdByUser             User?                 @relation("ContentWorkspaceCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  contentGenerations        ContentGeneration[]   @relation("ContentGenerationContentWorkspace")
  detailPageArtifacts       DetailPageArtifact[]  @relation("DetailPageArtifactContentWorkspace")
  productPreparations       ProductPreparation[]  @relation("ProductPreparationContentWorkspace")
  thumbnailGenerations      ThumbnailGeneration[] @relation("ThumbnailGenerationContentWorkspace")
  thumbnailSelections       ContentWorkspaceThumbnailSelection[] @relation("ContentWorkspaceThumbnailSelections")
  sourceProductPreparations ProductPreparation[]  @relation("ProductPreparationSourceContentWorkspace")
  contentGenerationGroups   ContentGenerationGroup[]

  @@unique([organizationId, ownerType, normalizedTitle], map: "content_workspaces_direct_title_unique", where: raw("owner_type = 'direct_detail_page' AND source_candidate_id IS NULL AND target_master_id IS NULL AND status = 'active' AND is_deleted = false"))
  @@unique([organizationId, sourceCandidateId, normalizedTitle], map: "content_workspaces_candidate_title_unique", where: raw("source_candidate_id IS NOT NULL AND status = 'active' AND is_deleted = false"))
  @@unique([organizationId, sourceCandidateId], map: "content_workspaces_candidate_active_key", where: raw("source_candidate_id IS NOT NULL AND status = 'active' AND is_deleted = false"))
  @@unique([organizationId, targetMasterId, normalizedTitle], map: "content_workspaces_master_title_unique", where: raw("target_master_id IS NOT NULL AND status = 'active' AND is_deleted = false"))
  @@unique([organizationId, channelListingId], map: "content_workspaces_listing_active_key", where: raw("channel_listing_id IS NOT NULL AND status = 'active' AND is_deleted = false"))
  @@unique([id, organizationId], map: "content_workspaces_id_org_key")
  @@unique([currentThumbnailSelectionId, organizationId], map: "content_workspaces_current_thumbnail_key", where: raw("current_thumbnail_selection_id IS NOT NULL"))
  @@index([organizationId])
  @@index([sourceCandidateId])
  @@index([targetMasterId])
  @@index([channelListingId])
  @@index([originWorkspaceId])
  @@index([currentDetailPageArtifactId])
  @@index([currentDetailPageRevisionId])
  @@index([currentThumbnailSelectionId])
  @@index([createdByUserId])
  @@index([organizationId, status, isDeleted])
  @@index([organizationId, normalizedTitle, status, isDeleted])
  @@index([organizationId, ownerType, normalizedTitle, status, isDeleted])
  @@index([organizationId, sourceCandidateId, status, isDeleted])
  @@index([organizationId, targetMasterId, status, isDeleted])
  @@map("content_workspaces")
}

/// @namespace AI
/// @describe Stable workspace-owned thumbnail adoption with optional generation provenance.
model ContentWorkspaceThumbnailSelection {
  id                          String   @id @default(uuid()) @db.Uuid
  organizationId              String   @map("organization_id") @db.Uuid
  contentWorkspaceId          String   @map("content_workspace_id") @db.Uuid
  contentAssetId              String   @map("content_asset_id") @db.Uuid
  sourceThumbnailGenerationId String?  @map("source_thumbnail_generation_id") @db.Uuid
  sourceThumbnailCandidateId  String?  @map("source_thumbnail_candidate_id") @db.Uuid
  createdByUserId             String?  @map("created_by_user_id") @db.Uuid
  createdAt                   DateTime @default(now()) @map("created_at") @db.Timestamptz

  organization       Organization                 @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contentWorkspace   ContentWorkspace             @relation("ContentWorkspaceThumbnailSelections", fields: [contentWorkspaceId, organizationId], references: [id, organizationId], onDelete: Cascade)
  contentAsset       ContentAsset                 @relation(fields: [contentAssetId, organizationId], references: [id, organizationId], onDelete: Restrict)
  sourceGeneration   ThumbnailGeneration?         @relation("ContentWorkspaceThumbnailSelectionGeneration", fields: [sourceThumbnailGenerationId, organizationId], references: [id, organizationId], onDelete: Restrict)
  sourceCandidate    ThumbnailGenerationCandidate? @relation("ContentWorkspaceThumbnailSelectionCandidate", fields: [sourceThumbnailCandidateId, organizationId], references: [id, organizationId], onDelete: Restrict)
  createdByUser      User?                        @relation("ContentWorkspaceThumbnailSelectionCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  currentForWorkspace ContentWorkspace?           @relation("ContentWorkspaceCurrentThumbnail")

  @@unique([id, organizationId], map: "content_workspace_thumbnail_selections_id_org_key")
  @@index([organizationId])
  @@index([contentWorkspaceId])
  @@index([contentAssetId])
  @@index([sourceThumbnailGenerationId])
  @@index([sourceThumbnailCandidateId])
  @@map("content_workspace_thumbnail_selections")
}

/// @namespace AI
/// @describe Product pipeline preparation state. Stores operator-confirmed registration inputs and selected generated assets before marketplace listing.
model ProductPreparation {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @map("organization_id") @db.Uuid

  sourceCandidateId  String? @map("source_candidate_id") @db.Uuid
  masterId           String? @map("master_id") @db.Uuid
  contentWorkspaceId String? @map("content_workspace_id") @db.Uuid
  channelAccountId   String? @map("channel_account_id") @db.Uuid
  sourceContentWorkspaceId String? @map("source_content_workspace_id") @db.Uuid
  channelListingId   String? @map("channel_listing_id") @db.Uuid

  displayName        String    @map("display_name")
  status             String    @default("draft")
  isCurrentForMaster Boolean   @default(false) @map("is_current_for_master")
  appliedToMasterAt  DateTime? @map("applied_to_master_at") @db.Timestamptz

  selectedThumbnailUrl                   String? @map("selected_thumbnail_url")
  selectedThumbnailGenerationId          String? @map("selected_thumbnail_generation_id") @db.Uuid
  selectedThumbnailGenerationCandidateId String? @map("selected_thumbnail_generation_candidate_id") @db.Uuid
  selectedDetailPageArtifactId           String? @map("selected_detail_page_artifact_id") @db.Uuid
  selectedDetailPageRevisionId           String? @map("selected_detail_page_revision_id") @db.Uuid
  selectedDetailPageGenerationId         String? @map("selected_detail_page_generation_id") @db.Uuid

  registrationInput Json @default("{}") @map("registration_input")
  submissionKey        String? @map("submission_key")
  providerSubmissionId String? @map("provider_submission_id")
  lastError            String? @map("last_error")
  registrationResult   Json?   @map("registration_result")
  submissionPayloadJson Json?  @map("submission_payload_json")
  submissionPayloadHash String? @map("submission_payload_hash")
  providerOutcome        String? @map("provider_outcome")
  submissionLeaseToken   String? @map("submission_lease_token") @db.Uuid
  submissionLeaseClaimedAt DateTime? @map("submission_lease_claimed_at") @db.Timestamptz

  createdByUserId String?   @map("created_by_user_id") @db.Uuid
  isDeleted       Boolean   @default(false) @map("is_deleted")
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization                         Organization                  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sourceCandidate                      SourcingCandidate?            @relation(fields: [sourceCandidateId, organizationId], references: [id, organizationId], onDelete: Restrict)
  master                               MasterProduct?                @relation(fields: [masterId, organizationId], references: [id, organizationId], onDelete: Restrict)
  contentWorkspace                     ContentWorkspace?             @relation("ProductPreparationContentWorkspace", fields: [contentWorkspaceId, organizationId], references: [id, organizationId], onDelete: Restrict)
  channelAccount                       ChannelAccount?                @relation(fields: [channelAccountId, organizationId], references: [id, organizationId], onDelete: Restrict)
  sourceContentWorkspace               ContentWorkspace?             @relation("ProductPreparationSourceContentWorkspace", fields: [sourceContentWorkspaceId, organizationId], references: [id, organizationId], onDelete: Restrict)
  channelListing                       ChannelListing?                @relation(fields: [channelListingId, organizationId], references: [id, organizationId], onDelete: Restrict)
  selectedDetailPageArtifact           DetailPageArtifact?           @relation("ProductPreparationSelectedDetailPageArtifact", fields: [selectedDetailPageArtifactId, organizationId], references: [id, organizationId], onDelete: Restrict)
  selectedDetailPageRevision           DetailPageRevision?           @relation("ProductPreparationSelectedDetailPageRevision", fields: [selectedDetailPageRevisionId, organizationId], references: [id, organizationId], onDelete: Restrict)
  selectedDetailPageGeneration         ContentGeneration?            @relation("ProductPreparationSelectedDetailPageGeneration", fields: [selectedDetailPageGenerationId, organizationId], references: [id, organizationId], onDelete: Restrict)
  selectedThumbnailGeneration          ThumbnailGeneration?          @relation("ProductPreparationSelectedThumbnailGeneration", fields: [selectedThumbnailGenerationId, organizationId], references: [id, organizationId], onDelete: Restrict)
  selectedThumbnailGenerationCandidate ThumbnailGenerationCandidate? @relation("ProductPreparationSelectedThumbnailGenerationCandidate", fields: [selectedThumbnailGenerationCandidateId, organizationId], references: [id, organizationId], onDelete: Restrict)
  createdByUser                        User?                         @relation("ProductPreparationCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@unique([organizationId, sourceCandidateId], map: "product_preparations_org_source_candidate_active_key", where: raw("source_candidate_id IS NOT NULL AND is_deleted = false"))
  @@unique([organizationId, masterId], map: "product_preparations_org_master_current_key", where: raw("master_id IS NOT NULL AND is_current_for_master = true AND is_deleted = false"))
  @@unique([organizationId, sourceCandidateId, channelAccountId], map: "product_preparations_org_source_account_active_key", where: raw("source_candidate_id IS NOT NULL AND channel_account_id IS NOT NULL AND status = ANY (ARRAY['draft'::text, 'submitting'::text, 'failed'::text]) AND is_deleted = false"))
  @@unique([organizationId, submissionKey], map: "product_preparations_org_submission_key", where: raw("submission_key IS NOT NULL"))
  @@index([organizationId, status, isDeleted])
  @@index([sourceCandidateId])
  @@index([masterId])
  @@index([organizationId, masterId, isDeleted])
  @@index([organizationId, masterId, isCurrentForMaster, isDeleted])
  @@index([contentWorkspaceId])
  @@index([channelAccountId])
  @@index([sourceContentWorkspaceId])
  @@index([channelListingId])
  @@index([selectedDetailPageArtifactId])
  @@index([selectedDetailPageRevisionId])
  @@index([selectedDetailPageGenerationId])
  @@index([selectedThumbnailGenerationId])
  @@index([selectedThumbnailGenerationCandidateId])
  @@index([createdByUserId])
  @@map("product_preparations")
}

/// @namespace AI
/// @describe Append-only detail-page HTML revision. Editor saves create rows; DetailPageArtifact.currentRevisionId selects the active version.
model DetailPageRevision {
  id                  String  @id @default(uuid()) @db.Uuid
  organizationId      String  @map("organization_id") @db.Uuid
  artifactId          String  @map("artifact_id") @db.Uuid
  contentGenerationId String? @map("content_generation_id") @db.Uuid
  revisionType        String  @default("manual_edit") @map("revision_type")
  html                String  @db.Text
  assetUrlMap         Json    @default("{}") @map("asset_url_map")
  imageUrls           Json    @default("[]") @map("image_urls")
  createdByUserId     String? @map("created_by_user_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  organization                   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  artifact                       DetailPageArtifact   @relation("DetailPageArtifactRevisions", fields: [artifactId], references: [id], onDelete: Cascade)
  contentGeneration              ContentGeneration?   @relation("DetailPageRevisionContentGeneration", fields: [contentGenerationId], references: [id], onDelete: SetNull)
  createdByUser                  User?                @relation("DetailPageRevisionCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  currentForArtifacts            DetailPageArtifact[] @relation("DetailPageArtifactCurrentRevision")
  currentForContentWorkspaces    ContentWorkspace[]   @relation("ContentWorkspaceCurrentRevision")
  selectedForProductPreparations ProductPreparation[] @relation("ProductPreparationSelectedDetailPageRevision")

  @@unique([id, organizationId], map: "detail_page_revisions_id_org_key")
  @@index([organizationId])
  @@index([artifactId])
  @@index([contentGenerationId])
  @@index([createdByUserId])
  @@index([organizationId, artifactId])
  @@index([artifactId, createdAt])
  @@map("detail_page_revisions")
}

/// @namespace AI
/// @describe Same-input generation group. Product-less groups are standalone generated-content workspaces; product-bound groups remain candidate lineage inside a Master workspace.
model ContentGenerationGroup {
  id                      String  @id @default(uuid()) @db.Uuid
  organizationId          String  @map("organization_id") @db.Uuid
  groupType               String  @default("input_variation") @map("group_type")
  targetMasterId          String? @map("target_master_id") @db.Uuid
  contentWorkspaceId      String? @map("content_workspace_id") @db.Uuid
  baseContentGenerationId String? @map("base_content_generation_id") @db.Uuid
  title                   String?
  inputFingerprint        String? @map("input_fingerprint")
  metadata                Json    @default("{}")
  createdByUserId         String? @map("created_by_user_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization          Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  targetMaster          MasterProduct?      @relation(fields: [targetMasterId], references: [id], onDelete: SetNull)
  contentWorkspace      ContentWorkspace?   @relation(fields: [contentWorkspaceId, organizationId], references: [id, organizationId], onDelete: Restrict)
  baseContentGeneration ContentGeneration?  @relation("ContentGenerationGroupBase", fields: [baseContentGenerationId], references: [id], onDelete: SetNull)
  generations           ContentGeneration[] @relation("ContentGenerationGroupMembers")
  assets                ContentAsset[]      @relation("ContentAssetGenerationGroup")
  originatingAssets     ContentAsset[]      @relation("ContentAssetOriginGenerationGroup")

  @@unique([organizationId, targetMasterId], map: "content_generation_groups_product_workspace_unique", where: raw("target_master_id IS NOT NULL AND group_type = 'product_workspace'"))
  @@index([organizationId])
  @@index([organizationId, groupType])
  @@index([organizationId, targetMasterId])
  @@unique([id, organizationId], map: "content_generation_groups_id_org_key")
  @@index([contentWorkspaceId])
  @@index([baseContentGenerationId])
  @@index([inputFingerprint])
  @@map("content_generation_groups")
}

/// @namespace AI
/// @describe Generation-level provenance. The source of a generated work unit can be a sourcing candidate, input asset, or another generation.
model ContentGenerationSource {
  id                  String @id @default(uuid()) @db.Uuid
  organizationId      String @map("organization_id") @db.Uuid
  contentGenerationId String @map("content_generation_id") @db.Uuid

  sourceType                String  @map("source_type")
  sourceCandidateId         String? @map("source_candidate_id") @db.Uuid
  sourceContentGenerationId String? @map("source_content_generation_id") @db.Uuid
  contentAssetId            String? @map("content_asset_id") @db.Uuid
  label                     String?
  sortOrder                 Int     @default(0) @map("sort_order")
  metadata                  Json    @default("{}")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization            Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contentGeneration       ContentGeneration  @relation("ContentGenerationSources", fields: [contentGenerationId], references: [id], onDelete: Cascade)
  sourceCandidate         SourcingCandidate? @relation(fields: [sourceCandidateId], references: [id], onDelete: SetNull)
  sourceContentGeneration ContentGeneration? @relation("ContentGenerationDerivedSources", fields: [sourceContentGenerationId], references: [id], onDelete: SetNull)
  contentAsset            ContentAsset?      @relation(fields: [contentAssetId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([contentGenerationId])
  @@index([organizationId, contentGenerationId])
  @@index([organizationId, sourceType])
  @@index([sourceCandidateId])
  @@index([organizationId, sourceCandidateId])
  @@index([sourceContentGenerationId])
  @@index([contentAssetId])
  @@map("content_generation_sources")
}

/// @namespace AI
/// @describe Generated/editable media workspace asset. Product gallery adoption copies selected rows into MasterProductImage.
model ContentAsset {
  id                String  @id @default(uuid()) @db.Uuid
  organizationId    String  @map("organization_id") @db.Uuid
  generationGroupId String  @map("generation_group_id") @db.Uuid
  originGenerationGroupId String? @map("origin_generation_group_id") @db.Uuid
  createdByUserId   String? @map("created_by_user_id") @db.Uuid

  assetKey   String  @map("asset_key")
  url        String
  storageKey String? @map("storage_key")
  assetType  String  @default("image") @map("asset_type")
  role       String?
  label      String?
  sortOrder  Int     @default(0) @map("sort_order")

  mimeType String? @map("mime_type")
  width    Int?
  height   Int?
  fileSize Int?    @map("file_size")
  metadata Json    @default("{}")

  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization      Organization                  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  generationGroup   ContentGenerationGroup        @relation("ContentAssetGenerationGroup", fields: [generationGroupId], references: [id], onDelete: Cascade)
  originGenerationGroup ContentGenerationGroup?   @relation("ContentAssetOriginGenerationGroup", fields: [originGenerationGroupId, organizationId], references: [id, organizationId], onDelete: Restrict)
  createdByUser     User?                         @relation("ContentAssetCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  usages            ContentGenerationAssetUsage[]
  generationSources ContentGenerationSource[]
  thumbnailSelections ContentWorkspaceThumbnailSelection[]

  @@unique([organizationId, assetKey])
  @@unique([id, organizationId], map: "content_assets_id_org_key")
  @@index([organizationId])
  @@index([generationGroupId])
  @@index([originGenerationGroupId])
  @@index([createdByUserId])
  @@index([organizationId, assetType])
  @@index([organizationId, generationGroupId])
  @@map("content_assets")
}

/// @namespace AI
/// @describe Current image assets used by a generated content row. Asset location stays on ContentAsset; this table is the replace-on-save usage set.
model ContentGenerationAssetUsage {
  id                  String @id @default(uuid()) @db.Uuid
  organizationId      String @map("organization_id") @db.Uuid
  contentGenerationId String @map("content_generation_id") @db.Uuid
  contentAssetId      String @map("content_asset_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contentGeneration ContentGeneration @relation(fields: [contentGenerationId], references: [id], onDelete: Cascade)
  contentAsset      ContentAsset      @relation(fields: [contentAssetId], references: [id], onDelete: Cascade)

  @@unique([contentGenerationId, contentAssetId])
  @@index([organizationId])
  @@index([contentGenerationId])
  @@index([contentAssetId])
  @@index([organizationId, contentGenerationId])
  @@map("content_generation_asset_usages")
}
