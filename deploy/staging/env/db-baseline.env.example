# Load this only in an operator shell or GitHub Environment secret/variable set.
# Never commit a filled copy. Restore/export commands are destructive or
# sensitive and must target the dedicated staging DB only.

STAGING_DB_BASELINE_TARGET=staging
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<pooler-host>:5432/postgres
STAGING_DB_BASELINE_SANITIZED=true

# Supabase Storage S3-compatible endpoint for a private bucket dedicated to DB
# baseline artifacts. Do not reuse the public app asset bucket.
STAGING_DB_BASELINE_BUCKET=kiditem-staging-db-baselines
STAGING_DB_BASELINE_S3_ENDPOINT=https://<project-ref>.storage.supabase.co/storage/v1/s3
STAGING_DB_BASELINE_S3_REGION=ap-northeast-2
STAGING_DB_BASELINE_S3_ACCESS_KEY=<supabase-storage-s3-access-key-id>
STAGING_DB_BASELINE_S3_SECRET_KEY=<supabase-storage-s3-secret-access-key>

# Immutable object prefix. The CLI writes:
#   <prefix>/<profileId>/public.dump.pgcustom
#   <prefix>/<profileId>/manifest.json
#   <prefix>/<profileId>/checksums.sha256
STAGING_DB_BASELINE_PREFIX=staging-db-baselines
STAGING_DB_BASELINE_PROFILE_ID=staging-smoke-YYYY-MM-DD-v1

# Optional when running on EC2. GitHub Actions copies the emitted record to this
# shape on the staging host after export/restore.
STAGING_DB_BASELINE_RECORD_DIR=/opt/kiditem/deployments
