# Staging/prod leave this empty. The edge nginx routes /api/* to NestJS.
NEXT_PUBLIC_API_URL=

# Supabase browser client for the project used by this environment. The first
# staging rollout may reuse the current dev Supabase project.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<staging-supabase-publishable-key>
