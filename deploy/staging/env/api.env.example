NODE_ENV=production
PORT=4000

# Supabase project used by this environment. The first staging rollout may reuse
# the current dev Supabase project, but a dedicated staging project is safer once
# real QA begins. On IPv4-only EC2 hosts, prefer Supabase's session pooler
# string from Dashboard -> Connect -> ORM/Prisma. The host can be aws-0/1/etc.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<pooler-host>:5432/postgres
DIRECT_URL=postgresql://postgres.<project-ref>:<password>@<pooler-host>:5432/postgres
SUPABASE_URL=https://<project-ref>.supabase.co

# Set to the public staging origin. Same-origin browser calls do not require
# CORS, but explicit allowlisting protects extension/admin/API-only callers.
CORS_ORIGINS=https://staging.example.com

# Supabase Storage via the S3-compatible endpoint.
# Generate S3 access keys from Supabase Dashboard -> Storage -> Configuration -> S3.
# The access key pair is server-only and bypasses Storage RLS.
S3_REGION=ap-northeast-2
S3_BUCKET=kiditem-staging-assets
S3_ENDPOINT=https://<project-ref>.storage.supabase.co/storage/v1/s3
S3_PUBLIC_URL=https://<project-ref>.supabase.co/storage/v1/object/public/kiditem-staging-assets
S3_ACCESS_KEY=<supabase-storage-s3-access-key-id>
S3_SECRET_KEY=<supabase-storage-s3-secret-access-key>

# Provider/model secrets used by server-side agents and workflows.
OPENAI_API_KEY=<openai-api-key>
