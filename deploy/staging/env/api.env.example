NODE_ENV=production
PORT=4000

# Keep this file to the variables required by the currently enabled staging API
# runtime and to safe staging verification examples. Populate optional Agent OS,
# Claude, or Python-agent runtime values only when that runtime is intentionally
# enabled; see docs/runbooks/environment-variables.md for the full catalog.

# Supabase project used by this environment. The first staging rollout may reuse
# the current dev Supabase project, but a dedicated staging project is safer once
# real QA begins. On IPv4-only EC2 hosts, prefer Supabase's session pooler
# string from Dashboard -> Connect -> ORM/Prisma. The host can be aws-0/1/etc.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<pooler-host>:5432/postgres
SUPABASE_URL=https://<project-ref>.supabase.co
SOURCING_EXTENSION_TOKEN_SECRET=<random-secret>
SOURCING_EXTENSION_TOKEN_TTL_SECONDS=1800
SOURCING_EXTENSION_TOKEN_MAX_SECONDS=86400

# Set to the public staging origin. Same-origin browser calls do not require
# CORS, but explicit allowlisting protects extension/admin/API-only callers.
CORS_ORIGINS=https://staging.example.com

# Supabase Storage via the S3-compatible endpoint.
# Generate S3 access keys from Supabase Dashboard -> Storage -> Configuration -> S3.
# The access key pair is server-only and bypasses Storage RLS.
S3_REGION=ap-northeast-2
S3_BUCKET=kiditem-staging-assets
S3_ENDPOINT=https://<project-ref>.storage.supabase.co/storage/v1/s3
S3_PUBLIC_URL=https://<project-ref>.supabase.co/storage/v1/object/public/kiditem-staging-assets
S3_ACCESS_KEY=<supabase-storage-s3-access-key-id>
S3_SECRET_KEY=<supabase-storage-s3-secret-access-key>

# Channel credentials encryption key — required for storing/decrypting channel
# account credentials. Generate with: openssl rand -base64 32
CHANNEL_CREDENTIALS_ENCRYPTION_KEY=<32-byte-base64-or-hex-key>

# Server-side Naver SearchAd keyword research. Optional until the sourcing
# rising-keyword workflow is enabled. Do not expose these in NEXT_PUBLIC env.
NAVER_DATALAB_CLIENT_ID=<naver-datalab-client-id>
NAVER_DATALAB_CLIENT_SECRET=<naver-datalab-client-secret>
NAVER_DATALAB_BASE_URL=https://openapi.naver.com
NAVER_DATALAB_WEB_BASE_URL=https://datalab.naver.com
NAVER_SEARCHAD_API_KEY=<naver-searchad-api-key>
NAVER_SEARCHAD_SECRET_KEY=<naver-searchad-secret-key>
NAVER_SEARCHAD_CUSTOMER_ID=<naver-searchad-customer-id>
NAVER_SEARCHAD_BASE_URL=https://api.searchad.naver.com

# Server-side 1688 image search via TMAPI. Optional until the wholesale
# Coupang-image matching workflow is enabled.
TMAPI_TOKEN=<tmapi-token>
TMAPI_BASE_URL=https://api.tmapi.top

# Optional managed browser endpoint for sourcing. When set, the Sourcing
# Playwright runtime attaches to this logged-in CDP browser before launching a
# new automation profile.
SOURCING_PLAYWRIGHT_CDP_ENDPOINT=<managed-browser-cdp-endpoint>

# Server-side Gemini AI used by current API text/detail/thumbnail/image-edit features.
GEMINI_API_KEY=<gemini-api-key>
AI_TEXT_MODEL=gemini-2.5-flash
AI_IMAGE_MODEL=gemini-3.1-flash-image-preview
AI_IMAGE_ANALYSIS_MODEL=gemini-3.1-flash-lite-preview
AI_IMAGE_ANALYSIS_VERIFY_MODEL=gemini-3.1-flash-lite-preview

# Agent OS manages only registered Agent definitions. Detail page,
# thumbnail, and image-edit generation are direct AI jobs and use the
# AI_* models above. The Hermes values below are optional staging verification
# settings; omit AGENT_OS_OPERATOR_RUNTIME or replace it when Hermes is not
# intentionally enabled.
AGENT_RUNTIME_WORKER_ENABLED=1
AGENT_DEFAULT_MODEL=gemini-2.5-flash
AGENT_OS_OPERATOR_RUNTIME=
AGENT_OS_HERMES_PATH=
AGENT_OS_HERMES_MODEL=
AGENT_OS_HERMES_HOME=
AGENT_OS_HERMES_TIMEOUT_MS=
AGENT_OS_HERMES_MAX_OUTPUT_BYTES=
AGENT_OS_HERMES_MAX_CONCURRENT_RUNS=
AGENT_OS_HERMES_ENABLE_KIDITEM_MCP=false
