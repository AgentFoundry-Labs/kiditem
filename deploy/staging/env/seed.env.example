# Load this only in an operator shell, never in docker compose. If staging reuses
# the shared dev Supabase project, do not run destructive reset commands.
# Use the Supabase session pooler on IPv4-only operator/EC2 networks.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<pooler-host>:5432/postgres
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SECRET_KEY=<staging-supabase-service-role-or-secret-key>

# Google Drive dev data root that stores pinned bundle profiles.
KIDITEM_DEV_DATA_DRIVE_DIR=<google-drive-folder-id-or-path>
KIDITEM_API_URL=https://staging.example.com
KIDITEM_DEV_USER_ID=<staging-supabase-user-uuid>
KIDITEM_DEV_ORGANIZATION_ID=<staging-organization-uuid>
