NODE_ENV=production
PORT=4000

# Production must use resources separate from local development and staging.
# Keep this file to the variables required by the currently enabled production
# API runtime and API features. Add Agent OS/Claude/Python-agent variables only
# when those runtimes are intentionally launched in production.

# Supabase production project. On IPv4-only hosts, prefer Supabase's session
# pooler string from Dashboard -> Connect -> ORM/Prisma.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<pooler-host>:5432/postgres
SUPABASE_URL=https://<project-ref>.supabase.co

# Public production origins, comma-separated when multiple domains are active.
CORS_ORIGINS=https://app.example.com

# Supabase Storage via the S3-compatible endpoint.
# Generate production-only S3 access keys from Supabase Dashboard -> Storage ->
# Configuration -> S3. The access key pair is server-only and bypasses Storage
# RLS.
S3_REGION=ap-northeast-2
S3_BUCKET=kiditem-production-assets
S3_ENDPOINT=https://<project-ref>.storage.supabase.co/storage/v1/s3
S3_PUBLIC_URL=https://<project-ref>.supabase.co/storage/v1/object/public/kiditem-production-assets
S3_ACCESS_KEY=<supabase-storage-s3-access-key-id>
S3_SECRET_KEY=<supabase-storage-s3-secret-access-key>

# Channel credentials encryption key — required for storing/decrypting channel
# account credentials. Generate with: openssl rand -base64 32
CHANNEL_CREDENTIALS_ENCRYPTION_KEY=<32-byte-base64-or-hex-key>

# Server-side Gemini AI used by current API text/detail/thumbnail features.
GEMINI_API_KEY=<gemini-api-key>
AI_TEXT_MODEL=gemini-2.5-flash
AI_IMAGE_MODEL=gemini-3.1-flash-image
AI_IMAGE_ANALYSIS_MODEL=gemini-3.1-flash-lite
AI_IMAGE_ANALYSIS_VERIFY_MODEL=gemini-3.1-flash-lite
