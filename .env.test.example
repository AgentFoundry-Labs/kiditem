# .env.test — Integration test environment
#
# 사용: `docker compose -f docker-compose.test.yml` 로 기동한 격리 Postgres(5434) 대상.
# 로컬/CI 공통. 실제 시크릿 아님 — test DB 는 격리 tmpfs.
#
# 실행 시 DATABASE_URL 을 이 값으로 덮어써서 prisma db push / vitest integration 이 사용.
#
DATABASE_URL=postgresql://kiditem_test:kiditem_test@localhost:5434/kiditem_test
NODE_ENV=test

# DevAuthMiddleware default — 테스트용 고정 UUID (e2e/helpers/mock-prisma.ts 와 동일)
DEV_DEFAULT_USER_ID=f1234567-89ab-4cde-8f01-23456789abcd

# Prod 안전장치 우회 (NODE_ENV=test 이지만 혹시 모르니 명시)
ALLOW_DEV_AUTH_IN_PROD=false
