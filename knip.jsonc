{
  "$schema": "https://unpkg.com/knip@6/schema-jsonc.json",
  "workspaces": {
    ".": {
      "entry": [
        "package.json",
        "prisma.config.ts",
        "vitest.config.ts",
        "scripts/**/*.{ts,js,mjs,cjs,sh}",
        "prisma/**/*.{ts,js,mjs,cjs,sh}",
        "extensions/**/*.{js,mjs,cjs}"
      ],
      "project": [
        "*.{ts,js,mjs,cjs}",
        "scripts/**/*.{ts,js,mjs,cjs,sh}",
        "prisma/**/*.{ts,js,mjs,cjs,sh}",
        "extensions/**/*.{js,mjs,cjs}"
      ],
      "ignore": [
        "**/node_modules/**",
        "**/dist/**",
        "**/.next/**",
        "**/coverage/**",
        "graphify-out/**",
        "**/generated/**",
        "**/*.generated.*",
        ".claude/worktrees/**",
        ".codex/worktrees/**",
        ".worktrees/**",
        "worktrees/**",
        "tmp/**",
        "**/.turbo/**",
        "**/.cache/**",
        "prisma/init.sql.gz"
      ],
      // External Python uv CLI; npm "uv" is unrelated.
      // Other entries are workspace-hoisted binaries invoked from root npm scripts:
      //   prisma → root postinstall + db:* scripts
      //   concurrently → dev:all
      //   knip → knip:report
      //   tsx → import:product-baseline + data:dev:* scripts
      "ignoreBinaries": ["uv", "prisma", "concurrently", "knip", "tsx"],
      "ignoreDependencies": [
        // Provides script binaries used by root scripts (`dev:all`, `data:dev:*`,
        // `import:product-baseline`). Knip cannot link these to the script bins.
        "concurrently",
        "tsx"
        // NOTE: @types/better-sqlite3, better-sqlite3, and react remain unignored
        // because no script or source file consumes them. They are tracked as
        // removal candidates by the Phase 5 dependency purge plan.
      ]
    },
    "apps/server": {
      "entry": [
        "package.json",
        "src/main.ts",
        "src/app.module.ts",
        "src/**/*.module.ts",
        "src/**/__tests__/**/*.spec.ts",
        "e2e/**/*.ts",
        "vitest.config*.ts",
        "nest-cli.json"
      ],
      "project": [
        "src/**/*.ts",
        "e2e/**/*.ts",
        "*.config.ts",
        "nest-cli.json"
      ],
      "ignore": [
        "dist/**",
        "coverage/**"
      ],
      // Script-bin false positives: these binaries are invoked by package.json scripts
      // (build/start/lint/test) but knip does not link them across npm workspace hoisting.
      "ignoreBinaries": ["nest", "eslint", "vitest"],
      "ignoreDependencies": [
        // Required peer dependency for @copilotkit/runtime (>=0.3.66, non-optional).
        // Knip does not currently see this consumer because no source file imports
        // from @langchain/core directly — the runtime adapter pulls it as a peer.
        "@langchain/core",
        // Provides script binaries: nest (build/start), eslint (lint), prisma (generate).
        // Knip cannot link npm script binary invocations back to providing packages.
        "@nestjs/cli",
        "eslint",
        "prisma"
      ]
    },
    "apps/web": {
      "entry": [
        "package.json",
        "next.config.mjs",
        "src/app/**/{layout,page,template,loading,error,not-found,route}.{ts,tsx}",
        "src/app/**/*.spec.{ts,tsx}",
        "src/app/**/__tests__/**/*.{ts,tsx}",
        "src/components/**/*.{ts,tsx}",
        "src/hooks/**/*.{ts,tsx}",
        "src/lib/**/*.{ts,tsx}",
        "src/store/**/*.{ts,tsx}",
        "test/**/*.{ts,tsx}",
        "vitest.config.ts",
        "tailwind.config.ts",
        "postcss.config.mjs"
      ],
      "project": [
        "src/**/*.{ts,tsx}",
        "test/**/*.{ts,tsx}",
        "*.{ts,tsx,js,mjs,cjs}"
      ],
      "ignore": [
        ".next/**",
        "coverage/**"
      ],
      // Script-bin false positives: dev/build/lint/test scripts.
      "ignoreBinaries": ["next", "eslint", "vitest"],
      "ignoreDependencies": [
        // Required peer dependencies declared by upstream packages:
        //   react-is → recharts non-optional peer dep
        //   @testing-library/dom → @testing-library/react non-optional peer dep
        "react-is",
        "@testing-library/dom",
        // Provides eslint binary used by the lint script.
        "eslint"
        // NOTE: tsx is intentionally NOT ignored here — apps/web has no script that
        // invokes tsx, so it is a legitimate removal candidate tracked by the
        // Phase 5 dependency purge plan.
      ]
    },
    "packages/shared": {
      "entry": [
        "package.json",
        "src/index.ts",
        "src/schemas/index.ts",
        "src/{product,order,inventory,ai,advertising}.ts",
        "src/errors/index.ts",
        "src/security/index.ts",
        "src/**/*.spec.ts",
        "vitest.config.ts",
        "tsup.config.ts"
      ],
      "project": [
        "src/**/*.ts",
        "*.config.ts"
      ],
      "ignore": [
        "dist/**",
        "coverage/**"
      ],
      // Build-tool binaries used by scripts (build/dev/type-check).
      "ignoreBinaries": ["tsup", "tsc"]
    },
    "packages/templates": {
      "entry": [
        "package.json",
        "src/index.ts",
        "src/scripts/generate-json-schema.ts",
        "tsup.config.ts"
      ],
      "project": [
        "src/**/*.ts",
        "*.config.ts"
      ],
      "ignore": [
        "dist/**",
        "coverage/**"
      ],
      // Script-bin false positives:
      //   tsup, tsc → build/dev/type-check
      //   tailwindcss → build:css (provided by @tailwindcss/cli)
      //   tsx → generate:schema
      "ignoreBinaries": ["tsup", "tsc", "tailwindcss", "tsx"],
      "ignoreDependencies": [
        // Provides the tailwindcss binary invoked by `build:css`.
        "@tailwindcss/cli",
        // Provides the tsx binary invoked by `generate:schema`.
        "tsx"
      ]
    }
  }
}
