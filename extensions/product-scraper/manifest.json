{
  "manifest_version": 3,
  "name": "Auto-Seller Product Scraper",
  "version": "2.2.1",
  "description": "이커머스 상품·중국 라이브 방송 데이터 추출 (Alibaba, 1688, Douyin)",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "externally_connectable": {
    "matches": [
      "http://localhost:3000/*",
      "https://staging.merchon.org/*"
    ]
  },
  "host_permissions": [
    "https://www.alibaba.com/*",
    "https://korean.alibaba.com/*",
    "https://*.alibaba.com/*",
    "https://*.1688.com/*",
    "https://*.douyin.com/*",
    "https://*.jinritemai.com/*",
    "https://itemcdn.tmall.com/*",
    "http://localhost:3000/*",
    "https://staging.merchon.org/*",
    "http://localhost:4000/*",
    "http://127.0.0.1:4000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.alibaba.com/*",
        "https://korean.alibaba.com/*",
        "https://*.alibaba.com/*",
        "https://*.1688.com/*"
      ],
      "js": [
        "extractors/common.js",
        "extractors/alibaba.js",
        "extractors/1688.js",
        "content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.alibaba.com/*",
        "https://korean.alibaba.com/*",
        "https://*.alibaba.com/*"
      ],
      "js": ["extractors/page-bridge.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://*.1688.com/*"
      ],
      "js": ["extractors/1688-bridge.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://*.1688.com/*",
        "https://*.douyin.com/*"
      ],
      "js": [
        "live-commerce-extractor.js",
        "live-commerce-content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://localhost:3000/*",
        "https://staging.merchon.org/*"
      ],
      "js": ["host-bridge.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Product Scraper"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
