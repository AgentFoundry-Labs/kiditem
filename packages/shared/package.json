{
  "name": "@kiditem/shared",
  "private": true,
  "version": "0.1.0",
  "description": "Shared Zod schemas and TypeScript types for KidItem",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.ts",
      "import": "./dist/schemas/index.js",
      "require": "./dist/schemas/index.cjs"
    },
    "./product": {
      "types": "./dist/product.d.ts",
      "import": "./dist/product.js",
      "require": "./dist/product.cjs"
    },
    "./order": {
      "types": "./dist/order.d.ts",
      "import": "./dist/order.js",
      "require": "./dist/order.cjs"
    },
    "./inventory": {
      "types": "./dist/inventory.d.ts",
      "import": "./dist/inventory.js",
      "require": "./dist/inventory.cjs"
    },
    "./ai": {
      "types": "./dist/ai.d.ts",
      "import": "./dist/ai.js",
      "require": "./dist/ai.cjs"
    },
    "./advertising": {
      "types": "./dist/advertising.d.ts",
      "import": "./dist/advertising.js",
      "require": "./dist/advertising.cjs"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "import": "./dist/errors/index.js",
      "require": "./dist/errors/index.cjs"
    },
    "./security": {
      "types": "./dist/security/index.d.ts",
      "import": "./dist/security/index.js",
      "require": "./dist/security/index.cjs"
    },
    "./internal/*": null
  },
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "schemas": ["dist/schemas/index.d.ts"],
      "product": ["dist/product.d.ts"],
      "order": ["dist/order.d.ts"],
      "inventory": ["dist/inventory.d.ts"],
      "ai": ["dist/ai.d.ts"],
      "advertising": ["dist/advertising.d.ts"],
      "errors": ["dist/errors/index.d.ts"],
      "security": ["dist/security/index.d.ts"]
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.25.0"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nestjs/common": "^11.0.0",
    "tsup": "^8.5.1",
    "typescript": "~5.8.3"
  }
}
