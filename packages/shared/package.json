{
  "name": "@kiditem/shared",
  "private": true,
  "version": "0.1.0",
  "description": "Shared Zod schemas and TypeScript types for KidItem",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.ts",
      "import": "./dist/schemas/index.js",
      "require": "./dist/schemas/index.cjs"
    },
    "./product": {
      "types": "./dist/product.d.ts",
      "import": "./dist/product.js",
      "require": "./dist/product.cjs"
    },
    "./order": {
      "types": "./dist/order.d.ts",
      "import": "./dist/order.js",
      "require": "./dist/order.cjs"
    },
    "./inventory": {
      "types": "./dist/inventory.d.ts",
      "import": "./dist/inventory.js",
      "require": "./dist/inventory.cjs"
    },
    "./ai": {
      "types": "./dist/ai.d.ts",
      "import": "./dist/ai.js",
      "require": "./dist/ai.cjs"
    },
    "./advertising": {
      "types": "./dist/advertising.d.ts",
      "import": "./dist/advertising.js",
      "require": "./dist/advertising.cjs"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "import": "./dist/errors/index.js",
      "require": "./dist/errors/index.cjs"
    },
    "./server-errors": {
      "types": "./dist/server-errors.d.ts",
      "import": "./dist/server-errors.js",
      "require": "./dist/server-errors.cjs"
    },
    "./security": {
      "types": "./dist/security/index.d.ts",
      "import": "./dist/security/index.js",
      "require": "./dist/security/index.cjs"
    },
    "./panel": {
      "types": "./dist/panel/index.d.ts",
      "import": "./dist/panel/index.js",
      "require": "./dist/panel/index.cjs"
    },
    "./dashboard": {
      "types": "./dist/dashboard.d.ts",
      "import": "./dist/dashboard.js",
      "require": "./dist/dashboard.cjs"
    },
    "./finance": {
      "types": "./dist/finance.d.ts",
      "import": "./dist/finance.js",
      "require": "./dist/finance.cjs"
    },
    "./marketplace": {
      "types": "./dist/marketplace.d.ts",
      "import": "./dist/marketplace.js",
      "require": "./dist/marketplace.cjs"
    },
    "./rules": {
      "types": "./dist/rules.d.ts",
      "import": "./dist/rules.js",
      "require": "./dist/rules.cjs"
    },
    "./action-task": {
      "types": "./dist/action-task.d.ts",
      "import": "./dist/action-task.js",
      "require": "./dist/action-task.cjs"
    },
    "./supplier-stats": {
      "types": "./dist/supplier-stats.d.ts",
      "import": "./dist/supplier-stats.js",
      "require": "./dist/supplier-stats.cjs"
    },
    "./channel-dashboard": {
      "types": "./dist/channel-dashboard.d.ts",
      "import": "./dist/channel-dashboard.js",
      "require": "./dist/channel-dashboard.cjs"
    },
    "./internal/*": null
  },
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "schemas": ["dist/schemas/index.d.ts"],
      "product": ["dist/product.d.ts"],
      "order": ["dist/order.d.ts"],
      "inventory": ["dist/inventory.d.ts"],
      "ai": ["dist/ai.d.ts"],
      "advertising": ["dist/advertising.d.ts"],
      "errors": ["dist/errors/index.d.ts"],
      "server-errors": ["dist/server-errors.d.ts"],
      "security": ["dist/security/index.d.ts"],
      "panel": ["dist/panel/index.d.ts"],
      "dashboard": ["dist/dashboard.d.ts"],
      "finance": ["dist/finance.d.ts"],
      "marketplace": ["dist/marketplace.d.ts"],
      "rules": ["dist/rules.d.ts"],
      "action-task": ["dist/action-task.d.ts"],
      "supplier-stats": ["dist/supplier-stats.d.ts"],
      "channel-dashboard": ["dist/channel-dashboard.d.ts"]
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.25.0"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nestjs/common": "^11.0.0",
    "tsup": "^8.5.1",
    "typescript": "~5.8.3",
    "vitest": "^4.1.2"
  }
}
