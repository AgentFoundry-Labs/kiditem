{
  "name": "@kiditem/templates",
  "private": true,
  "version": "0.1.0",
  "description": "Shared detail page templates — React components + Zod schemas",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && npm run build:css",
    "build:css": "node scripts/build-css.mjs",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "generate:schema": "tsx src/scripts/generate-json-schema.ts"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "react-icons": "^5.6.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "@tailwindcss/oxide": "4.2.2",
    "@types/react": "^19.0.0",
    "esbuild": "^0.27.7",
    "react": "^19.0.0",
    "tailwindcss": "^4.2.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "~5.8.3",
    "zod-to-json-schema": "^3.25.1"
  }
}
