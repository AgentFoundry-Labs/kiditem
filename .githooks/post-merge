#!/bin/sh
#
# Post-merge hook: warn when DB schema or shared types changed.
# Runs after git pull/merge.
#

CHANGED=$(git diff-tree -r --name-only ORIG_HEAD HEAD)

NEED_SYNC=0
NEED_PRISMA=0
NEED_SHARED=0
NEED_DATA_MIGRATIONS=0

if echo "$CHANGED" | grep -Eq "^(prisma/schema\.prisma|prisma/models/|prisma\.config\.ts)"; then
  echo ""
  echo "⚠️  Prisma schema 변경됨 → npm run db:push + npx prisma generate 필요"
  NEED_SYNC=1
  NEED_PRISMA=1
fi

if echo "$CHANGED" | grep -q "packages/shared/"; then
  echo "⚠️  packages/shared/ 변경됨 → npm run build -w packages/shared 필요"
  NEED_SYNC=1
  NEED_SHARED=1
fi

if echo "$CHANGED" | grep -q "prisma/init.sql.gz"; then
  echo "ℹ️  prisma/init.sql.gz 갱신됨 → fresh-volume snapshot 이 필요한 경우에만 사용하세요."
fi

if echo "$CHANGED" | grep -q "scripts/data-migrations/"; then
  echo "⚠️  release data migration 변경됨 → 로컬 DB ledger/status 확인 필요"
  NEED_SYNC=1
  NEED_DATA_MIGRATIONS=1
fi

if [ "$NEED_SYNC" -eq 1 ]; then
  echo ""
  if [ "$NEED_DATA_MIGRATIONS" -eq 1 ]; then
    echo "👉 권장 로컬 동기화 순서:"
    echo "  1. npm run data:migrate -- up --phase pre-schema --target local --confirm APPLY_DATA_MIGRATIONS"
    if [ "$NEED_PRISMA" -eq 1 ]; then
      echo "  2. npm run db:push"
      echo "  3. npx prisma generate"
      echo "  4. npm run data:migrate -- up --phase post-schema --target local --confirm APPLY_DATA_MIGRATIONS"
    else
      echo "  2. npm run data:migrate -- up --phase post-schema --target local --confirm APPLY_DATA_MIGRATIONS"
    fi
  elif [ "$NEED_PRISMA" -eq 1 ]; then
    echo "👉 필요한 로컬 동기화: npm run db:push && npx prisma generate"
  fi
  if [ "$NEED_SHARED" -eq 1 ]; then
    echo "👉 shared package 동기화: npm run build -w packages/shared"
  fi
  echo ""
fi
